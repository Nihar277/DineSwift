# Copy this file to ".env" (do not commit .env)
# These variables are NOT automatically loaded by ASP.NET Core unless you add a loader.
# You can still use them for local dev, CI, or to document required secrets.

# --- Database ---
PG_CONN=Host=localhost;Port=5432;Database=DineSwift;Username=postgres;Password=CHANGE_ME

# --- Redis ---
REDIS_CONFIGURATION=localhost:6379
REDIS_INSTANCE_NAME=MVC:

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# --- Email / SMTP ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=CHANGE_ME
EMAIL_FROM=your_email@example.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME

# --- JWT ---
JWT_KEY=CHANGE_ME_LONG_RANDOM
JWT_ISSUER=https://localhost:5274
JWT_AUDIENCE=https://localhost:5274
JWT_SUBJECT=JWTServicesAccessToken

# --- Elasticsearch ---
ELASTIC_URL=http://localhost:9200/
ELASTIC_DEFAULT_INDEX=fooditems1
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=CHANGE_ME


