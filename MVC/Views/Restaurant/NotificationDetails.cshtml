@{

    Layout = "_Vendor"; // Restaurant layout
    ViewData["Title"] = "Notification Details";
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}

<style>
    :root {
        --primary-orange: #f97316;
        --deep-orange: #ea580c;
        --orange-light: #fff7ed;
        --text-heading: #0f172a;
        --text-body: #475569;
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .notification-details-container {
        max-width: 800px;
        margin: 30px auto;
        padding: 0 20px;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary-orange);
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 20px;
        padding: 10px 16px;
        border-radius: 8px;
        transition: all 0.2s ease;
        background: var(--orange-light);
        border: 1px solid #fed7aa;
    }

    .back-btn:hover {
        background: var(--primary-orange);
        color: white;
        transform: translateX(-3px);
    }

    .notification-card {
        background: white;
        border-radius: 18px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        position: relative;
    }

    .notification-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg, #f97316, #fb923c, #fbbf24);
    }

    .notification-header {
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        padding: 30px;
        border-bottom: 1px solid #fed7aa;
    }

    .notification-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #f97316, #ea580c);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(249, 115, 22, 0.3);
    }

    .notification-icon i {
        font-size: 1.8rem;
        color: white;
    }

    .notification-title {
        font-size: 1.6rem;
        font-weight: 800;
        color: #9a3412;
        margin-bottom: 10px;
        line-height: 1.4;
    }

    .notification-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 15px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #92400e;
    }

    .meta-item i {
        color: var(--primary-orange);
    }

    .notification-body {
        padding: 30px;
    }

    .notification-content {
        background: #f8fafc;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid #e2e8f0;
        margin-bottom: 25px;
    }

    .notification-content p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--text-body);
        margin: 0;
    }

    .notification-actions {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .action-btn {
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(249, 115, 22, 0.3);
    }

    .btn-secondary {
        background: #f1f5f9;
        color: var(--text-heading);
        border: 1px solid #e2e8f0;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
        transform: translateY(-2px);
    }

    .btn-danger {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .btn-danger:hover {
        background: #fecaca;
        transform: translateY(-2px);
    }

    .related-section {
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid #e2e8f0;
    }

    .related-section h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-heading);
        margin-bottom: 15px;
    }

    .related-notifications {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .related-item {
        padding: 15px;
        background: #f8fafc;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .related-item:hover {
        background: var(--orange-light);
        border-color: #fed7aa;
        transform: translateX(5px);
    }

    .related-item-title {
        font-weight: 600;
        color: var(--text-heading);
        font-size: 0.9rem;
    }

    .related-item-time {
        font-size: 0.8rem;
        color: #94a3b8;
    }

    .notifications-list-container {
        margin-top: 30px;
    }

    .notifications-list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
    }

    .notifications-list-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-heading);
        margin: 0;
    }

    .notifications-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
        max-height: 600px;
        overflow-y: auto;
        padding-right: 10px;
    }

    .notification-list-item {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .notification-list-item:hover {
        border-color: var(--primary-orange);
        box-shadow: 0 4px 12px rgba(249, 115, 22, 0.1);
        transform: translateY(-2px);
    }

    .notification-list-item-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }

    .notification-list-item-title {
        font-weight: 600;
        color: var(--text-heading);
        font-size: 1rem;
        flex: 1;
    }

    .notification-list-item-time {
        font-size: 0.85rem;
        color: #94a3b8;
        white-space: nowrap;
        margin-left: 15px;
    }

    .notification-list-item-sender {
        font-size: 0.9rem;
        color: var(--primary-orange);
        font-weight: 500;
        margin-top: 5px;
    }

    .notification-list-item-message {
        font-size: 0.95rem;
        color: var(--text-body);
        line-height: 1.6;
        margin-top: 8px;
    }

    .notification-list-item-actions {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .delete-btn {
        border: 1px solid #fecaca;
        background: #fee2e2;
        color: #dc2626;
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .delete-btn:hover {
        background: #fecaca;
        transform: translateY(-1px);
    }

    .empty-state {
        text-align: center;
        padding: 60px 30px;
    }

    .empty-state i {
        font-size: 4rem;
        color: #cbd5e1;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        color: var(--text-heading);
        margin-bottom: 10px;
    }

    .empty-state p {
        color: var(--text-body);
        margin-bottom: 25px;
    }

    @@media (max-width: 768px) {
        .notification-details-container {
            margin: 20px auto;
            padding: 0 15px;
        }

        .notification-header {
            padding: 20px;
        }

        .notification-title {
            font-size: 1.3rem;
        }

        .notification-body {
            padding: 20px;
        }

        .notification-actions {
            flex-direction: column;
        }

        .action-btn {
            width: 100%;
            justify-content: center;
        }
    }

    .notification-delete-btn {
        position: absolute;
        top: 18px;
        right: 18px;
        background: transparent;
        border: none;
        color: #ef4444;
        cursor: pointer;
        font-size: 1.1rem;
    }

    .notification-delete-btn:hover {
        color: #b91c1c;
    }
</style>

<div class="notification-details-container">
    <!-- Back Button -->
    <a href="/Restaurant/Dashboard" class="back-btn">
        <i class="bi bi-arrow-left"></i>
        Back to Dashboard
    </a>

    <!-- Notification Card -->
    <div class="notification-card" id="notificationCard">
        <div class="notification-header">
            <div class="notification-icon">
                <i class="bi bi-bell-fill"></i>
            </div>
            <h1 class="notification-title" id="notificationTitle">Notification History</h1>
            <div class="notification-meta">
                <div class="meta-item">
                    <i class="bi bi-collection-fill"></i>
                    <span id="pageNotificationCount">Loading...</span>

                </div>
                <div class="meta-item">
                    <i class="bi bi-clock-fill"></i>
                    <span>All Time</span>
                </div>
                <div class="meta-item">
                    <i class="bi bi-database-fill"></i>
                    <span>Redis</span>
                </div>
            </div>
        </div>

        <div class="notification-body">
            <!-- All Notifications List -->
            <div class="notifications-list-container">
                <div class="notifications-list-header">
                    <h2><i class="bi bi-bell-fill"></i> All Notifications</h2>
                </div>
                <div class="notifications-list" id="allNotificationsList">
                    <div style="text-align: center; padding: 40px; color: #94a3b8;">
                        <i class="bi bi-hourglass-split" style="font-size: 2rem; margin-bottom: 10px;"></i>
                        <p>Loading notifications...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            loadAllNotificationHistory();
        });
        const customerId = @Context.Session.GetInt32("CustomerId");
        function loadAllNotificationHistory() {
            $.ajax({
                url: `http://localhost:5245/api/notifications/restaurant/history/by-customer/${customerId}`,
                type: "GET",
                success: function (res) {
                    console.log("API Response:", res);

                    if (!res.success || !res.messages || res.messages.length === 0) {
                        showEmptyState();
                        return;
                    }

                    displayAllNotifications(res.messages);
                },
                error: function () {
                    showEmptyState();
                }
            });
        }


        @* function displayAllNotifications(messages) {
            const listContainer = $("#allNotificationsList");

            $("#notificationCount").text(`${messages.length} Notifications`);

            if (messages.length === 0) {
                showEmptyState();
                return;
            }

            let html = "";

            // ✅ LATEST FIRST
            messages.slice().reverse().forEach((msg, index) => {
                

                const cleanMsg = msg.replace('[RabbitMQ] ', '').replace('[Redis] ', '');
                const parts = cleanMsg.split("|");

                if (parts.length >= 3) {
                    const sender = parts[0] || "System";
                    const dateStr = parts[1];
                    const message = parts[2] || "";

                    const date = new Date(dateStr);
                    const formattedDate = date.toLocaleString('en-IN');

                    const encodedRaw = encodeURIComponent(cleanMsg);

                    html += `
                                            <div class="notification-list-item" data-raw="${encodedRaw}">
                                                <div class="notification-list-item-header">
                                                    <div class="notification-list-item-title">${message}</div>
                                                    <div class="notification-list-item-actions">
                                                        <div class="notification-list-item-time">${formattedDate}</div>
                                                        <button class="delete-btn" onclick="onDeleteNotification(this)">
                                                            <i class="bi bi-trash3"></i> Delete
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="notification-list-item-sender">
                                                    <i class="bi bi-person-circle"></i> ${sender}
                                                </div>
                                            </div>
                                        `;
                }
            });

            listContainer.html(html);
        } *@

            function displayAllNotifications(messages) {
                const listContainer = $("#allNotificationsList");

                @* $("#notificationCount").text(`${messages.length} Notifications`); *@
                    $("#pageNotificationCount").text(
                        messages.length + " Notification" + (messages.length > 1 ? "s" : "")
                    );


                if (messages.length === 0) {
                    showEmptyState();
                    return;
                }

                let html = "";

                // ✅ LATEST FIRST
                messages.slice().reverse().forEach((msg) => {

                    // 1️⃣ Clean message
                    const cleanMsg = msg.replace('[RabbitMQ] ', '').replace('[Redis] ', '');
                    const parts = cleanMsg.split("|");

                    if (parts.length < 3) return;

                    // 2️⃣ Extract values FIRST
                    const sender = parts[0] || "System";
                    const dateStr = parts[1];
                    const message = parts[2] || "";

                    // 3️⃣ Time calculation
                    const date = new Date(dateStr);
                    const formattedDate = date.toLocaleString('en-IN');
                    const timeAgo = getTimeAgo(date);

                    const encodedRaw = encodeURIComponent(cleanMsg);

                    // 4️⃣ Render HTML
                    html += `
                                    <div class="notification-list-item" data-raw="${encodedRaw}">
                                        <div class="notification-list-item-header">
                                            <div class="notification-list-item-title">${message}</div>
                                            <div class="notification-list-item-actions">
                                                <div class="notification-list-item-time">
                                                    <i class="bi bi-clock"></i> ${formattedDate}
                                                    <br>
                                                    <small style="color:#cbd5e1;">${timeAgo}</small>
                                                </div>
                                                <button class="delete-btn" onclick="onDeleteNotification(this)">
                                                    <i class="bi bi-trash3"></i> Delete
                                                </button>
                                            </div>
                                        </div>
                                        <div class="notification-list-item-sender">
                                            <i class="bi bi-person-circle"></i> ${sender}
                                        </div>
                                    </div>
                                `;
                });

                listContainer.html(html);
            }

        @* function onDeleteNotification(button) {
            const raw = decodeURIComponent($(button).closest(".notification-list-item").data("raw") || "");
            if (!raw) return;

            const confirmDelete = confirm("Delete this notification from history?");
            if (!confirmDelete) return;

            deleteNotification(raw);
        } *@

            function onDeleteNotification(button) {
                const raw = decodeURIComponent($(button).closest(".notification-list-item").data("raw") || "");
                if (!raw) return;

                Swal.fire({
                    title: 'Delete Notification?',
                    text: 'This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#f97316',
                    cancelButtonColor: '#64748b',
                    background: '#fff7ed',
                    color: '#1f2937',
                    iconColor: '#f97316',
                    customClass: {
                        popup: 'swal-orange-popup',
                        confirmButton: 'swal-orange-confirm',
                        cancelButton: 'swal-orange-cancel'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        deleteNotification(raw);
                    }
                });
            }


        function deleteNotification(rawMessage) {
            $.ajax({
                url: `http://localhost:5245/api/notifications/restaurant/delete/by-customer/${customerId}`,
                type: "DELETE",
                contentType: "application/json",
                data: JSON.stringify({ message: rawMessage }),
                success: function (res) {
                    if (res.success) {

                        Swal.fire({
                            title: 'Deleted!',
                            text: 'Notification successfully removed.',
                            icon: 'success',
                            confirmButtonText: 'OK',
                            confirmButtonColor: '#f97316',
                            background: '#fff7ed',
                            color: '#1f2937',
                            iconColor: '#f97316',
                            customClass: {
                                popup: 'swal-orange-popup',
                                confirmButton: 'swal-orange-confirm'
                            }
                        }).then(() => {
                            loadAllNotificationHistory();
                        });

                    } else {
                        Swal.fire({
                            title: 'Error',
                            text: 'Could not delete notification.',
                            icon: 'error',
                            confirmButtonColor: '#f97316'
                        });
                    }
                },
                error: function () {
                    Swal.fire({
                        title: 'Failed',
                        text: 'Something went wrong while deleting.',
                        icon: 'error',
                        confirmButtonColor: '#f97316'
                    });
                }
            });
        }


        function getTimeAgo(date) {
            const now = new Date();
            const diffMs = now - date;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);

            if (diffMins < 1) return "Just now";
            if (diffMins < 60) return `${diffMins} minute${diffMins > 1 ? 's' : ''} ago`;
            if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
            if (diffDays < 7) return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;

            const diffWeeks = Math.floor(diffDays / 7);
            if (diffWeeks < 4) return `${diffWeeks} week${diffWeeks > 1 ? 's' : ''} ago`;

            const diffMonths = Math.floor(diffDays / 30);
            return `${diffMonths} month${diffMonths > 1 ? 's' : ''} ago`;
        }

        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }
        function showEmptyState() {
            $("#pageNotificationCount").text("0 Notifications");

            $("#allNotificationsList").html(`
                <div class="empty-state">
                    <i class="bi bi-bell-slash"></i>
                    <h2>No Notifications</h2>
                    <p>No notification history found.</p>
                </div>
            `);
        }

    </script>

}