@{
    ViewData["Title"] = "Change Password";
    var customerId = Context.Session.GetInt32("CustomerId");
    Layout = "_Vendor";
}
@if (customerId == 0)
{
    <script>
        window.location.href = "http://localhost:5030/";
    </script>
}

@section Styles {
    <style>
        .change-password-wrapper {
            
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            background: linear-gradient(180deg, #ffffff 0%, #fffaf5 100%);
            position: relative;
        }

        .back-link {
            position: absolute;
            top: 24px;
            left: 24px;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            color: #6b7280;
            font-size: 1.1rem;
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .back-link:hover {
            background: #fff7ed;
            border-color: hsl(var(--primary));
            color: hsl(var(--primary));
            transform: translateX(-2px);
        }

        .password-card {
            width: 100%;
            max-width: 480px;
            background: #fff;
            border-radius: 20px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

        .password-card-header {
            background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
            padding: 32px 28px;
            text-align: center;
            border-bottom: 1px solid #fed7aa;
        }

        .icon-circle {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--primary-dark)) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 2rem;
            box-shadow: 0 8px 24px rgba(249, 115, 22, 0.35);
        }

        .password-card-header h2 {
            margin: 0 0 8px;
            font-size: 1.6rem;
            font-weight: 700;
            color: #1f2937;
            letter-spacing: -0.02em;
        }

        .password-card-header p {
            margin: 0;
            font-size: 0.95rem;
            color: #9a3412;
        }

        .password-card-body {
            padding: 32px;
        }

        .password-form-group {
            margin-bottom: 24px;
        }

        .password-form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 10px;
        }

        .password-form-group .form-control {
            width: 100%;
            padding: 14px 18px;
            font-size: 0.95rem;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            background: linear-gradient(#fff, #fafafa);
            transition: all 0.25s ease;
            box-sizing: border-box;
        }

        .password-form-group .form-control:focus {
            outline: none;
            border-color: hsl(var(--primary));
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.12);
            background: #fff;
        }

        .password-form-group .form-control::placeholder {
            color: #9ca3af;
        }

        .password-hint {
            font-size: 0.75rem;
            color: #6b7280;
            margin-top: 8px;
            display: block;
        }

        .btn-submit-password {
            width: 100%;
            padding: 16px 24px;
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--primary-dark)) 100%);
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 6px 20px rgba(249, 115, 22, 0.35);
            margin-top: 8px;
        }

        .btn-submit-password:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(249, 115, 22, 0.45);
        }

        .btn-submit-password:active {
            transform: translateY(0);
        }

        .k-invalid-msg {
            display: block;
            font-size: 0.75rem;
            color: #ef4444;
            margin-top: 8px;
        }

        .password-form-group .form-control.k-invalid {
            border-color: #ef4444 !important;
            box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1) !important;
        }

        @@media (max-width: 480px) {
            .password-card {
                border-radius: 16px;
            }

            .password-card-header {
                padding: 24px 20px;
            }

            .password-card-body {
                padding: 24px;
            }
        }
    </style>
}

<div class="change-password-wrapper">
    <a href="javascript:history.back()" class="back-link">
        <i class="fa-solid fa-arrow-left"></i>
    </a>

    <span id="notification"></span>

    <div class="password-card">
        <div class="password-card-header">
            <div class="icon-circle">
                <i class="fa-solid fa-lock" style="color: #fff;"></i>
            </div>
            <h2>Change Password</h2>
            <p>Keep your account secure</p>
        </div>

        <div class="password-card-body">
            <form id="changePasswordForm">
                <div class="password-form-group">
                    <label for="OldPassword">Current Password</label>
                    <input type="password" class="form-control" id="OldPassword" name="OldPassword"
                        placeholder="Enter current password" required />
                </div>

                <div class="password-form-group">
                    <label for="NewPassword">New Password</label>
                    <input type="password" class="form-control" id="NewPassword" name="NewPassword"
                        placeholder="Create a strong password" required />
                    <span class="password-hint">Min 8 chars, uppercase, lowercase, number & special character</span>
                </div>

                <div class="password-form-group">
                    <label for="ConfirmPassword">Confirm New Password</label>
                    <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword"
                        placeholder="Re-enter new password" required />
                </div>

                <button type="button" class="btn-submit-password" id="btnSubmit">
                    <i class="fa-solid fa-shield-check me-2"></i>Update Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const OrangeSwal = Swal.mixin({
            confirmButtonColor: '#f97316',   // same vendor/orange theme
            cancelButtonColor: '#64748b',
            background: '#fff7ed',
            color: '#1f2937',
            iconColor: '#f97316',
            showClass: {
                popup: 'animate__animated animate__fadeInDown'
            },
            hideClass: {
                popup: 'animate__animated animate__fadeOutUp'
            }
        });
    </script>

    <script>
        $(document).ready(function () {
            $("#notification").kendoNotification({
                position: { top: 20, right: 20 },
                autoHideAfter: 3000
            });

            kendo.ui.validator.rules.strongPassword = function (input) {
                if (input.is("[name='NewPassword']")) {
                    return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&]).{8,}$/.test(input.val());
                }
                return true;
            };
            kendo.ui.validator.messages.strongPassword = "Min 8 chars, uppercase, lowercase, number & special character";

            kendo.ui.validator.rules.passwordMatch = function (input) {
                if (input.is("[name='ConfirmPassword']")) {
                    return input.val() === $("[name='NewPassword']").val();
                }
                return true;
            };
            kendo.ui.validator.messages.passwordMatch = "Passwords do not match";

            const validator = $("#changePasswordForm").kendoValidator({ validateOnBlur: true }).data("kendoValidator");

            $("#btnSubmit").click(function () {
                if (!validator.validate()) return;

                const payload = {
                    CustomerId: @customerId,
                    OldPassword: $("[name='OldPassword']").val(),
                    NewPassword: $("[name='NewPassword']").val()
                };

                $.ajax({
                    url: "http://localhost:5245/api/restaurant/change-password",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(payload),
                    success: function (res) {

                        if (res.success) {
                            OrangeSwal.fire({
                                icon: 'success',
                                title: 'Password Updated',
                                text: res.message || 'Your password has been changed successfully.',
                                timer: 1800,
                                showConfirmButton: false
                            });

                            // 🔥 Clear fields after success
                            $("#OldPassword").val("");
                            $("#NewPassword").val("");
                            $("#ConfirmPassword").val("");

                        } else {
                            OrangeSwal.fire({
                                icon: 'error',
                                title: 'Change Failed',
                                text: res.message || 'Old password is incorrect'
                            });
                        }
                    },
                    error: function () {
                        OrangeSwal.fire({
                            icon: 'error',
                            title: 'Server Error',
                            text: 'Something went wrong. Please try again later.'
                        });
                    }
                });
            });
        });

        @* success: function (res) {
            $("#notification").data("kendoNotification").show(res.message, res.success ? "success" : "error");
        },
        error: function () {
            $("#notification").data("kendoNotification").show("Server error", "error");
        } *@
    </script>
}