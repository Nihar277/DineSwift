@{
    ViewData["Title"] = "Vendor Profile";
    int customerId = Context.Session.GetInt32("CustomerId") ?? 0;
    Layout = "_Vendor";
}
@if (customerId == 0)
{
    <script>
        window.location.href = "http://localhost:5030/";
    </script>
}
<style>
    :root {
        --vendor-primary: #8B4513;
        /* Brown color for vendor */
        --vendor-primary-dark: #654321;
        --vendor-primary-light: #F5F1E8;
        --text-dark: #2C1810;
        --text-medium: #6B4F3F;
        --border-color: #E8D9C9;
        --bg-light: #FAF7F2;
    }

    * {
        font-family: 'Poppins', sans-serif;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, #FAF7F2 0%, #FFFFFF 50%, #F5F1E8 100%);
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    /* Vendor specific background */
    .vendor-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .vendor-3d {
        position: absolute;
        font-size: 70px;
        opacity: 0.1;
        animation: floatVendor 20s ease-in-out infinite;
    }

    .vendor-3d:nth-child(1) {
        top: 10%;
        left: 10%;
        animation-delay: 0s;
    }

    .vendor-3d:nth-child(2) {
        top: 70%;
        right: 15%;
        animation-delay: 5s;
    }

    .vendor-3d:nth-child(3) {
        top: 40%;
        right: 5%;
        animation-delay: 10s;
    }

    @@keyframes floatVendor {

        0%,
        100% {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(5deg);
        }
    }

    .profile-container {
        max-width: 1000px;
        margin: 30px auto;
        padding: 0 20px;
        position: relative;
        z-index: 10;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 50px rgba(139, 69, 19, 0.1);
        animation: cardSlide 0.6s ease-out;
        border: 1px solid rgba(139, 69, 19, 0.1);
    }

    @@keyframes cardSlide {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card-header {
        background: linear-gradient(135deg,
                rgba(139, 69, 19, 0.9) 0%,
                rgba(101, 67, 33, 0.9) 100%);
        color: white;
        padding: 35px 40px;
        position: relative;
        overflow: hidden;
    }

    .card-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg,
                #FFD700 0%,
                #DAA520 50%,
                #FFD700 100%);
    }

    .vendor-badge {
        position: absolute;
        right: 40px;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.15);
        padding: 15px 25px;
        border-radius: 50px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .vendor-badge::before {
        content: '👨‍🍳';
        font-size: 20px;
    }

    .header-content {
        position: relative;
        z-index: 2;
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 10px;
    }

    .brand-logo span {
        font-size: 36px;
        animation: logoPulse 3s ease-in-out infinite;
    }

    .card-header h3 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: white;
    }

    .card-header p {
        margin: 8px 0 0;
        color: rgba(255, 255, 255, 0.9);
        font-size: 15px;
    }

    .profile-content {
        padding: 40px;
        background: rgba(255, 255, 255, 0.9);
    }

    /* Profile Image Section */
    .profile-image-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 40px;
        padding: 30px;
        background: var(--bg-light);
        border-radius: 15px;
        border: 2px dashed var(--border-color);
    }

    .image-container {
        position: relative;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        overflow: hidden;
        border: 5px solid white;
        box-shadow: 0 10px 30px rgba(139, 69, 19, 0.2);
        margin-bottom: 20px;
    }

    .profile-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .image-container:hover .profile-image {
        transform: scale(1.05);
    }

    .image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(139, 69, 19, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
        cursor: pointer;
    }

    .image-container:hover .image-overlay {
        opacity: 1;
    }

    .upload-btn {
        background: white;
        color: var(--vendor-primary);
        padding: 10px 20px;
        border-radius: 25px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
    }

    .upload-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3);
    }

    #profileUpload {
        display: none;
    }

    .image-hint {
        color: var(--text-medium);
        font-size: 13px;
        text-align: center;
        margin-top: 10px;
    }

    /* Form Styles */
    .k-form {
        max-width: 800px;
        margin: 0 auto;
    }

    .k-form .k-form-field {
        margin-bottom: 25px;
    }

    .k-form-label {
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
    }

    /* ===== KENDO INPUT WRAPPER ===== */
    #vendorProfileForm .k-input,
    #vendorProfileForm .k-textbox,
    #vendorProfileForm .k-dropdown,
    #vendorProfileForm .k-textarea {
        border: 2px solid var(--border-color);
        border-radius: 10px;
        padding: 4px;
        background: white;
        transition: all 0.25s ease;
    }

    /* ===== INNER INPUT (CLEAN) ===== */
    #vendorProfileForm .k-input-inner,
    #vendorProfileForm textarea {
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
        background: transparent !important;
        padding: 12px 14px;
        font-size: 15px;
        color: var(--text-dark);
        width: 100%;
    }

    .k-form,
    .k-form-inline {
        color: #e31414;
    }

    /* ===== FOCUS ONLY ON WRAPPER ===== */
    #vendorProfileForm .k-input:focus-within,
    #vendorProfileForm .k-dropdown:focus-within,
    #vendorProfileForm .k-textarea:focus-within {
        border-color: var(--vendor-primary);
        box-shadow: 0 0 0 4px rgba(139, 69, 19, 0.15);
    }

    @* .k-textbox,
    .k-textarea,
    .k-dropdown {
        border: 2px solid var(--border-color);
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 15px;
        transition: all 0.3s;
        width: 100%;
        background: white;
    }
*@

    .k-textbox:focus,
    .k-textarea:focus,
    .k-dropdown:focus {
        border-color: var(--vendor-primary);
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        outline: none;
    }

    /* Email field - read only */
    .email-readonly {
        background: #f8f8f8;
        color: #666;
        cursor: not-allowed;
    }

    /* Gender Options */
    .gender-options {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }

    .gender-option {
        flex: 1;
        position: relative;
    }

    .gender-option input[type="radio"] {
        position: absolute;
        opacity: 0;
        
    }

    .gender-option label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px;
        border: 2px solid var(--border-color);
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.3s;
        font-weight: 500;
        color: var(--text-medium);
        background: white;
        text-align: center;
    }

    .gender-option:nth-child(1) label::before {
        content: '👨';
    }

    .gender-option:nth-child(2) label::before {
        content: '👩';
    }

    .gender-option:nth-child(3) label::before {
        content: '🧑';
    }

    .gender-option input[type="radio"]:checked+label {
        background: var(--vendor-primary-light);
        border-color: var(--vendor-primary);
        color: var(--vendor-primary-dark);
        font-weight: 600;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid var(--border-color);
    }

    .k-button {
        padding: 14px 30px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s;
        border: 2px solid transparent;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: var(--vendor-primary);
        color: white;
    }

    .btn-primary:hover {
        background: var(--vendor-primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(139, 69, 19, 0.2);
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
        border-color: #6c757d;
    }

    .btn-secondary:hover {
        background: #5a6268;
        transform: translateY(-2px);
    }

    .btn-change-password {
        background: #17a2b8;
        color: white;
        border-color: #17a2b8;
    }

    .btn-change-password:hover {
        background: #138496;
        transform: translateY(-2px);
    }

    /* Notification */
    .k-notification {
        font-family: 'Poppins', sans-serif;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .profile-container {
            margin: 15px auto;
            padding: 0 15px;
        }

        .profile-content {
            padding: 20px;
        }

        .card-header {
            padding: 25px 20px;
        }

        .vendor-badge {
            position: relative;
            right: auto;
            top: auto;
            transform: none;
            margin-top: 15px;
            display: inline-flex;
        }

        .action-buttons {
            flex-direction: column;
        }

        .gender-options {
            flex-direction: column;
        }

        .image-container {
            width: 140px;
            height: 140px;
        }
    }
</style>

<!-- Vendor Background -->
<div class="vendor-background">
    <div class="vendor-3d">🍴</div>
    <div class="vendor-3d">👨‍🍳</div>
    <div class="vendor-3d">🏪</div>
</div>

<div class="profile-container">
    <div class="profile-card">
        <div class="card-header">
            <div class="header-content">
                <div class="brand-logo">
                    <span>👨‍🍳</span>
                    <h3>Vendor Profile</h3>
                </div>
                <p>Manage your personal information and settings</p>
            </div>
            <div class="vendor-badge">Verified Restaurant Owner</div>
        </div>

        <div class="profile-content">
            <!-- Profile Image Upload -->
            <div class="profile-image-section">
                <div class="image-container">
                    <img id="previewProfile" class="profile-image" src="/Images/no-profile.png" alt="Profile Image" />
                    <div class="image-overlay">
                        <label for="profileUpload" class="upload-btn">
                            <i class="k-icon k-i-upload"></i> Change Photo
                        </label>
                    </div>
                </div>
                <input type="file" id="profileUpload" accept="image/*" />
                <p class="image-hint">Max size: 2MB, Formats: JPG, PNG, JPEG</p>
            </div>
            <input type="hidden" id="c_customerid" value="@customerId" />

            <!-- Profile Form -->
            <div id="notification"></div>
            <form id="vendorProfileForm" onsubmit="return false;"></form>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button type="button" id="btnCancel" class="btn-secondary k-button">
                    <i class="k-icon k-i-cancel"></i> Cancel
                </button>
                <button type="button" id="btnChangePassword" class="btn-change-password k-button">
                    <i class="k-icon k-i-lock"></i> Change Password
                </button>
                <button type="button" id="btnUpdate" class="btn-primary k-button">
                    <i class="k-icon k-i-save"></i> Update Profile
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        const OrangeSwal = Swal.mixin({
            confirmButtonColor: '#8B4513',   // vendor brown
            cancelButtonColor: '#6c757d',
            background: '#FAF7F2',
            color: '#2C1810',
            iconColor: '#8B4513',
            showClass: {
                popup: 'animate__animated animate__fadeInDown'
            },
            hideClass: {
                popup: 'animate__animated animate__fadeOutUp'
            }
        });
    </script>

    <script>
        $(document).ready(function () {

            const customerId = @customerId;
            @* console.log(customerId); *@
                        if (!customerId || customerId === 0) {
                window.location.href = "http://localhost:5030/";
                return;
            }

            // ================= Notification =================
            $("#notification").kendoNotification({
                position: { top: 20, right: 20 },
                autoHideAfter: 3000,
                stacking: "down"
            });

            // ================= LOAD PROFILE =================
            loadVendorProfile();

            function loadVendorProfile() {
                $.ajax({
                    url: "http://localhost:5245/api/restaurant/customer/" + customerId,
                    type: "GET",
                    success: function (res) {
                        if (res.success && res.data) {
                            updateProfileImage(res.data.c_image);
                            initializeVendorForm(res.data);
                        } else {
                            showNotification("Failed to load profile", "error");
                        }
                    },
                    error: function () {
                        showNotification("Profile load error", "error");
                    }
                });
            }

            // ================= IMAGE PREVIEW =================
            function updateProfileImage(imageName) {
                if (imageName) {
                    $("#previewProfile").attr(
                        "src",
                        "/Images/customer/" + imageName + "?v=" + new Date().getTime()
                    );
                } else {
                    $("#previewProfile").attr("src", "/Images/no-profile.png");
                }
            }

            // ================= KENDO FORM =================
            function initializeVendorForm(data) {
                // 🔥 DESTROY EXISTING FORM (VERY IMPORTANT)
                const existingForm = $("#vendorProfileForm").data("kendoForm");
                if (existingForm) {
                    existingForm.destroy();
                    $("#vendorProfileForm").empty(); // 🔥 remove old HTML
                }

                $("#vendorProfileForm").kendoForm({
                    formData: data,
                    buttonsTemplate: "",
                    // 🔥 SAME PATTERN AS REGISTER FORM
                    validatable: {
                        validateOnBlur: true,
                        validationSummary: false,
                        errorTemplate: "<span class='k-invalid-msg'>#: message #</span>"
                    },
                    items: [



                        {
                            type: "group",
                            layout: "grid",
                            grid: { cols: 2 },
                            items: [
                                {
                                    field: "c_fname", label: "First Name", validation: {
                                        required: { message: "Name is required" }
                                    }
                                },
                                {
                                    field: "c_lname", label: "Last Name", validation: {
                                        required: { message: "Last Name is required" }
                                    }
                                }
                            ]
                        },

                        {
                            field: "c_email",
                            label: "Email",
                            editor: (c, o) =>
                                $("<input readonly class='k-textbox email-readonly' />")
                                    .attr("name", o.field)
                                    .val(o.model.c_email)
                                    .appendTo(c)
                        },


                        {
                            field: "c_phonenumber",
                            label: "Phone",
                            validation: {
                                required: { message: "Phone Number is required" },
                                pattern: { value: "^[6-9]\\d{9}$", message: "Invalid phone" }
                            }
                        },

                        {
                            field: "c_gender",
                            label: "Gender",
                            editor: function (container, options) {
                                const genders = ["Male", "Female", "Other"];
                                const div = $('<div class="gender-options"></div>').appendTo(container);
                                genders.forEach(g => {
                                    div.append(
                                        `<div class="gender-option">       <input type="radio" name="${options.field}" value="${g}" id="gender_${g}" required>       <label for="gender_${g}"><span>${g}</span></label>   </div>`
                                    );
                                });
                            },
                            validation: { required: { message: "Please select gender" } }
                        },

                        {
                            field: "c_address", label: "Address", editor: "TextArea", validation: {
                                required: { message: "Address is required" }
                            }
                        },

                        {
                            type: "group",
                            layout: "grid",
                            grid: { cols: 2 },
                            items: [

                                // ================= STATE DROPDOWN =================
                                {
                                    field: "c_state",
                                    label: "State",
                                    editor: function (container, options) {

                                        $('<input name="' + options.field + '" data-bind="value:' + options.field + '" required data-required-msg="State is required" />')
                                            .appendTo(container)
                                            .kendoDropDownList({
                                                optionLabel: "Select State",
                                                dataTextField: "c_sname",
                                                dataValueField: "c_sname",
                                                dataSource: {
                                                    transport: {
                                                        read: "http://localhost:5245/api/restaurant/states"
                                                    }
                                                },
                                                change: function () {
                                                    const cityDDL = $("[name='c_city']").data("kendoDropDownList");
                                                    if (cityDDL) {
                                                        cityDDL.value("");
                                                        cityDDL.enable(true);
                                                        cityDDL.dataSource.read();
                                                    }
                                                }
                                            });
                                    },
                                    validation: { required: true }
                                },

                                // ================= CITY DROPDOWN =================
                                {
                                    field: "c_city",
                                    label: "City",
                                    editor: function (container, options) {

                                        $('<input name="' + options.field + '" data-bind="value:' + options.field + '" required data-required-msg="City is required" />')
                                            .appendTo(container)
                                            .kendoDropDownList({
                                                optionLabel: "Select City",
                                                dataTextField: "cityname",
                                                dataValueField: "cityname",
                                                autoBind: false,
                                                enable: false,
                                                dataSource: {
                                                    transport: {
                                                        read: {
                                                            url: function () {

                                                                const stateDDL = $("[name='c_state']").data("kendoDropDownList");
                                                                const stateData = stateDDL.dataSource.data();
                                                                const selectedItem = stateData.find(s => s.c_sname === stateDDL.value());
                                                                return "http://localhost:5245/api/restaurant/cities/" + (selectedItem ? selectedItem.id : 0);
                                                            },
                                                            dataType: "json"
                                                        }
                                                    }
                                                }
                                            });
                                    },
                                    validation: { required: true }
                                },


                            ]
                        },
                        {
                            field: "c_pincode",
                            label: "Pincode",
                            validation: {
                                required: { message: "Pincode is required" },
                                pattern: { value: "^\\d{6}$", message: "6 digit pincode" }
                            }
                        }
                    ],

                });

                setTimeout(() => {
                    const stateDDL = $("[name='c_state']").data("kendoDropDownList");
                    const cityDDL = $("[name='c_city']").data("kendoDropDownList");

                    if (stateDDL) {

                        stateDDL.value(data.c_state);


                        cityDDL.enable(true);
                        cityDDL.dataSource.read().then(function () {

                            cityDDL.value(data.c_city);
                        });
                    }
                }, 800);
                // 🔥 DATA BIND AFTER CREATE
                const form = $("#vendorProfileForm").data("kendoForm");
                form.value(data);   // ✅ THIS FIXES AUTO LOAD
            }

            // ================= IMAGE UPLOAD =================
            $("#profileUpload").change(function () {
                const file = this.files[0];
                if (!file) return;

                if (file.size > 2 * 1024 * 1024) {
                    showNotification("Max 2MB allowed", "warning");
                    this.value = "";
                    return;
                }

                const reader = new FileReader();
                reader.onload = e => $("#previewProfile").attr("src", e.target.result);
                reader.readAsDataURL(file);
            });

            // ================= UPDATE PROFILE =================
            $("#btnUpdate").click(function () {

                const form = $("#vendorProfileForm").data("kendoForm");

                if (!form || !form.validate()) {
                    showNotification("Fix validation errors", "warning");
                    return;
                }

                const fd = new FormData();

                // ✅ AUTO COLLECT ALL FORM VALUES
                $("#vendorProfileForm").find(":input[name]").each(function () {

                    const $el = $(this);

                    // Radio: only checked
                    if ($el.attr("type") === "radio") {
                        if ($el.is(":checked")) {
                            fd.append(this.name, $el.val());
                        }
                        return;
                    }

                    // Dropdowns handled below
                    if ($el.hasClass("k-input")) return;

                    fd.append(this.name, $el.val());
                });

                fd.append("c_customerid", @customerId);

                // ✅ KENDO DROPDOWNS (CORRECT WAY)
                fd.append(
                    "c_state",
                    $("[name='c_state']").data("kendoDropDownList").text()
                );

                fd.append(
                    "c_city",
                    $("[name='c_city']").data("kendoDropDownList").text()
                );

                // ✅ IMAGE FILE
                const img = $("#profileUpload")[0].files[0];
                if (img) fd.append("c_imagefile", img);

                $.ajax({
                    url: "http://localhost:5245/api/restaurant/customer",
                    type: "PUT",
                    data: fd,
                    contentType: false,
                    processData: false,
                    success: res => {

                        if (!res.success) {
                            OrangeSwal.fire({
                                icon: 'error',
                                title: 'Update Failed',
                                text: res.message || 'Something went wrong'
                            });
                            return;
                        }

                        // ✅ SUCCESS SWEETALERT
                        OrangeSwal.fire({
                            icon: 'success',
                            title: 'Profile Updated',
                            text: 'Your vendor profile has been updated successfully.',
                            timer: 1800,
                            showConfirmButton: false
                        });

                        // 🔄 Refresh profile image only
                        if (res.image) {
                            updateProfileImage(res.image);
                        }
                    },
                    error: xhr => {
                        OrangeSwal.fire({
                            icon: 'error',
                            title: 'Update Failed',
                            text: 'Validation failed. Please check all fields.'
                        });
                    }



                });
            });

            @* success: res => {

                        if (!res.success) {
                            showNotification(res.message || "Update failed", "error");
                            return;
                        }

                        showNotification("Profile updated successfully", "success");

                        // 🔥 ONLY IMAGE REFRESH
                        if (res.image) {
                            updateProfileImage(res.image);
                        }
                    },
                    error: xhr => {
                        console.error(xhr.responseText);
                        showNotification("Validation failed (400)", "error");
                    } *@
                    $("#btnCancel").click(() => location.reload());
            $("#btnChangePassword").click(() => location.href = "/Restaurant/ChangePassword");

            function showNotification(msg, type) {
                $("#notification").data("kendoNotification").show(msg, type);
            }

        });
    </script>
}