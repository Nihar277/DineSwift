<script>
    const USER_ID = "@Context.Session.GetInt32("CustomerId")";

    function loadCartCount() {
        if (!USER_ID) return;

        $.get(`http://localhost:5245/api/userHome/GetCartItems?userid=${USER_ID}`, function (res) {

            let items = res.data ?? res;

            // ✅ COUNT ONLY ROWS (NOT QUANTITY)
