@* <!DOCTYPE html>
<html lang="en">

<head>
    <!-- ================= META ================= -->
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - DineSwift</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ================= CSS ================= -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/css/_Vendor.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/RestaurantProfileUpdate.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @RenderSection("Styles", required: false)

</head>

<body>
    <div class="app-wrapper">

        <!-- ================= SIDEBAR ================= -->
        <aside class="sidebar">

            <!-- Logo -->
            <div class="sidebar-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 100 100" class="logo-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Steam Lines -->
                        <path class="steam steam-1" d="M35 25 Q37 20 35 15" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" />
                        <path class="steam steam-2" d="M50 22 Q52 17 50 12" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" />
                        <path class="steam steam-3" d="M65 25 Q67 20 65 15" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" />

                        <!-- Cloche Handle -->
                        <circle class="cloche-part" cx="50" cy="32" r="6" fill="currentColor" />

                        <!-- Cloche Dome -->
                        <path class="cloche-part" d="M20 55 Q20 35 50 35 Q80 35 80 55 L20 55" fill="currentColor" />

                        <!-- Plate -->
                        <rect x="15" y="55" width="70" height="8" rx="4" fill="currentColor" />

                        <!-- Left Wheel -->
                        <g class="wheel wheel-left">
                            <circle cx="30" cy="75" r="10" stroke="currentColor" stroke-width="3" fill="none" />
                            <line x1="30" y1="68" x2="30" y2="82" stroke="currentColor" stroke-width="2" />
                            <line x1="23" y1="75" x2="37" y2="75" stroke="currentColor" stroke-width="2" />
                        </g>

                        <!-- Right Wheel -->
                        <g class="wheel wheel-right">
                            <circle cx="70" cy="75" r="10" stroke="currentColor" stroke-width="3" fill="none" />
                            <line x1="70" y1="68" x2="70" y2="82" stroke="currentColor" stroke-width="2" />
                            <line x1="63" y1="75" x2="77" y2="75" stroke="currentColor" stroke-width="2" />
                        </g>

                        <!-- Axles -->
                        <line x1="30" y1="65" x2="30" y2="75" stroke="currentColor" stroke-width="3" />
                        <line x1="70" y1="65" x2="70" y2="75" stroke="currentColor" stroke-width="3" />
                    </svg>
                </div>

                <div class="logo-text">
                    <h3>DineSwift</h3>
                    <span>Restaurant Panel</span>
                </div>
            </div>

            <!-- Menu -->
            <nav class="sidebar-menu">
                <a asp-controller="Restaurant" asp-action="Dashboard"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Restaurant" asp-action="RestaurantProfileUpdate"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "RestaurantProfileUpdate" ? "active" : "")">
                    <i class="fa-solid fa-user"></i>
                    <span>Restaurant Profile</span>
                </a>

                <a asp-controller="Restaurant" asp-action="VendorProfile"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "VendorProfile" ? "active" : "")">
                    <i class="fa-solid fa-id-card"></i>
                    <span>Vendor Profile</span>
                </a>

                <a asp-controller="Restaurant" asp-action="MenuItems"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "MenuItems" ? "active" : "")">
                    <i class="fa-solid fa-utensils"></i>
                    <span>Menu Items</span>
                </a>

                <a asp-controller="Restaurant" asp-action="Orders"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-receipt"></i>
                    <span>Orders</span>
                </a>
            </nav>

            <!-- Footer -->
            <div class="sidebar-footer">
                <a href="javascript:void(0)" onclick="logoutConfirm()" class="menu-item logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Logout</span>
                </a>
            </div>

        </aside>

        <!-- ================= MAIN CONTENT ================= -->
        <main class="main-content">
            <div class="notification-wrapper">
                <button id="notificationBtn" class="notification-btn">
                    <i class="bi bi-bell-fill"></i>
                    <span id="notificationCount" class="notification-count d-none">0</span>
                </button>

                <div id="notificationDropdown" class="notification-dropdown d-none">
                    <div class="notification-header d-flex justify-content-between align-items-center">
                        <strong>Notifications</strong>

                        <!-- ✅ VIEW ALL LINK -->
                        <a href="/Restaurant/NotificationDetails" class="view-all-link"
                            style="font-size:12px; font-weight:600; color:#f97316; text-decoration:none;">
                            View All
                        </a>
                    </div>

                    <div id="notificationList" class="notification-list">
                        <p class="text-muted p-2">No notifications</p>
                    </div>
                </div>

            </div>

            @RenderBody()
        </main>

    </div>

    <!-- ================= SCRIPTS ================= -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/kendo/kendo.all.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <!-- 🔔 RESTAURANT NOTIFICATION SCRIPT -->
    <script>
        let unreadCount = 0;
        let notificationsLoaded = false;
        window.customerId = @Context.Session.GetInt32("CustomerId");
        const NOTIFICATION_COUNT_KEY = `notification_count_restaurant_${window.customerId}`;

        // Load count from localStorage on page load
        function loadStoredCount() {
            const stored = localStorage.getItem(NOTIFICATION_COUNT_KEY);
            console.log("Loading stored count (restaurant):", stored);
            if (stored !== null) {
                unreadCount = parseInt(stored) || 0;
                console.log("Stored count loaded (restaurant):", unreadCount);
            } else {
                console.log("No stored count found (restaurant)");
                unreadCount = 0;
            }

            // Always update UI based on current count
            if (unreadCount > 0) {
                $("#notificationCount")
                    .text(unreadCount)
                    .removeClass("d-none")
                    .css("display", "flex");
                console.log("Count displayed (restaurant):", unreadCount);
            } else {
                $("#notificationCount")
                    .addClass("d-none")
                    .css("display", "none");
            }
        }

        // Save count to localStorage
        function saveCount(count) {
            unreadCount = count;
            localStorage.setItem(NOTIFICATION_COUNT_KEY, count.toString());
            console.log("Saving count to localStorage (restaurant):", count);

            // Always update UI
            if (count > 0) {
                $("#notificationCount")
                    .text(count)
                    .removeClass("d-none")
                    .css("display", "flex");
                console.log("Count displayed in UI (restaurant):", count);
            } else {
                $("#notificationCount")
                    .addClass("d-none")
                    .css("display", "none");
                console.log("Count hidden (0) (restaurant)");
            }
        }

        function formatNotification(raw) {
            raw = raw.replace('[RabbitMQ] ', '').replace('[Redis] ', '');
            const parts = raw.split('|');

            const msg = parts[2] ?? raw;
            const time = parts[1]
                ? new Date(parts[1]).toLocaleString('en-IN')
                : '';

            return `
            <div class="notification-item">
                <strong>${msg}</strong><br/>
                <small class="text-muted">${time}</small>
            </div>
        `;
        }

        // Store notifications in localStorage (newest at the end)
        function storeNotifications(messages) {
            const NOTIFICATIONS_KEY = `notifications_restaurant_${window.customerId}`;
            const existing = JSON.parse(localStorage.getItem(NOTIFICATIONS_KEY) || '[]');
            const combined = [...existing, ...messages]; // Append new messages to the end
            localStorage.setItem(NOTIFICATIONS_KEY, JSON.stringify(combined));
            return combined;
        }

        // Get stored notifications from localStorage
        function getStoredNotifications() {
            const NOTIFICATIONS_KEY = `notifications_restaurant_${window.customerId}`;
            return JSON.parse(localStorage.getItem(NOTIFICATIONS_KEY) || '[]');
        }

        // Clear stored notifications
        function clearStoredNotifications() {
            const NOTIFICATIONS_KEY = `notifications_restaurant_${window.customerId}`;
            localStorage.removeItem(NOTIFICATIONS_KEY);
        }

        // Check for new notifications and update count (consumes messages)
        function checkNotificationCount() {
            if (!window.customerId) {
                console.log("No customerId found (restaurant)");
                return;
            }

            $.get(`http://localhost:5245/api/notifications/restaurant/by-customer/${window.customerId}`,
                function (res) {
                    console.log("Notification check response (restaurant):", res);
                    if (res.success && res.messages && res.messages.length > 0) {
                        // Store notifications in localStorage
                        storeNotifications(res.messages);

                        // New notifications found, add to existing count
                        const newCount = unreadCount + res.messages.length;
                        console.log(`Found ${res.messages.length} new notifications (restaurant). Total count: ${newCount}`);
                        saveCount(newCount);
                    } else {
                        console.log("No new notifications found (restaurant)");
                    }
                }).fail(function (xhr, status, error) {
                    console.error("Failed to check notifications (restaurant):", error, xhr);
                });
        }

        // Load and show notifications from localStorage (when user clicks bell)
        function loadNotifications() {
            if (!window.customerId) return;

            const list = $("#notificationList");
            const storedNotifications = getStoredNotifications();

            console.log("Loading notifications from storage (restaurant):", storedNotifications);

            if (storedNotifications && storedNotifications.length > 0) {
                list.html("");
                // Show latest notifications first (at top)
                // Iterate in reverse order to show newest first
                for (let i = storedNotifications.length - 1; i >= 0; i--) {
                    list.append(formatNotification(storedNotifications[i]));
                }

                // Clear stored notifications and update count
                clearStoredNotifications();
                saveCount(0);
                console.log("Notifications displayed and cleared (restaurant)");
            } else {
                // If no stored notifications, try to get from API
                $.get(`http://localhost:5245/api/notifications/restaurant/by-customer/${window.customerId}`,
                    function (res) {
                        if (res.success && res.messages && res.messages.length > 0) {
                            list.html("");
                            // Show latest notifications first (at top)
                            // Iterate in reverse order to show newest first
                            for (let i = res.messages.length - 1; i >= 0; i--) {
                                list.append(formatNotification(res.messages[i]));
                            }

                            // Update count - subtract consumed notifications
                            const newCount = Math.max(0, unreadCount - res.messages.length);
                            saveCount(newCount);
                        } else {
                            list.html("<p class='text-muted p-2'>No notifications</p>");
                        }
                    }).fail(function () {
                        console.error("Failed to load notifications (restaurant)");
                        list.html("<p class='text-muted p-2'>No notifications</p>");
                    });
            }
        }

        // Initialize on page load
        $(document).ready(function () {
            console.log("Document ready (restaurant), customerId:", window.customerId);
            console.log("Notification count element exists (restaurant):", $("#notificationCount").length > 0);

            if (window.customerId) {
                // First load stored count
                loadStoredCount();

                // Wait a bit then check for new notifications on page load
                setTimeout(function () {
                    checkNotificationCount();
                }, 500);

                // Check for new notifications periodically (every 30 seconds)
                setInterval(checkNotificationCount, 30000);
            } else {
                console.error("CustomerId is not set! (restaurant)");
            }
        });

        $("#notificationBtn").on("click", function () {
            const isOpen = !$("#notificationDropdown").hasClass("d-none");

            if (!isOpen) {
                // Opening dropdown - load and show notifications
                loadNotifications();
                $("#notificationDropdown").removeClass("d-none");

                if (!notificationsLoaded) {
                    notificationsLoaded = true;
                }
            } else {
                // Closing dropdown
                $("#notificationDropdown").addClass("d-none");
            }
        });

        $(document).on("click", function (e) {
            if (!$(e.target).closest(".notification-wrapper").length) {
                $("#notificationDropdown").addClass("d-none");
            }
        });
    </script>

</body>

<script>
    function logoutConfirm() {
        Swal.fire({
            title: 'Logout Confirmation',
            text: 'Are you sure you want to logout?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, Logout',
            cancelButtonText: 'Cancel',
            reverseButtons: false,
            confirmButtonColor: '#f97316',
            cancelButtonColor: '#64748b',
            background: '#fff7ed',
            color: '#1f2937',
            iconColor: '#f97316',
            customClass: {
                popup: 'swal-orange-popup',
                confirmButton: 'swal-orange-confirm',
                cancelButton: 'swal-orange-cancel'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location = '../Restaurant/Logout';
            }
        });
    }
</script>

</html> *@
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - DineSwift</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/kendo/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/css/_Vendor.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="app-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">
                    <svg class="logo-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Steam -->
                        <path class="steam steam-1" d="M35 25 Q35 20 38 18" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" fill="none" />
                        <path class="steam steam-2" d="M50 22 Q50 17 53 15" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" fill="none" />
                        <path class="steam steam-3" d="M65 25 Q65 20 68 18" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" fill="none" />
                        <!-- Cloche -->
                        <ellipse class="cloche-part" cx="50" cy="55" rx="30" ry="20" fill="currentColor" />
                        <path class="cloche-part" d="M20 55 Q20 35 50 30 Q80 35 80 55" fill="currentColor" />
                        <circle class="cloche-part" cx="50" cy="30" r="5" fill="currentColor" />
                        <!-- Plate -->
                        <ellipse cx="50" cy="58" rx="35" ry="8" fill="currentColor" opacity="0.3" />
                        <!-- Wheels -->
                        <circle class="wheel wheel-left" cx="30" cy="75" r="8" stroke="currentColor" stroke-width="3"
                            fill="none" />
                        <circle class="wheel wheel-right" cx="70" cy="75" r="8" stroke="currentColor" stroke-width="3"
                            fill="none" />
                        <line x1="30" y1="75" x2="70" y2="75" stroke="currentColor" stroke-width="3" />
                    </svg>
                </div>
                <div class="logo-text">
                    <h3>DineSwift</h3>
                    <span>Restaurant Panel</span>
                </div>
            </div>

            <nav class="sidebar-menu">
                <a asp-controller="Restaurant" asp-action="Dashboard"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Restaurant" asp-action="RestaurantProfileUpdate"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "RestaurantProfileUpdate" ? "active" : "")">
                    <i class="fa-solid fa-user"></i>
                    <span>Restaurant Profile</span>
                </a>

                <a asp-controller="Restaurant" asp-action="VendorProfile"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "VendorProfile" ? "active" : "")">
                    <i class="fa-solid fa-id-card"></i>
                    <span>Vendor Profile</span>
                </a>

                <a asp-controller="Restaurant" asp-action="MenuItems"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "MenuItems" ? "active" : "")">
                    <i class="fa-solid fa-utensils"></i>
                    <span>Menu Items</span>
                </a>

                <a asp-controller="Restaurant" asp-action="Orders"
                    class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-clipboard-list"></i>
                    <span>Orders</span>
                </a>
            </nav>

             <div class="sidebar-footer">
                <a href="javascript:void(0)" onclick="logoutConfirm()" class="menu-item logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Logout</span>
                </a>
            </div>

        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            <div class="topbar">
                <div class="notification-wrapper">
                    <button id="notificationBtn" class="notification-btn">
                        <i class="bi bi-bell-fill"></i>
                        <span id="notificationCount" class="notification-count d-none">0</span>
                    </button>

                    <div id="notificationDropdown" class="notification-dropdown d-none">
                        <div class="notification-header">
                            <strong>Notifications</strong>
                            <a href="/Restaurant/NotificationDetails" class="view-all-link">View All</a>
                        </div>
                        <div id="notificationList" class="notification-list">
                            <p class="text-muted p-2">No notifications</p>
                        </div>
                    </div>
                </div>
            </div>

            @RenderBody()
        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/kendo/kendo.all.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- NOTIFICATION SCRIPT -->
    <script>
        let unreadCount = 0;
        let notificationsLoaded = false;
        window.customerId = @(Context.Session.GetInt32("CustomerId") ?? 0);
        const NOTIFICATION_COUNT_KEY = `notification_count_restaurant_${window.customerId}`;
        const NOTIFICATIONS_KEY = `notifications_restaurant_${window.customerId}`;

        function loadStoredCount() {
            const stored = localStorage.getItem(NOTIFICATION_COUNT_KEY);
            unreadCount = stored !== null ? (parseInt(stored) || 0) : 0;
            updateCountUI();
        }

        function saveCount(count) {
            unreadCount = count;
            localStorage.setItem(NOTIFICATION_COUNT_KEY, count.toString());
            updateCountUI();
        }

        function updateCountUI() {
            if (unreadCount > 0) {
                $("#notificationCount").text(unreadCount).removeClass("d-none");
            } else {
                $("#notificationCount").addClass("d-none");
            }
        }

        function formatNotification(raw) {
            raw = raw.replace('[RabbitMQ] ', '').replace('[Redis] ', '');
            const parts = raw.split('|');
            const msg = parts[2] ?? raw;
            const time = parts[1] ? new Date(parts[1]).toLocaleString('en-IN') : '';

            return `
                <div class="notification-item">
                    <strong>${msg}</strong>
                    <small class="text-muted">${time}</small>
                </div>
            `;
        }

        function storeNotifications(messages) {
            const existing = JSON.parse(localStorage.getItem(NOTIFICATIONS_KEY) || '[]');
            const combined = [...messages, ...existing];
            localStorage.setItem(NOTIFICATIONS_KEY, JSON.stringify(combined));
            return combined;
        }

        function getStoredNotifications() {
            return JSON.parse(localStorage.getItem(NOTIFICATIONS_KEY) || '[]');
        }

        function clearStoredNotifications() {
            localStorage.removeItem(NOTIFICATIONS_KEY);
        }

        function checkNotificationCount() {
            if (!window.customerId) return;

            $.get(`http://localhost:5245/api/notifications/restaurant/by-customer/${window.customerId}`,
                function (res) {
                    if (res.success && res.messages && res.messages.length > 0) {
                        storeNotifications(res.messages);
                        saveCount(unreadCount + res.messages.length);
                    }
                });
        }

        function loadNotifications() {
            if (!window.customerId) return;

            const list = $("#notificationList");
            const storedNotifications = getStoredNotifications();

            if (storedNotifications && storedNotifications.length > 0) {
                list.html("");
                for (let i = storedNotifications.length - 1; i >= 0; i--) {
                    list.prepend(formatNotification(storedNotifications[i]));
                }
                clearStoredNotifications();
                saveCount(0);
            } else {
                $.get(`http://localhost:5245/api/notifications/restaurant/by-customer/${window.customerId}`,
                    function (res) {
                        if (res.success && res.messages && res.messages.length > 0) {
                            list.html("");
                            for (let i = res.messages.length - 1; i >= 0; i--) {
                                list.prepend(formatNotification(res.messages[i]));
                            }
                            saveCount(Math.max(0, unreadCount - res.messages.length));
                        } else {
                            list.html("<p class='text-muted p-2'>No notifications</p>");
                        }
                    });
            }
        }

        $(document).ready(function () {
            if (window.customerId) {
                loadStoredCount();
                setTimeout(checkNotificationCount, 500);
                setInterval(checkNotificationCount, 30000);
            }
        });

        $("#notificationBtn").on("click", function () {
            const dropdown = $("#notificationDropdown");
            if (dropdown.hasClass("d-none")) {
                loadNotifications();
                dropdown.removeClass("d-none");
            } else {
                dropdown.addClass("d-none");
            }
        });

        $(document).on("click", function (e) {
            if (!$(e.target).closest(".notification-wrapper").length) {
                $("#notificationDropdown").addClass("d-none");
            }
        });
    </script>
    <script>
        function logoutConfirm() {
            Swal.fire({
                title: 'Logout Confirmation',
                text: 'Are you sure you want to logout?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Logout',
                cancelButtonText: 'Cancel',
                reverseButtons: false,
                confirmButtonColor: '#f97316',
                cancelButtonColor: '#64748b',
                background: '#fff7ed',
                color: '#1f2937',
                iconColor: '#f97316',
                customClass: {
                    popup: 'swal-orange-popup',
                    confirmButton: 'swal-orange-confirm',
                    cancelButton: 'swal-orange-cancel'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location = '../Restaurant/Logout';
                }
            });
        }
    </script>
</body>

</html>