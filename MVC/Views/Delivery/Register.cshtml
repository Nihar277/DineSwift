        kendo.ui.validator.rules.strongPassword = function (input) {
            if (input.is("[name='c_password']")) {
                var value = input.val();
                return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&]).{8,}$/.test(value);
            }
            return true;
        };

        kendo.ui.validator.messages.strongPassword = "Password must contain uppercase, lowercase, number & special character";

        kendo.ui.validator.rules.passwordMatch = function (input) {
            if (input.is("[name='c_confirmpassword']")) {
                var password = $("[name='c_password']").val();
                var confirm = input.val();
                return password === confirm;
            }
            return true;
        };

        kendo.ui.validator.messages.passwordMatch = "Password and Confirm Password do not match";

        kendo.ui.validator.rules.ifscValidation = function (input) {
