<style>
    /* ================= BASE ================= */
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f5f5f5;
    }

    /* ================= WRAPPER ================= */
    .vendor-wrapper {
        width: 70%;
        height: 85vh;
        margin: auto;
        margin-top: 3rem;
        border-radius: 24px;
        display: flex;
        @* min-height: 100vh; *@
    }

    /* ================= LEFT PANEL ================= */
    .vendor-left {
        width: 45%;
        background: linear-gradient(180deg, #ff7a00, #ff9f2f);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-top-left-radius: 24px;
        border-bottom-left-radius: 24px;
    }

    .brand-box {
        width: 80%;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 40px;
    }

    .logo .icon {
        background: rgba(255, 255, 255, 0.2);
        padding: 10px;
        border-radius: 12px;
    }

    .brand-box h2 {
        font-size: 32px;
        line-height: 1.3;
    }

    .brand-box p {
        margin-top: 15px;
        font-size: 16px;
        opacity: 0.95;
    }

    .stats {
        display: flex;
        gap: 40px;
        margin-top: 50px;
    }

    .stats h3 {
        font-size: 26px;
        margin-bottom: 5px;
    }

    .stats span {
        font-size: 14px;
        opacity: 0.9;
    }

    /* ================= RIGHT PANEL ================= */
    .vendor-right {
        border-bottom-right-radius: 24px;
        border-top-right-radius: 24px;
        width: 55%;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .form-card {
        width: 85%;
    }

    .form-card .title {
        text-align: center;
        margin-bottom: 30px;
        font-weight: 600;
    }

    /* ================= KENDO OVERRIDES ================= */
    .k-wizard {
        border: none !important;
        background: transparent !important;
    }

    .k-stepper {
        background: transparent !important;
        justify-content: center;
    }

    .k-step-indicator {
        width: 42px !important;
        height: 42px !important;
        border-radius: 50% !important;
    }

    .k-step-current .k-step-indicator {
        background: #ff7a00 !important;
        color: #fff !important;
    }

    .k-step-done .k-step-indicator {
        background: #ffd6ad !important;
        color: #ff7a00 !important;
    }

    .k-form {
        margin-top: 30px;
    }

    .k-textbox,
    .k-input,
    .k-dropdown,
    .k-upload {
        border-radius: 10px !important;
    }

    /* ================= BUTTONS ================= */
    .k-wizard .k-button.k-primary {
        background: linear-gradient(180deg, #ff7a00, #ff9f2f);
        border: none;
        border-radius: 10px;
        padding: 10px 30px;
    }

    .k-wizard .k-button {
        border-radius: 10px;
    }

    .gender-wrapper {
        margin-bottom: 4px;
    }

    .k-invalid-msg {
        display: block;
        margin-top: 4px;
        color: #d32f2f;
        font-size: 12px;
    }




    .vendor-left {
        width: 45%;
        position: relative;
        overflow: hidden;
        color: #fff;

        background: linear-gradient(135deg, #f97316 0%, #ea580c 50%, #dc2626 100%);

        display: flex;
        align-items: center;
        justify-content: center;
        border-top-left-radius: 24px;
        border-bottom-left-radius: 24px;

    }

    .brand-box {
        width: 80%;
        text-align: center;
        position: relative;
        z-index: 2;
    }

    /* Title instead of logo */
    .main-title {
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .tagline {
        opacity: 0.9;
        margin-bottom: 30px;
    }

    /* ================= IMAGE CARD ================= */
    .image-card {
        width: 280px;
        height: 360px;
        margin: 30px auto;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;

        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.35);
    }

    .image-card img {

        width: 90%;
        animation: floatImage 5s ease-in-out infinite;
    }

    /* ================= BADGES ================= */
    .badges {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
    }

    .badge {
        background: rgba(255, 255, 255, 0.2);
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
    }

    /* ================= STATS ================= */
    .stats-box {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .stat {
        background: rgba(255, 255, 255, 0.18);
        border-radius: 14px;
        padding: 15px;
        text-align: center;
    }

    .stat h4 {
        font-size: 20px;
        margin: 0;
    }

    .stat span {
        font-size: 12px;
        opacity: 0.9;
    }

    /* ================= FLOATING ICONS ================= */
    .float-icon {
        position: absolute;
        font-size: 24px;
        opacity: 0.6;
        animation: floatIcons 8s infinite linear;
    }

    .icon-1 {
        top: 20%;
        left: 10%;
        animation-duration: 6s;
    }

    .icon-2 {
        top: 40%;
        right: 15%;
        animation-duration: 9s;
    }

    .icon-3 {
        bottom: 30%;
        left: 15%;
        animation-duration: 7s;
    }

    .icon-4 {
        bottom: 20%;
        right: 10%;
        animation-duration: 10s;
    }

    /* ================= ANIMATIONS ================= */
    @@keyframes floatImage {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0);
        }
    }

    @@keyframes floatIcons {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-25px);
        }

        100% {
            transform: translateY(0);
        }
    }

    .title {
        margin-top: 10px;
    }

    .brand-logo {
        width: 100%;
        margin: auto;
        /* center and add spacing below */
    }


    /* ================= WIZARD BUTTON STYLES ================= */

    /* Common button style */
    .k-wizard-buttons .k-button {
        border-radius: 12px;
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.25s ease;
    }

    /* NEXT / DONE button */
    .k-wizard-buttons .k-primary {
        background: linear-gradient(180deg, #ff7a00, #ff9f2f) !important;
        border: none !important;
        color: #fff !important;
        box-shadow: 0 6px 14px rgba(255, 122, 0, 0.35);
    }

    .k-wizard-buttons .k-primary:hover {
        background: linear-gradient(180deg, #ff6a00, #ff8f1f) !important;
        transform: translateY(-1px);
    }

    /* PREVIOUS button */
    .k-wizard-buttons .k-button:not(.k-primary) {
        background: #fff !important;
        border: 2px solid #ff7a00 !important;
        color: #ff7a00 !important;
    }

    .k-wizard-buttons .k-button:not(.k-primary):hover {
        background: #fff3e6 !important;
        transform: translateY(-1px);
    }

    /* Disabled button */
    .k-wizard-buttons .k-button.k-disabled,
    .k-wizard-buttons .k-button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        box-shadow: none;
    }

    /* ================= FIX KENDO WIZARD SIZE ================= */

    .form-card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    /* Wizard main container */
    #wizard {
        height: 520px;
        /* 🔒 FIXED HEIGHT */
        display: flex;
        flex-direction: column;
    }

    /* Wizard content scroll */
    .k-wizard-content {
        flex: 1;
        overflow-y: auto;
        /* ✅ SCROLL ENABLED */
        padding-right: 10px;
    }

    /* Keep stepper fixed */
    .k-stepper {
        flex-shrink: 0;
    }

    /* Keep buttons fixed */
    .k-wizard-buttons {
        flex-shrink: 0;
        position: sticky;
        bottom: 0;
        background: #fff;
        padding-top: 12px;
        z-index: 5;
    }

    /* ================= CUSTOM SCROLLBAR ================= */

    .k-wizard-content::-webkit-scrollbar {
        width: 6px;
    }

    .k-wizard-content::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #ff7a00, #ff9f2f);
        border-radius: 10px;
    }

    .k-wizard-content::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    #wizard {
        height: 100%;
    }

    /* 🔥 Hide Kendo field-name validation tooltips */
    .k-tooltip,
    .k-tooltip-validation {
        display: none !important;
    }

    /* 🛑 Prevent browser autofill icons overlay */
    input::-webkit-credentials-auto-fill-button {
        display: none !important;
    }

    /* 👇 Extra safety: remove auto labels from dropdown inputs */
    .k-dropdown .k-input,
    .k-dropdown input {
        title: "" !important;
        aria-label: "" !important;
    }


    .back-button {
        position: absolute;
        left: 20px;
        top: 20px;
        width: 45px;
        height: 45px;
        min-width: 44px;
        min-height: 44px;
        border-radius: 50%;
        background: rgba(252, 128, 25, 0.2);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(252, 128, 25, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        z-index: 10;
        color: var(--swiggy-orange-dark);
        font-size: 20px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 2px 8px rgba(252, 128, 25, 0.3),
            inset 0 1px 3px rgba(255, 255, 255, 0.2);
        /* Touch-friendly */
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        touch-action: manipulation;
    }

    .back-button:hover {
        background: rgba(252, 128, 25, 0.3);
        border-color: rgba(252, 128, 25, 0.6);
        transform: scale(1.1);
        box-shadow: 0 4px 15px rgba(252, 128, 25, 0.4),
            inset 0 1px 3px rgba(255, 255, 255, 0.3);
        color: var(--swiggy-orange-dark);
    }

    .back-button:active {
        transform: scale(0.95);
    }

    /* ================= OTP MODAL STYLES ================= */

    .k-window{
        border-radius: 12px;    
    }

    .k-window-titlebar {
        background: linear-gradient(180deg, #ff7a00, #ff9f2f) !important;
        color: white;
        border: none;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
        @* padding: 15px 20px; *@
    }

    #otpModel .k-window-title {
        background: linear-gradient(180deg, #ff7a00, #ff9f2f) !important;
        font-weight: 600;
        font-size: 18px;
    }

    #otpModel .k-window-content {
        padding: 30px;
        background: #fff;
        border-bottom-left-radius: 12px;
        border-bottom-right-radius: 12px;
    }

    /* OTP Form container */
    #otpFrm .k-form {
        padding: 0;
    }

    #otpFrm .k-form-field {
        margin-bottom: 20px;
    }

    #otpFrm .k-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
    }

    /* OTP Input field */
    #otpFrm input[name="Otp"] {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 18px;
        text-align: center;
        letter-spacing: 8px;
        font-weight: 600;
        color: #333;
        transition: all 0.3s ease;
        background: #f9f9f9;
    }

    #otpFrm input[name="Otp"]:focus {
        border-color: #ff7a00;
        box-shadow: 0 0 0 3px rgba(255, 122, 0, 0.1);
        background: #fff;
        outline: none;
    }

    #otpFrm input[name="Otp"]::placeholder {
        color: #aaa;
        letter-spacing: normal;
        font-weight: normal;
    }

    /* Validation messages */
    #otpError {
        @* display: block; *@
        @* text-align: center; *@
        @* margin-top: 10px; *@
        color: #dc2626;
        font-size: 14px;
        font-weight: 500;
        @* padding: 8px 12px; *@
        @* background: #fee2e2; *@
        @* border-radius: 8px; *@
        @* border-left: 4px solid #dc2626; *@
    }

    #otpSuccess {
        @* display: block; *@
        @* text-align: center; *@
        @* margin-top: 10px; *@
        color: #059669;
        font-size: 14px;
        font-weight: 500;
        @* padding: 8px 12px; *@
        @* background: #d1fae5; *@
        border-radius: 8px;
        @* border-left: 4px solid #059669; *@
    }

    /* OTP Form buttons */
    #otpFrm .k-form-buttons {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    #verifyBtn {
        flex: 1;
        background: linear-gradient(180deg, #ff7a00, #ff9f2f);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(255, 122, 0, 0.2);
    }

    #verifyBtn:hover {
        background: linear-gradient(180deg, #ff6a00, #ff8f1f);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(255, 122, 0, 0.3);
    }

    #verifyBtn:active {
        transform: translateY(0);
    }

    #verifyBtn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    #resendBtn {
        flex: 1;
        background: white;
        color: #ff7a00;
        border: 2px solid #ff7a00;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    #resendBtn:hover {
        background: #fff3e6;
        transform: translateY(-1px);
    }

    #resendBtn:active {
        transform: translateY(0);
    }

    #resendBtn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    /* OTP Info text */
    .otp-info {
        text-align: center;
        color: #666;
        font-size: 13px;
        margin-top: 15px;
        padding: 10px;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px dashed #ddd;
    }

    .otp-info strong {
        color: #ff7a00;
    }

    /* Close button in titlebar */
    #otpModel .k-window-titlebar .k-window-actions {
        right: 15px;

    }

    #otpModel .k-window-titlebar .k-link {
        color: white;
        opacity: 0.8;
        transition: opacity 0.2s;
    }

    #otpModel .k-window-titlebar .k-link:hover {
        opacity: 1;
    }

    /* Responsive adjustments */
    @@media (max-width: 480px) {
        #otpModel .k-window {
            width: 90% !important;
            margin: 10px !important;
        }

        #otpFrm input[name="Otp"] {
            font-size: 16px;
            padding: 12px;
            letter-spacing: 6px;
        }

        #otpFrm .k-form-buttons {
            flex-direction: column;
        }
    }

     /* ============================= */
    /* GLOBAL LOADER */
    /* ============================= */
    .global-loader {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 99999;
    }

    .loader-box {
        background: #fff;
        padding: 25px 35px;
        border-radius: 14px;
        text-align: center;
        box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    }

    .loader-box .k-icon {
        font-size: 32px;
        color: #E9622A;
        margin-bottom: 10px;
        animation: spin 1s linear infinite;
    }

    .loader-box p {
        margin: 0;
        font-size: 14px;
        font-weight: 500;
        color: #444;
    }


    @@keyframes spin {
        100% { transform: rotate(360deg); }
    }
</style>

