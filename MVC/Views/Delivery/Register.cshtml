<div id="globalLoader" class="global-loader">
    <div class="loader-box">
        <span class="k-icon k-i-loading"></span>
        <p>Processing, please wait...</p>
    </div>
</div>

<script>


    $(document).ready(function () {

        hideLoader();
        $("#otpModel").kendoWindow({
            visible: false,
            modal: true,
            title: "Verification",
            width: 400
        })


        @* $("#otpModel").getKendoWindow().center().open() *@


        $("#otpFrm").kendoForm({
            formData: {
                Otp: " "
            },
            items: [
                {
                    field: "Otp",
                    label: "Enter OTP",
                    editor: function (container, options) {
                        $(`<input name="${options.field}"
                    maxlength="6"
                    placeholder="Enter 6-digit OTP"
                    required
                    data-required-msg="OTP is required"
                    pattern="^[0-9]{6}$"
                    data-pattern-msg="OTP must be exactly 6 digits"
                />`)
                            .appendTo(container)
                            .kendoTextBox()
                            .on("input", function () {
                                // allow digits only
                                this.value = this.value.replace(/\D/g, "");
                            });
                    }
                }
            ],
            buttonsTemplate: `<button id="verifyBtn">Verify</button> <button type="button" id="resendBtn">Resend</button>`,
            submit: function (e) {
                e.preventDefault();

                const form = e.sender;
                const validator = form.element.data("kendoValidator");

                if (!validator.validate()) {
                    return;
                }

                console.log("click")
                var verifyData = new FormData();
                verifyData.append("Email", $("[name='c_email']").val())
                verifyData.append("Otp", e.model.Otp)
                $.ajax({
                    url: "http://localhost:5245/api/Otp/verify",
                    type: "POST",
                    data: verifyData,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        $("#otpModel").getKendoWindow().close()

                        $("#otpError").text(" ")
