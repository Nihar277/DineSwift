@{
    ViewData["Title"] = "Order History Page";
    Layout = "~/Views/Shared/_OrderLayout.cshtml";
}

<style>
    :root {
        --background: #FDF9F6;
        --foreground: #2E2621;
        --primary: #E9622A;
        --primary-glow: #EF8456;
        --secondary: #F5F0E8;
        --accent: #DF4423;
        --success: #22B55B;
        --muted: #EDE9E5;
        --muted-text: #7A716A;
        --border: #E5DFD9;
        --destructive: #EF4444;
        --card-bg: #FFFFFF;
        --spacing-xs: 0.5rem;
        --spacing-sm: 1rem;
        --spacing-md: 1.5rem;
        --spacing-lg: 2rem;
        --spacing-xl: 3rem;
        --border-radius: 12px;
        --shadow-sm: 0 2px 8px rgba(46, 38, 33, 0.04);
        --shadow-md: 0 4px 16px rgba(46, 38, 33, 0.08);
        --shadow-lg: 0 8px 32px rgba(46, 38, 33, 0.12);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background-color: var(--background);
        color: var(--foreground);
        line-height: 1.6;
        padding: var(--spacing-md);
        min-height: 100vh;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-xl);
        padding-bottom: var(--spacing-md);
        border-bottom: 1px solid var(--border);
    }

    .header h1 {
        font-size: clamp(1.5rem, 4vw, 2.25rem);
        font-weight: 700;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .header h1 .k-icon {
        font-size: 1.8em;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 300px;
    }

    .loading-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid var(--muted);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .error-message {
        background-color: #FEE2E2;
        border: 1px solid var(--destructive);
        color: #7F1D1D;
        padding: var(--spacing-md);
        border-radius: var(--border-radius);
        text-align: center;
        margin: var(--spacing-lg) 0;
    }

    .orders-container {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-xl);
    }

    .order-row {
        background: var(--card-bg);
        border-radius: var(--border-radius);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
    }

    @@media (min-width: 768px) {
        .order-row {
            flex-direction: row;
            align-items: center;
        }
    }

    .order-row:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-glow);
    }

    .order-row.active {
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
    }

    .order-image-section {
        flex: 0 0 120px;
        padding: var(--spacing-md);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @@media (min-width: 768px) {
        .order-image-section {
            flex: 0 0 140px;
        }
    }

    .food-image {
        width: 100px;
        height: 100px;
        border-radius: var(--border-radius);
        object-fit: cover;
        background-color: var(--muted);
    }

    @@media (min-width: 768px) {
        .food-image {
            width: 120px;
            height: 120px;
        }
    }

    .order-details-section {
        flex: 1;
        padding: var(--spacing-md);
        border-top: 1px solid var(--border);
    }

    @@media (min-width: 768px) {
        .order-details-section {
            border-top: none;
            border-left: 1px solid var(--border);
        }
    }

    .dish-name {
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--foreground);
        margin-bottom: var(--spacing-xs);
    }

    .order-meta {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-sm);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--muted-text);
        font-size: 0.9375rem;
    }

    .meta-item .k-icon {
        color: var(--primary);
        font-size: 1.1em;
        width: 20px;
        flex-shrink: 0;
    }

    .meta-value {
        font-weight: 500;
        color: var(--foreground);
    }

    .order-status-section {
        flex: 0 0 auto;
        padding: var(--spacing-md);
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: var(--spacing-sm);
        border-top: 1px solid var(--border);
    }

    @@media (min-width: 768px) {
        .order-status-section {
            border-top: none;
            border-left: 1px solid var(--border);
            flex: 0 0 200px;
        }
    }

    .status-badge {
        padding: 0.375rem 1rem;
        border-radius: 100px;
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        white-space: nowrap;
        text-align: center;
    }

    .status-processing { background-color: #FEF3C7; color: #92400E; }
    .status-prepared { background-color: #DBEAFE; color: #1E40AF; }
    .status-outfordelivery { background-color: #E0E7FF; color: #3730A3; }
    .status-delivered { background-color: #D1FAE5; color: #065F46; }

    .price-display {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .price-display::before {
        content: "₹";
        font-weight: 600;
    }

    .collapse-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        background: var(--secondary);
        border-top: 1px solid var(--border);
    }

    .collapse-panel.active {
        max-height: 500px;
        padding: var(--spacing-md);
    }

    .progress-title {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: var(--spacing-md);
        color: var(--foreground);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .progress-title .k-icon {
        color: var(--primary);
    }

    .step-descriptions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--spacing-sm);
        text-align: center;
        margin-top: var(--spacing-sm);
    }

    .step-desc {
        font-size: 0.875rem;
        color: var(--muted-text);
        transition: color 0.3s ease;
    }

    .step-desc.active {
        color: var(--foreground);
        font-weight: 500;
    }

    @@media (max-width: 640px) {
        .step-descriptions {
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-xs);
        }
        
        .step-desc {
            font-size: 0.8125rem;
        }
        
        .order-meta {
            flex-direction: column;
            gap: var(--spacing-xs);
        }
        
        .order-status-section {
            align-items: stretch;
        }
    }

    .no-orders {
        text-align: center;
        padding: var(--spacing-xl);
        color: var(--muted-text);
    }

    .no-orders .k-icon {
        font-size: 3rem;
        color: var(--border);
        margin-bottom: var(--spacing-sm);
    }

    .progress-steps {
        display: flex;
        align-items: center;
        margin-bottom: var(--spacing-md);
        position: relative;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        position: relative;
        z-index: 2;
    }

    .step-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--spacing-xs);
        border: 2px solid var(--border);
        background-color: var(--card-bg);
        transition: all 0.3s ease;
    }

    .step.active .step-icon {
        background-color: var(--primary);
        border-color: var(--primary);
        color: white;
        animation: pulse 2s infinite;
    }

    .step.completed .step-icon {
        background-color: var(--success);
        border-color: var(--success);
        color: white;
        animation: scaleIn 0.5s ease;
    }

    .step-label {
        font-size: 0.875rem;
        color: var(--muted-text);
        text-align: center;
        transition: color 0.3s ease;
    }

    .step.active .step-label {
        color: var(--foreground);
        font-weight: 600;
    }

    .step.completed .step-label {
        color: var(--foreground);
    }

    .progress-line {
        position: absolute;
        top: 20px;
        left: 20px;
        right: 20px;
        height: 2px;
        background-color: var(--border);
        z-index: 1;
    }

    .progress-fill {
        position: absolute;
        top: 20px;
        left: 20px;
        height: 2px;
        background-color: var(--primary);
        z-index: 1;
        transform-origin: left center;
        animation: fillProgress 1.5s ease-out forwards;
    }

    .step .k-icon {
        font-size: 1.2rem;
        transition: transform 0.3s ease;
    }

    .step.completed .k-icon {
        animation: checkmark 0.5s ease;
    }

    /* Animations */
    @@keyframes fillProgress {
        from {
            width: 0%;
        }
        to {
            width: var(--progress-width);
        }
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(233, 98, 42, 0.4);
        }
        70% {
            box-shadow: 0 0 0 10px rgba(233, 98, 42, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(233, 98, 42, 0);
        }
    }

    @@keyframes scaleIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }
        70% {
            transform: scale(1.1);
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes checkmark {
        0% {
            transform: scale(0);
        }
        50% {
            transform: scale(1.2);
        }
        100% {
            transform: scale(1);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .step {
        animation: fadeInUp 0.5s ease forwards;
        opacity: 0;
    }

    .step:nth-child(1) { animation-delay: 0.1s; }
    .step:nth-child(2) { animation-delay: 0.2s; }
    .step:nth-child(3) { animation-delay: 0.3s; }
    .step:nth-child(4) { animation-delay: 0.4s; }
</style>

<div class="header">
    <h1>
        <span class="k-icon k-i-history"></span>
        Order History
    </h1>
</div>

<div id="loading" class="loading-container">
    <div class="loading-spinner"></div>
</div>

<div id="errorContainer" style="display: none;"></div>

<div class="orders-container" id="ordersContainer"></div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var customerId = 1;
            var currentOpenCard = null;
            var progressCache = {};

            function getStatusBadgeClass(status) {
                const statusMap = {
                    'Processing': 'status-processing',
                    'Prepared': 'status-prepared',
                    'Out for delivery': 'status-outfordelivery',
                    'Out for Delivery': 'status-outfordelivery',
                    'Delivered': 'status-delivered'
                };
                return statusMap[status] || 'status-processing';
            }

            function formatDate(dateString) {
                const date = new Date(dateString);
                return date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            }

            function formatCurrency(amount) {
                return new Intl.NumberFormat('en-IN', {
                    style: 'currency',
                    currency: 'INR',
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                }).format(amount).replace('₹', '');
            }

            function loadOrders() {
                $('#loading').show();
                $('#errorContainer').hide();
                $('#ordersContainer').empty();

                $.ajax({
                    url: 'http://localhost:5245/api/OrderHistory/' + customerId,
                    type: 'GET',
                    dataType: 'json',
                    success: function(orders) {
                        $('#loading').hide();
                        if (orders.length === 0) {
                            $('#ordersContainer').html(`
                                <div class="no-orders">
                                    <span class="k-icon k-i-inbox"></span>
                                    <h3>No orders yet</h3>
                                    <p>Your order history will appear here</p>
                                </div>
                            `);
                            return;
                        }

                        renderOrderRows(orders);
                    },
                    error: function(xhr, status, error) {
                        console.log(error);
                        $('#loading').hide();
                        showError('Failed to load orders. Please try again later.');
                    }
                });
            }

            function renderOrderRows(orders) {
                const container = $('#ordersContainer');
                
                orders.forEach(order => {
                    const row = $(`
                        <div class="order-row" data-booking-id="${order.c_bookingid}" data-order-id="${order.c_orderid}">
                            <div class="order-image-section">
                                ${order.c_foodimage ? 
                                    `<img src="${order.c_foodimage}" alt="${order.c_dishname || 'Order image'}" class="food-image" />` : 
                                    '<div class="food-image"></div>'}
                            </div>
                            
                            <div class="order-details-section">
                                <div class="dish-name">${order.c_dishname || 'Order Items'}</div>
                                
                                <div class="order-meta">
                                    <div class="meta-item">
                                        <span class="k-icon k-i-receipt"></span>
                                        <span>Order ID:</span>
                                        <span class="meta-value">#${order.c_orderid}</span>
                                    </div>
                                    
                                    <div class="meta-item">
                                        <span class="k-icon k-i-calendar"></span>
                                        <span>Date:</span>
                                        <span class="meta-value">${formatDate(order.c_orderdate)}</span>
                                    </div>
                                    
                                    <div class="meta-item">
                                        <span class="k-icon k-i-box"></span>
                                        <span>Items:</span>
                                        <span class="meta-value">${order.c_quantity}</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="order-status-section">
                                <div class="price-display">
                                    ${formatCurrency(order.c_totalprice)}
                                </div>
                                <div class="status-badge ${getStatusBadgeClass(order.c_orderstatus)}">
                                    ${order.c_orderstatus}
                                </div>
                            </div>
                            
                            <div class="collapse-panel" id="panel-${order.c_bookingid}"></div>
                        </div>
                    `);
                    
                    container.append(row);
                });

                attachRowEvents();
            }

            function attachRowEvents() {
                $('.order-row').on('click', function(e) {
                    if ($(e.target).closest('.collapse-panel').length) return;
                    
                    const row = $(this);
                    const bookingId = row.data('booking-id');
                    const panel = row.find('.collapse-panel');
                    
                    if (currentOpenCard && currentOpenCard[0] !== row[0]) {
                        currentOpenCard.removeClass('active');
                        currentOpenCard.find('.collapse-panel').removeClass('active').slideUp();
                    }
                    
                    if (panel.hasClass('active')) {
                        row.removeClass('active');
                        panel.removeClass('active').slideUp();
                        currentOpenCard = null;
                    } else {
                        row.addClass('active');
                        panel.addClass('active').slideDown();
                        
                        if (!panel.hasClass('loaded')) {
                            loadProgress(bookingId, panel);
                            panel.addClass('loaded');
                        }
                        
                        currentOpenCard = row;
                    }
                });
            }

            function loadProgress(bookingId, panel) {
                if (progressCache[bookingId]) {
                    renderProgressBar(progressCache[bookingId], panel);
                    return;
                }

                $.ajax({
                    url: 'http://localhost:5245/api/OrderHistory/progress/' + bookingId,
                    type: 'GET',
                    dataType: 'json',
                    success: function(progress) {
                        progressCache[bookingId] = progress;
                        renderProgressBar(progress, panel);
                    },
                    error: function() {
                        panel.html('<div class="error-message">Failed to load progress</div>');
                    }
                });
            }

            function renderProgressBar(progress, panel) {
                const steps = [
                    { 
                        key: 'processing', 
                        label: 'Processing', 
                        icon: 'k-i-loading',
                        completed: progress.processing
                    },
                    { 
                        key: 'prepared', 
                        label: 'Prepared', 
                        icon: 'k-i-check-circle',
                        completed: progress.prepared
                    },
                    { 
                        key: 'outForDelivery', 
                        label: 'Out for Delivery', 
                        icon: 'k-i-truck',
                        completed: progress.outForDelivery
                    },
                    { 
                        key: 'delivered', 
                        label: 'Delivered', 
                        icon: 'k-i-check',
                        completed: progress.delivered
                    }
                ];

                // Find the highest completed step (last step that is true)
                const completedSteps = steps.filter(step => step.completed);
                const allCompleted = progress.delivered;
                
                // Calculate progress percentage for the line
                let progressPercent = 0;
                if (allCompleted) {
                    progressPercent = 100;
                } else {
                    const completedCount = completedSteps.length;
                    progressPercent = ((completedCount) / steps.length) * 100;
                }

                // Create progress bar HTML with inline style for animation
                const progressHTML = `
                    <div class="progress-title">
                        <span class="k-icon k-i-track-changes"></span>
                        Order Progress
                    </div>
                    <div class="progress-steps">
                        <div class="progress-line"></div>
                        <div class="progress-fill" style="--progress-width: ${progressPercent}%"></div>
                        ${steps.map((step, index) => {
                            let stepClass = '';
                            const stepCompleted = step.completed;
                            
                            if (stepCompleted) {
                                stepClass = 'completed';
                            } else if (index === completedSteps.length) {
                                stepClass = 'active';
                            }
                            
                            const iconClass = stepCompleted ? 'k-i-check' : step.icon;
                            
                            return `
                                <div class="step ${stepClass}">
                                    <div class="step-icon">
                                        <span class="k-icon ${iconClass}"></span>
                                    </div>
                                    <div class="step-label">${step.label}</div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                    <div class="step-descriptions">
                        ${steps.map((step, index) => `
                            <div class="step-desc ${step.completed ? 'active' : ''}">
                                ${step.completed ? 
                                    `<span class="k-icon k-i-check" style="color: var(--success); margin-right: 4px;"></span>` : 
                                    ''}
                                ${step.label}
                            </div>
                        `).join('')}
                    </div>
                `;
                
                // Add fade-in animation to the panel content
                panel.html(progressHTML);
                
                // Trigger reflow to restart animations
                setTimeout(() => {
                    const steps = panel.find('.step');
                    steps.each(function(index) {
                        $(this).css('animation', `fadeInUp 0.5s ease ${0.1 * (index + 1)}s forwards`);
                    });
                }, 10);
            }

            function showError(message) {
                const container = $('#errorContainer');
                container.html(`
                    <div class="error-message">
                        <span class="k-icon k-i-warning"></span>
                        <strong>Error:</strong> ${message}
                    </div>
                `).show();
            }

            loadOrders();
        });
        
    </script>
}