            function loadProgress(bookingId, panel) {
                if (progressCache[bookingId]) {
                    renderProgressBar(progressCache[bookingId], panel);
                    return;
                }

                $.ajax({
                    url: 'http://localhost:5245/api/OrderHistory/progress/' + bookingId,
                    type: 'GET',
                    dataType: 'json',
                    success: function (progress) {
                        progressCache[bookingId] = progress;
                        renderProgressBar(progress, panel);
                    },
                    error: function () {
                        panel.html('<div class="error-message"><span class="k-icon k-i-warning"></span>Failed to load progress</div>');
                    }
                });
            }

            function renderProgressBar(progress, panel) {
                const steps = [
                    { key: 'processing', label: 'Processing', icon: 'k-i-clock', completed: progress.processing },
                    { key: 'prepared', label: 'Prepared', icon: 'k-i-check-circle', completed: progress.prepared },
                    { key: 'outForDelivery', label: 'Out for Delivery', icon: 'k-i-truck', completed: progress.outForDelivery },
                    { key: 'delivered', label: 'Delivered', icon: 'k-i-package', completed: progress.delivered }
                ];

                const completedSteps = steps.filter(step => step.completed);
                const completedCount = completedSteps.length;
                const progressPercent = completedCount > 0 ? ((completedCount - 1) / (steps.length - 1)) * 100 : 0;
                const progressWidth = `calc(${progressPercent}% - 40px)`;

                const progressHTML = `
                        <div class="progress-header">
                            <div class="progress-header-icon">
                                <span class="k-icon k-i-track-changes"></span>
                            </div>
                            <span class="progress-title">Order Progress</span>
                        </div>
                        <div class="progress-container">
                            <div class="progress-line"></div>
                            <div class="progress-fill" style="--progress-width: ${progressWidth};"></div>
                            <div class="progress-steps">
                                ${steps.map((step, index) => {
                    let stepClass = '';
                    if (step.completed) {
                        stepClass = 'completed';
                    } else if (index === completedCount) {
                        stepClass = 'active';
                    }
                    const iconClass = step.completed ? 'k-i-check' : step.icon;

                    return `
                                        <div class="step ${stepClass}">
                                            <div class="step-icon">
                                                <span class="k-icon ${iconClass}"></span>
                                            </div>
                                            <div class="step-label">${step.label}</div>
                                            ${step.completed ? `
                                                <div class="step-done-badge">
                                                    <span class="k-icon k-i-check"></span>
                                                    Done
                                                </div>
                                            ` : ''}
                                        </div>
                                    `;
                }).join('')}
                            </div>
                        </div>
                    `;

                panel.html(progressHTML);
            }

            function submitRating() {
                if (!selectedRating) {
                    showError('Please select a rating before submitting.');
                    return;
                }

                console.log('Submitting rating with data:', currentRatingOrder);

                const today = new Date();
                const formattedDate = today.toISOString().split('T')[0];

                const ratingData = {
                    c_userid: customerId,
                    c_restaurantid: parseInt(currentRatingOrder.restaurantId) || 0,
                    c_fooditemid: parseInt(currentRatingOrder.fooditemId) || 0,
                    c_rating: selectedRating,
                    c_reviewtext: $('#reviewText').val().trim(),
                    c_date: formattedDate
                };

                console.log('Rating data being sent:', ratingData);

                if (!ratingData.c_restaurantid || !ratingData.c_fooditemid) {
                    showError('Missing required data. Cannot submit rating.');
                    return;
                }

                $('#submitRating').prop('disabled', true);
                $('#submitRating').html('<span class="k-icon k-i-loading"></span> Submitting...');

                $.ajax({
                    url: 'http://localhost:5245/api/Rating',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(ratingData),
                    dataType: 'json',
                    success: function (response) {
                        $('#submitRating').prop('disabled', false);
                        $('#submitRating').html('<span class="k-icon k-i-check"></span> Submit Rating');

                        console.log('Rating response:', response);

                        // Check if rating was successful (handle both response formats)
                        let isSuccess = false;

                        if (typeof response === 'object') {
                            if (response.success !== undefined) {
                                isSuccess = response.success;
                            } else if (response.Success !== undefined) {
                                isSuccess = response.Success;
                            } else if (Array.isArray(response)) {
                                // If it's returning all ratings
                                isSuccess = true;
                            }
                        }

                        if (isSuccess) {
                            // Save to localStorage so button doesn't show again
                            saveRatedOrder(currentRatingOrder.orderId);

                            Swal.fire({
                                title: '✅ Thank You!',
                                html: `<div style="text-align: center;">
                                        <p><strong>Your rating has been submitted successfully!</strong></p>
                                        <div style="margin: 20px 0;">
                                            <span style="font-size: 2rem; color: #FFC107;">
                                                ${'★'.repeat(selectedRating)}${'☆'.repeat(5 - selectedRating)}
                                            </span>
                                        </div>
                                        <p style="color: #6B7280; font-size: 0.9em;">
                                            Your feedback helps us serve you better.
                                        </p>
                                    </div>`,
                                icon: 'success',
                                confirmButtonColor: '#22B55B',
                                confirmButtonText: 'Continue',
                                backdrop: 'rgba(0, 0, 0, 0.5)',
                                customClass: {
                                    popup: 'animated bounceIn'
                                }
                            }).then(() => {
                                $('#ratingPopup').hide();
                                // Update the UI to show "Rated" instead of the button
                                const orderRow = $(`.order-row[data-order-id="${currentRatingOrder.orderId}"]`);
                                const rateButton = orderRow.find('.rate-review-btn');
                                if (rateButton.length) {
                                    rateButton.replaceWith(`
                                            <div style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--success); font-weight: 600;">
                                                <span class="k-icon k-i-check"></span> Rated
                                            </div>
                                        `);
                                }
                                currentRatingOrder = null;
                                selectedRating = 0;
                            });
                        } else {
                            Swal.fire({
                                title: 'Submission Failed',
                                text: 'Failed to submit rating. Please try again.',
                                icon: 'error',
                                confirmButtonColor: '#EF4444',
                                confirmButtonText: 'Try Again',
                                backdrop: 'rgba(0, 0, 0, 0.5)',
                                customClass: {
                                    popup: 'animated shake'
                                }
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.log('Rating error:', error, xhr.responseText);
                        $('#submitRating').prop('disabled', false);
                        $('#submitRating').html('<span class="k-icon k-i-check"></span> Submit Rating');

                        Swal.fire({
                            title: 'Error!',
                            text: 'Failed to submit rating. Please try again.',
                            icon: 'error',
                            confirmButtonColor: '#EF4444',
                            confirmButtonText: 'OK',
                            backdrop: 'rgba(0, 0, 0, 0.5)',
                            customClass: {
                                popup: 'animated wobble'
                            }
                        });
