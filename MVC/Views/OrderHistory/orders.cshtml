            function showError(message) {
                const container = $('#errorContainer');
                container.html(`
                        <div class="error-message">
                            <span class="k-icon k-i-warning"></span>
                            <span><strong>Error:</strong> ${message}</span>
                        </div>
                    `).show();
            }

            // ===========================================
            // REAL-TIME POLLING FUNCTIONS
            // ===========================================

            function startStatusPolling() {
                // Clear any existing polling
                if (pollingInterval) {
                    clearInterval(pollingInterval);
                }

                // Start polling every 15 seconds
                pollingInterval = setInterval(checkForStatusUpdates, 15000);
                console.log('Status polling started (every 15 seconds)');

                // Show real-time indicator
                $('#realtimeIndicator').show();
            }

            function checkForStatusUpdates() {
                if (!isPollingActive) return;

                $.ajax({
                    url: `http://localhost:5245/api/OrderHistory/updates/${customerId}`,
                    type: 'GET',
                    dataType: 'json',
                    headers: {
                        'Last-Check': lastCheckTime.toISOString()
                    },
                    success: function (updates) {
                        if (updates && updates.length > 0) {
                            console.log('Found', updates.length, 'status updates');
                            updates.forEach(update => {
                                updateOrderStatusInUI(update);
                            });

                            // Update the last check time
                            lastCheckTime = new Date();

                            // Update stats
                            updateOrderStats();
                        }
                    },
                    error: function (xhr, status, error) {
                        console.log('Polling error:', error);
                    }
                });
            }

            function updateOrderStatusInUI(update) {
                const orderRow = $(`.order-row[data-order-id="${update.orderId}"]`);

                if (orderRow.length) {
                    const currentStatus = orderRow.find('.status-badge').text().trim();

                    // Only update if status changed
                    if (currentStatus !== update.newStatus) {
                        console.log(`Updating order #${update.orderId} from ${currentStatus} to ${update.newStatus}`);

                        // Add update animation
                        orderRow.addClass('status-updated');
                        setTimeout(() => {
                            orderRow.removeClass('status-updated');
                        }, 1500);

                        // Update status badge
                        const statusBadge = orderRow.find('.status-badge');
                        statusBadge.text(update.newStatus);

                        // Remove all status classes and add the new one
                        const statusClass = getStatusBadgeClass(update.newStatus);
                        statusBadge.removeClass().addClass(`status-badge ${statusClass}`);

                        // Show notification
                        showStatusUpdateNotification(update.orderId, update.newStatus);

                        // Update the status in allOrders array
                        const orderIndex = allOrders.findIndex(order => order.c_orderid === update.orderId);
                        if (orderIndex !== -1) {
                            allOrders[orderIndex].c_orderstatus = update.newStatus;
                        }

                        // Update rate/cancel buttons based on new status
                        updateOrderButtons(orderRow, update.orderId, update.newStatus);

                        // If progress panel is open, reload it
                        if (orderRow.hasClass('active')) {
                            const bookingId = orderRow.data('booking-id');
                            const panel = orderRow.find('.collapse-panel');
                            // Clear cache and reload
                            delete progressCache[bookingId];
                            panel.removeClass('loaded');
                            loadProgress(bookingId, panel);
                        }
                    }
                }
            }

            function updateOrderButtons(orderRow, orderId, newStatus) {
                const statusSection = orderRow.find('.status-and-chevron');
                const ratedOrders = getRatedOrders();
                const isRated = isOrderRated(orderId);

                // Remove existing cancel and rate buttons
                orderRow.find('.cancel-order-btn').remove();
                orderRow.find('.rate-review-btn').remove();
                orderRow.find('div:contains("Rated")').remove();

                // Add appropriate buttons based on new status
                if (newStatus === 'Processing') {
                    statusSection.append(`
                            <button class="cancel-order-btn" data-booking-id="${orderRow.data('booking-id')}" data-order-id="${orderId}">
                                <span class="k-icon k-i-delete"></span>
                                Cancel Order
                            </button>
                        `);
                } else if (newStatus === 'Delivered' && !isRated) {
                    const orderData = allOrders.find(order => order.c_orderid === orderId);
                    if (orderData) {
                        statusSection.append(`
                                <button class="rate-review-btn" data-order-id="${orderId}" 
                                        data-booking-id="${orderData.c_bookingid}"
                                        data-restaurant-id="${orderData.c_restaurantid || 0}"
                                        data-fooditem-id="${orderData.c_fooditemid || 0}">
                                    <span class="k-icon k-i-star"></span>
                                    Rate & Review
                                </button>
                            `);
                    }
                } else if (newStatus === 'Delivered' && isRated) {
                    statusSection.append(`
                            <div style="margin-top: 0.5rem; font-size: 0.875rem; color: var(--success); font-weight: 600;">
                                <span class="k-icon k-i-check"></span> Rated
                            </div>
                        `);
                }

                // Reattach event listeners for new buttons
                attachCancelButtonEvents();
                attachRateButtonEvents();
            }

            function showStatusUpdateNotification(orderId, newStatus) {
                // Helper functions for notifications
                function getStatusColor(status) {
                    const colors = {
                        'Processing': '#F59E0B',
                        'Prepared': '#3B82F6',
                        'Out for Delivery': '#8B5CF6',
                        'Out for delivery': '#8B5CF6',
                        'Delivered': '#22C55E',
                        'Cancelled': '#EF4444'
                    };
                    return colors[status] || '#6B7280';
                }

                function getStatusBgColor(status) {
                    const colors = {
                        'Processing': 'linear-gradient(135deg, #F59E0B, #D97706)',
                        'Prepared': 'linear-gradient(135deg, #3B82F6, #1D4ED8)',
                        'Out for Delivery': 'linear-gradient(135deg, #8B5CF6, #7C3AED)',
                        'Out for delivery': 'linear-gradient(135deg, #8B5CF6, #7C3AED)',
                        'Delivered': 'linear-gradient(135deg, #22C55E, #16A34A)',
                        'Cancelled': 'linear-gradient(135deg, #EF4444, #DC2626)'
                    };
                    return colors[status] || 'linear-gradient(135deg, #6B7280, #4B5563)';
                }

                function getStatusIcon(status) {
                    const icons = {
                        'Processing': 'k-i-clock',
                        'Prepared': 'k-i-check-circle',
                        'Out for Delivery': 'k-i-truck',
                        'Out for delivery': 'k-i-truck',
                        'Delivered': 'k-i-package',
                        'Cancelled': 'k-i-close-circle'
                    };
                    return icons[status] || 'k-i-info-circle';
                }

                // Create toast notification
                const toast = $(`
                        <div class="status-toast" style="border-left-color: ${getStatusColor(newStatus)};">
                            <div style="width: 40px; height: 40px; border-radius: 50%; background: ${getStatusBgColor(newStatus)}; 
                                 display: flex; align-items: center; justify-content: center;">
                                <span class="k-icon ${getStatusIcon(newStatus)}" style="color: white; font-size: 1.2rem;"></span>
                            </div>
                            <div>
                                <div style="font-weight: 600; margin-bottom: 4px;">Order #${orderId}</div>
                                <div style="font-size: 0.875rem; color: var(--muted-text);">
                                    Status updated to: <span style="color: ${getStatusColor(newStatus)}; font-weight: 600;">${newStatus}</span>
                                </div>
                            </div>
                        </div>
                    `);

                $('body').append(toast);

                // Remove toast after 5 seconds
                setTimeout(() => {
                    toast.animate({
                        opacity: 0,
                        right: '-100%'
                    }, 300, function () {
                        $(this).remove();
                    });
                }, 5000);
            }

            // ===========================================
            // POLLING CONTROLS EVENT HANDLERS
            // ===========================================

            // Manual refresh button
            $('#manualRefreshBtn').on('click', function () {
                const btn = $(this);
                const originalHtml = btn.html();

                btn.prop('disabled', true);
                btn.html('<span class="k-icon k-i-loading"></span> Refreshing...');

                // Force check for updates
                lastCheckTime = new Date(0); // Reset to beginning of time to get all updates
                checkForStatusUpdates();

                // Re-enable button after 2 seconds
                setTimeout(() => {
                    btn.html(originalHtml);
                    btn.prop('disabled', false);
                }, 2000);
            });

            // Enable polling button
            $('#enablePolling').on('click', function () {
                isPollingActive = true;
                startStatusPolling();
                $(this).css({
                    'background': 'var(--primary)',
                    'color': 'white'
                });
                $('#disablePolling').css({
                    'background': 'var(--muted)',
                    'color': 'var(--muted-text)'
                });
                $('#pollingStatus').text('Active').css('background', 'var(--success)');
                $('#realtimeIndicator').show();
            });

            // Disable polling button
            $('#disablePolling').on('click', function () {
                isPollingActive = false;
                if (pollingInterval) {
                    clearInterval(pollingInterval);
                    pollingInterval = null;
                }
                $(this).css({
                    'background': 'var(--danger)',
                    'color': 'white'
                });
                $('#enablePolling').css({
                    'background': 'var(--muted)',
                    'color': 'var(--muted-text)'
                });
                $('#pollingStatus').text('Paused').css('background', 'var(--danger)');
                $('#realtimeIndicator').hide();
            });

            // ===========================================
            // MOCK UPDATES FOR TESTING (REMOVE WHEN REAL API IS READY)
            // ===========================================
            function mockUpdatesForTesting() {
                // Simulate status changes every 30 seconds
                setInterval(() => {
                    if (allOrders.length > 0 && isPollingActive) {
                        // Pick a random order
                        const randomIndex = Math.floor(Math.random() * allOrders.length);
                        const order = allOrders[randomIndex];

                        // Don't update cancelled or delivered orders
                        if (order.c_orderstatus !== 'Cancelled' && order.c_orderstatus !== 'Delivered') {
                            const statusFlow = ['Processing', 'Prepared', 'Out for delivery', 'Delivered'];
                            const currentIndex = statusFlow.indexOf(order.c_orderstatus);

                            if (currentIndex !== -1 && currentIndex < statusFlow.length - 1) {
                                const newStatus = statusFlow[currentIndex + 1];

                                // Simulate receiving an update
                                const update = {
                                    orderId: order.c_orderid,
                                    newStatus: newStatus,
                                    updatedAt: new Date().toISOString()
                                };

                                updateOrderStatusInUI(update);

                                // Update the order in allOrders array
                                order.c_orderstatus = newStatus;
                                updateOrderStats();
                            }
                        }
                    }
                }, 30000); // Every 30 seconds
            }

            // ===========================================
            // INITIALIZATION
            // ===========================================

            // Star rating interaction
            $('.star-btn').on('click', function () {
                const value = parseInt($(this).data('value'));
                selectedRating = value;

                $('.star-btn').removeClass('selected');
                $('.star-btn').each(function () {
                    if (parseInt($(this).data('value')) <= value) {
                        $(this).addClass('selected');
                    }
                });

                $('#selectedRatingValue').text(`${value}/5`);
                $('#submitRating').prop('disabled', false);
            });

            // Review text character count
            $('#reviewText').on('input', function () {
                const length = $(this).val().length;
                $('#charCount').text(length);

                if (length > 450) {
                    $('#charCount').css('color', '#EF4444');
                } else if (length > 400) {
                    $('#charCount').css('color', '#F59E0B');
                } else {
                    $('#charCount').css('color', 'var(--muted-text)');
                }
            });

            // Cancel rating button
            $('#cancelRating').on('click', function () {
                $('#ratingPopup').hide();
                currentRatingOrder = null;
                selectedRating = 0;
            });

            // Submit rating button
            $('#submitRating').on('click', submitRating);

            // Close popup when clicking outside
            $('#ratingPopup').on('click', function (e) {
                if (e.target === this) {
                    $('#ratingPopup').hide();
                    currentRatingOrder = null;
                    selectedRating = 0;
                }
            });

            // Initial load
            loadOrders();

            // Start polling after 3 seconds (wait for initial load)
            setTimeout(() => {
                if (allOrders.length > 0) {
                    startStatusPolling();
                    // Uncomment the line below for testing without backend
                    // mockUpdatesForTesting();
                }
            }, 3000);

            // Optimize polling when page is not visible
            $(window).on('blur', function () {
                console.log('Page blurred, pausing polling');
                isPollingActive = false;
                if (pollingInterval) {
                    clearInterval(pollingInterval);
                    pollingInterval = null;
                }
                $('#pollingStatus').text('Paused').css('background', 'var(--muted-text)');
                $('#realtimeIndicator').hide();
            });

            $(window).on('focus', function () {
                
                console.log('Page focused, resuming polling');
                if (allOrders.length > 0) {
                    isPollingActive = true;
                    startStatusPolling();
                    $('#pollingStatus').text('Active').css('background', 'var(--success)');
                    $('#realtimeIndicator').show();
                }
            });
        });
    </script>
}