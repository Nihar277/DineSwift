            function attachRowEvents() {
                $('.order-row').on('click', function (e) {
                    if ($(e.target).closest('.cancel-order-btn').length || $(e.target).closest('.rate-review-btn').length) {
                        return;
                    }

                    if ($(e.target).closest('.collapse-panel').length) return;

                    const row = $(this);
                    const bookingId = row.data('booking-id');
                    const panel = row.find('.collapse-panel');

                    if (currentOpenCard && currentOpenCard[0] !== row[0]) {
                        currentOpenCard.removeClass('active');
                        currentOpenCard.find('.collapse-panel').removeClass('active');
                    }

                    if (panel.hasClass('active')) {
                        row.removeClass('active');
                        panel.removeClass('active');
                        currentOpenCard = null;
                    } else {
                        row.addClass('active');
                        panel.addClass('active');

                        if (!panel.hasClass('loaded')) {
                            loadProgress(bookingId, panel);
                            panel.addClass('loaded');
                        }

                        currentOpenCard = row;
                    }
                });
            }

            function attachCancelButtonEvents() {
                $(document).on('click', '.cancel-order-btn', function (e) {
                    e.stopPropagation();

                    const button = $(this);
                    const bookingId = button.data('booking-id');
                    const orderId = button.data('order-id');
                    const orderRow = button.closest('.order-row');
                    const orderPrice = orderRow.find('.price-display').text();

                    showCancelConfirmation(bookingId, orderId, orderRow, orderPrice);
                });
            }

            function attachRateButtonEvents() {
                $(document).on('click', '.rate-review-btn', function (e) {
                    e.stopPropagation();

                    const button = $(this);

                    currentRatingOrder = {
                        orderId: button.data('order-id'),
                        bookingId: button.data('booking-id'),
                        restaurantId: button.data('restaurant-id') || 0,
                        fooditemId: button.data('fooditem-id') || 0
