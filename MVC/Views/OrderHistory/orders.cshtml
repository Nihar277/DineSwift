                    selectedRating = 0;
                    $('.star-btn').removeClass('selected');
                    $('#selectedRatingValue').text('0/5');
                    $('#reviewText').val('');
                    $('#charCount').text('0');
                    $('#submitRating').prop('disabled', true);

                    $('#ratingPopup').css('display', 'flex');
