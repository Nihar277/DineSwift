                                            ${showCancelButton ? `
                                                <button class="cancel-order-btn" data-booking-id="${order.c_bookingid}" data-order-id="${order.c_orderid}">
                                                    <span class="k-icon k-i-delete"></span>
                                                    Cancel Order
                                                </button>
                                            ` : ''}
                                            ${isRated ? `
