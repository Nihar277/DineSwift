<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

@section Scripts {
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <!-- SweetAlert JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const customerId = "@Context.Session.GetInt32("CustomerId")";
            var currentOpenCard = null;
            var progressCache = {};
            var currentRatingOrder = null;
            var selectedRating = 0;
            var allOrders = [];

            // Real-time polling variables
            var lastCheckTime = new Date();
            var isPollingActive = true;
            var pollingInterval = null;

            // Store rated orders in localStorage
            function getRatedOrders() {
                const rated = localStorage.getItem('ratedOrders');
                return rated ? JSON.parse(rated) : [];
            }

            function saveRatedOrder(orderId) {
                const rated = getRatedOrders();
                if (!rated.includes(orderId)) {
                    rated.push(orderId);
                    localStorage.setItem('ratedOrders', JSON.stringify(rated));
                }
            }

            function isOrderRated(orderId) {
                const rated = getRatedOrders();
                return rated.includes(orderId);
            }

            function getStatusBadgeClass(status) {
                const statusMap = {
                    'Processing': 'status-processing',
                    'Prepared': 'status-prepared',
                    'Out for delivery': 'status-outfordelivery',
                    'Out for Delivery': 'status-outfordelivery',
                    'Delivered': 'status-delivered'
                };
                return statusMap[status] || 'status-processing';
            }

            function formatDateTime(dateString, timeString) {
                let date = new Date(dateString);
                if (isNaN(date.getTime())) {
                    date = new Date();
                }

                const formattedDate = date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                });

                let formattedTime = '';
                if (timeString) {
                    const timeParts = timeString.toString().split(':');
                    if (timeParts.length >= 2) {
                        let hours = parseInt(timeParts[0]);
                        const minutes = timeParts[1];
                        const ampm = hours >= 12 ? 'PM' : 'AM';
                        hours = hours % 12;
                        hours = hours ? hours : 12;
                        formattedTime = `${hours}:${minutes.padStart(2, '0')} ${ampm}`;
                    } else {
                        formattedTime = timeString;
                    }
                } else {
                    formattedTime = date.toLocaleTimeString('en-US', {
                        hour: '2-digit',
                        minute: '2-digit',
                        hour12: true
                    });
                }

                return {
                    date: formattedDate,
                    time: formattedTime
                };
            }

            function formatCurrency(amount) {
                return '₹' + new Intl.NumberFormat('en-IN', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                }).format(amount);
            }

            function updateOrderStats() {
                const totalOrders = allOrders.length;
                const deliveredOrders = allOrders.filter(order =>
                    order.c_orderstatus === 'Delivered'
                ).length;
                const pendingOrders = allOrders.filter(order =>
                    order.c_orderstatus !== 'Delivered' &&
                    order.c_orderstatus !== 'Cancelled'
                ).length;

                $('#totalOrders').text(totalOrders);
                $('#deliveredOrders').text(deliveredOrders);
                $('#pendingOrders').text(pendingOrders);
            }

            function loadOrders() {
                $('#loading').show();
                $('#errorContainer').hide();
                $('#ordersContainer').empty();
                $('#footerHint').hide();
                $('#orderStats').hide();
                $('#manualRefreshBtn').hide();
                $('#pollingControls').hide();

                $.ajax({
                    url: 'http://localhost:5245/api/OrderHistory/' + customerId,
                    type: 'GET',
                    dataType: 'json',
                    success: function (orders) {
                        $('#loading').hide();
                        allOrders = orders;

                        if (orders.length === 0) {
                            $('#ordersContainer').html(`
                                    <div class="no-orders">
                                        <div class="no-orders-icon">
