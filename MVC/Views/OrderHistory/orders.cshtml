                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                title: 'Order Cancelled!',
                                html: `<div style="text-align: left;">
                                        <p><strong>${response.message}</strong></p>
                                        <p style="color: #22B55A; margin-top: 15px; font-size: 0.95em;">
                                            <strong>Refund Information:</strong><br>
                                            Your money will be refunded to your original payment method within <strong>5-7 business days</strong>.
                                        </p>
                                        <p style="color: #6B7280; font-size: 0.85em; margin-top: 10px;">
                                            You will receive a confirmation email shortly.
                                        </p>
                                    </div>`,
                                icon: 'success',
                                confirmButtonColor: '#22B55B',
                                confirmButtonText: 'Got it!',
                                backdrop: 'rgba(0, 0, 0, 0.5)',
                                customClass: {
                                    popup: 'animated bounceIn'
                                }
                            }).then(() => {
                                orderRow.animate({
                                    opacity: 0,
                                    height: 0,
                                    margin: 0,
                                    padding: 0
                                }, 500, function () {
