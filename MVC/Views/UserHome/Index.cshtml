    <style>
        /* AI FAB */
        .ai-fab {
            position: fixed;
            right: 24px;
            bottom: 24px;
            background: linear-gradient(135deg, #fa7414 0%, #e35f00 100%);
            color: #fff;
            border: none;
            border-radius: 999px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 10px 30px rgba(250,116,20,0.25);
            cursor: pointer;
            z-index: 9999;
            font-weight: 700;
            transition: transform 0.12s ease, box-shadow 0.12s ease;
        }

        .ai-fab:hover { transform: translateY(-4px); box-shadow: 0 14px 36px rgba(250,116,20,0.32); }

        .ai-fab .ai-icon { font-size: 1.25rem; line-height: 1; }
        .ai-fab .ai-label { font-size: 0.95rem; letter-spacing: 0.6px; }

        /* If the panel uses an open class, this gives a hint (no-op if panel handled elsewhere) */
        #ai-panel.open { transform: translateX(0); }
    </style>

    <script>
        (function(){
            var btn = document.getElementById('ai-fab');
            if (!btn) return;

            btn.addEventListener('click', function () {
                // Prefer a global opener if provided by the existing panel implementation
                if (typeof openAIPanel === 'function') {
                    openAIPanel();
                    return;
                }

                // Otherwise toggle a panel with id 'ai-panel' if present
                var panel = document.getElementById('ai-panel');
                if (panel) {
                    panel.classList.toggle('open');
                    // ensure focus for accessibility
                    if (panel.classList.contains('open')) panel.focus();
                    return;
                }

                // Fallback: if a Kendo window named 'aiWindow' exists, try to open it
                try {
                    if (window.aiWindow && typeof window.aiWindow.open === 'function') {
                        window.aiWindow.open();
                        return;
                    }
                } catch (e) { /* ignore */ }

                console.warn('AI panel not found. Define `openAIPanel()` or add an element with id "ai-panel".');
            });
        })();
    </script>