    <script>
        $(document).ready(function () {
            $("#dishes-list").kendoListView({
                dataSource: {
                    transport: {
                        read: {
                            url: "http://localhost:5245/api/userHome/allDishes",
                            dataType: "json"
                        }
                    },
                    pageSize: 9
                },
                template: kendo.template($("#dish-template").html()),
                dataBound: function () {
                    duplicateOnce("#dishes-list");
                    // Trigger animations for newly loaded cards
                    setTimeout(function() {
                        const cards = document.querySelectorAll("#dishes-list .dish-card");
                        cards.forEach(function(card, index) {
                            card.style.animation = 'none';
                            setTimeout(function() {
                                card.style.animation = '';
                            }, 10);
                        });
                    }, 100);
                },
                scrollable: false
            });

            $("#restaurant-list").kendoListView({
                dataSource: {
                    transport: {
                        read: {
                            url: "http://localhost:5245/api/userHome/allRestaurants",
                            dataType: "json"
                        }
                    },
                    pageSize: 10
                },
                template: kendo.template($("#restaurant-template").html()),
                scrollable: false,
                dataBound: function () {
                    const container = $(".restaurant-track");
                    duplicateOnce("#restaurant-list");
                    if (!container.hasClass("duplicated")) {
                        container.append(container.html());
                        container.addClass("duplicated");
                    }
                }
            });

            // Initialize Kendo Window
            $("#item-details-window").kendoWindow({
                width: "500px",
                title: "Dish Information",
                visible: false,
                modal: true,
                actions: ["Close"],
                draggable: true,
                resizable: false
            });
        });

        function duplicateOnce(selector) {
            const content = document.querySelector(selector + " .k-listview-content");

            if (!content || content.dataset.duplicated === "true") return;

            content.innerHTML += content.innerHTML;   // duplicate items
            content.dataset.duplicated = "true";     // mark as done
        }

        function showItemInfo(itemId) {
            $.ajax({
                url: "http://localhost:5245/api/userHome/" + itemId,
                method: "GET",
                success: function (data) {
                    console.log("Item details fetched:", data);
                    var windowContent = `
                                        <div style="padding: 20px; font-family: 'Segoe UI', sans-serif;">
                                            <div style="display: flex; gap: 20px; align-items: start; margin-bottom: 20px;">
                                                <img src="/Images/restaurant/dishes/${data.c_restaurantid}/${data.c_imageurl}" 
                                                     style="width: 150px; height: 150px; object-fit: cover; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);" />
                                                <div>
                                                    <h2 style="color: #fa7414; margin: 0 0 5px 0; font-weight: 700;">${data.c_name}</h2>
                                                    <p style="color: #666; font-weight: 500; margin-bottom: 10px;">By ${data.c_r_name || 'DineSwift Partner'}</p>
                                                    <span class="badge" style="background-color: #fa7414; color: white; padding: 5px 12px; border-radius: 20px; font-size: 0.85rem;">${data.c_category || 'General'}</span>
                                                </div>
                                            </div>
                                
                                            <div style="background: #f9f9f9; padding: 15px; border-radius: 12px; margin-bottom: 15px;">
                                                <h4 style="margin-top: 0; color: #333; font-size: 1rem;">Description</h4>
                                                <p style="color: #666; line-height: 1.5; margin-bottom: 0;">${data.c_description || 'No description available.'}</p>
                                            </div>

                                            <div style="background: #f9f9f9; padding: 15px; border-radius: 12px; margin-bottom: 20px;">
                                                <h4 style="margin-top: 0; color: #333; font-size: 1rem;">Main Ingredients</h4>
                                                <p style="color: #666; line-height: 1.5; margin-bottom: 0;">${data.c_ingredients || 'Secret ingredients!'}</p>
                                            </div>

                                            <div style="display: flex; justify-content: center; border-top: 1px solid #eee; pt: 15px; margin-top: 10px; padding-top: 15px;">
                                                <span style="font-size: 1.8rem; font-weight: 800; color: #fa7414;">₹${data.c_price}</span>
                                            </div>
                                        </div>
                                    `;

                    var dialog = $("#item-details-window").data("kendoWindow");
                    dialog.content(windowContent);
                    dialog.center().open();

                    // Close on click outside (overlay click)
                    $(".k-overlay").one("click", function () {
                        dialog.close();
                    });
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: "Error fetching item details. Please try again.",
                        showConfirmButton: true
                    });
                }
            });
        }

        function addToCart(itemId) {
            var listView = $("#dishes-list").data("kendoListView");
            var dataSource = listView.dataSource;
            var item = dataSource.data().find(function (d) { return d.c_itemid === itemId; });

            if (!item) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: "Item not found.",
                    showConfirmButton: true
                });
                return;
            }

            // Create FormData with all cart data
            let data = new FormData();
            data.append("c_customerId", "@Context.Session.GetInt32("CustomerId")"); // Default customer ID for now
            data.append("c_itemId", item.c_itemid);
            data.append("c_restaurantId", item.c_restaurantid);
            data.append("c_itemname", item.c_name);
            data.append("c_price", item.c_price);
            data.append("c_quantity", 1);
            data.append("c_image", item.c_imageurl);

            // Only append file if it exists
            if (item.c_imageurlPicture) {
                data.append("c_imageurlPicture", item.c_imageurlPicture);
            }

            // Log the data being sent (for debugging)
            console.log("Sending cart data:", {
                c_customerId: 1,
                c_itemId: item.c_itemid,
                c_restaurantId: item.c_restaurantid,
                c_itemname: item.c_name,
                c_price: item.c_price,
                c_quantity: 1,
                c_image: item.c_imageurl
            });

            $.ajax({
                url: "http://localhost:5245/api/userHome/AddToCart",
                type: "POST",
                data: data,
                processData: false,  // Required for FormData
                contentType: false,   // Required for FormData - let browser set it
                success: function (response) {
                    console.log("Success response:", response);
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: response.message || "Item added to cart!",
                            showConfirmButton: true,
                            timer: 2000,
                            timerProgressBar: true
                        });
                    } else {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Oops...',
                            text: response.message || "Failed to add item to cart.",
                            showConfirmButton: true
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error adding to cart:", error);
                    console.error("Status:", status);
                    console.error("Response:", xhr.responseText);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: "An error occurred while adding the item to the cart.",
                        showConfirmButton: true
                    });
                }
            });
        }

        function viewRestaurant(restaurantId) {
            console.log("Viewing restaurant: " + restaurantId);
            window.location.href = '/UserHome/RestaurantDetails/' + restaurantId;
        }
    </script>

    <script>
        let dishIndex = 0;

        function updateDishCarousel() {
            const list = document.querySelector("#dishes-list .k-listview-content");
            const card = document.querySelector("#dishes-list .dish-card");
            if (!list || !card) return;

            const cardWidth = card.offsetWidth + 24;
            list.style.transform = `translateX(-${dishIndex * cardWidth}px)`;
        }

        document.getElementById("dishNext").addEventListener("click", () => {
            const list = document.querySelectorAll("#dishes-list .dish-card");
            dishIndex = (dishIndex + 1) % list.length;
            updateDishCarousel();
        });

        document.getElementById("dishPrev").addEventListener("click", () => {
            const list = document.querySelectorAll("#dishes-list .dish-card");
            dishIndex = (dishIndex - 1 + list.length) % list.length;
            updateDishCarousel();
        });

        /* Pause on hover */
        document.querySelector(".dishes-carousel").addEventListener("mouseenter", () => {
            document.querySelector("#dishes-list .k-listview-content").style.transition = "none";
        });

        document.querySelector(".dishes-carousel").addEventListener("mouseleave", () => {
            document.querySelector("#dishes-list .k-listview-content").style.transition = "transform 0.6s ease";
        });
    </script>


