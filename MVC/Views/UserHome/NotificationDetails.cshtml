@{
    Layout = "_userdashboardLayout";
    ViewData["Title"] = "Notification Details";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    .notification-details-container {
        max-width: 800px;
        margin: 100px auto 40px;
        padding: 0 20px;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #f97316;
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 20px;
        padding: 10px 16px;
        border-radius: 8px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        transition: all 0.2s ease;
    }

    .back-btn:hover {
        background: #f97316;
        color: white;
        transform: translateX(-3px);
    }

    .notification-card {
        background: white;
        border-radius: 18px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        position: relative;
    }

    .notification-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg, #f97316, #fb923c, #fbbf24);
    }

    .notification-card-header {
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        padding: 30px;
        border-bottom: 1px solid #fed7aa;
    }

    .notification-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #f97316, #ea580c);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(249, 115, 22, 0.3);
    }

    .notification-icon i {
        font-size: 1.8rem;
        color: white;
    }

    .notification-title {
        font-size: 1.6rem;
        font-weight: 800;
        color: #9a3412;
        margin-bottom: 10px;
    }

    .notification-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 15px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #92400e;
    }

    .meta-item i {
        color: #f97316;
    }

    .notification-body {
        padding: 30px;
    }

    .notifications-list-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
    }

    .notifications-list-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .notifications-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
        max-height: 500px;
        overflow-y: auto;
    }

    .notification-list-item {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
    }

    .notification-list-item:hover {
        border-color: #f97316;
        box-shadow: 0 4px 12px rgba(249, 115, 22, 0.1);
        transform: translateY(-2px);
    }

    .notification-list-item-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 15px;
    }

    .notification-list-item-title {
        font-weight: 600;
        color: #0f172a;
        font-size: 1rem;
        flex: 1;
    }

    .notification-list-item-time {
        font-size: 0.85rem;
        color: #94a3b8;
        white-space: nowrap;
    }

    .notification-list-item-sender {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: #f97316;
        font-weight: 500;
        margin-top: 8px;
    }

    .delete-btn {
        border: 1px solid #fecaca;
        background: #fee2e2;
        color: #dc2626;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 0.85rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s ease;
    }

    .delete-btn:hover {
        background: #fecaca;
    }

    .empty-state {
        text-align: center;
        padding: 60px 30px;
    }

    .empty-state i {
        font-size: 4rem;
        color: #cbd5e1;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        color: #0f172a;
        margin-bottom: 10px;
    }

    .empty-state p {
        color: #475569;
    }
</style>

<div class="notification-details-container">
    <a asp-controller="UserHome" asp-action="Index" class="back-btn">
        <i class="bi bi-arrow-left"></i>
        Back to Home
    </a>

    <div class="notification-card">
        <div class="notification-card-header">
            <div class="notification-icon">
                <i class="bi bi-bell-fill"></i>
            </div>
            <h1 class="notification-title">Notification History</h1>
            <div class="notification-meta">
                <div class="meta-item">
                    <i class="bi bi-stack"></i>
                    <span id="pageNotificationCount">Loading...</span>

                </div>
                <div class="meta-item">
                    <i class="bi bi-clock"></i>
                    <span>All Time</span>
                </div>
            </div>
        </div>

        <div class="notification-body">
            <div class="notifications-list-header">
                <i class="bi bi-bell" style="color: #f97316;"></i>
                <h2>All Notifications</h2>
            </div>
            <div class="notifications-list" id="allNotificationsList">
                <div class="empty-state">
                    <i class="bi bi-hourglass-split"></i>
                    <p>Loading notifications...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const customerId = @Context.Session.GetInt32("CustomerId");

        $(document).ready(function () {
            loadAllNotificationHistory();
        });
        function getTimeAgo(date) {
            const now = new Date();
            const diffMs = now - date;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);

            if (diffMins < 1) return "Just now";
            if (diffMins < 60) return `${diffMins} minute${diffMins > 1 ? 's' : ''} ago`;
            if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
            if (diffDays < 7) return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;

            const diffWeeks = Math.floor(diffDays / 7);
            if (diffWeeks < 4) return `${diffWeeks} week${diffWeeks > 1 ? 's' : ''} ago`;

            const diffMonths = Math.floor(diffDays / 30);
            return `${diffMonths} month${diffMonths > 1 ? 's' : ''} ago`;
        }

        function loadAllNotificationHistory() {
            $.ajax({
                url: `http://localhost:5245/api/notifications/customer/history/${customerId}`,
                type: "GET",
                success: function (res) {
                    if (!res.success || !res.messages || res.messages.length === 0) {
                        showEmptyState();
                        return;
                    }
                    displayAllNotifications(res.messages);
                },
                error: function () {
                    showEmptyState();
                }
            });
        }

        function displayAllNotifications(messages) {
            const listContainer = $("#allNotificationsList");
            $("#pageNotificationCount").text(
                messages.length + " Notification" + (messages.length > 1 ? "s" : "")
            );


            let html = "";
            messages.slice().reverse().forEach((msg) => {
                const cleanMsg = msg.replace('[RabbitMQ] ', '').replace('[Redis] ', '');
                const parts = cleanMsg.split("|");

                if (parts.length >= 3) {
                    const sender = escapeHtml(parts[0] || "System");
                    const dateStr = parts[1];
                    const message = escapeHtml(parts[2] || "");
                    // 3️⃣ Time calculation
                    const date = new Date(dateStr);
                    const formattedDate = date.toLocaleString('en-IN');
                    const timeAgo = getTimeAgo(date);

                    const encodedRaw = encodeURIComponent(cleanMsg);

                    // 4️⃣ Render HTML
                    html += `
                                                <div class="notification-list-item" data-raw="${encodedRaw}">
                                                    <div class="notification-list-item-header">
                                                        <div class="notification-list-item-title">${message}</div>
                                                        <div class="notification-list-item-actions">
                                                            <div class="notification-list-item-time">
                                                                <i class="bi bi-clock"></i> ${formattedDate}
                                                                <br>
                                                                <small style="color:#cbd5e1;">${timeAgo}</small>
                                                            </div>
                                                            <button class="delete-btn" onclick="onDeleteNotification(this)">
                                                                <i class="bi bi-trash3"></i> Delete
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="notification-list-item-sender">
                                                        <i class="bi bi-person-circle"></i> ${sender}
                                                    </div>
                                                </div>
                                            `;
                }
            });

            listContainer.html(html);
        }

        function onDeleteNotification(button) {
            const raw = decodeURIComponent($(button).closest(".notification-list-item").data("raw") || "");
            if (!raw) return;

            Swal.fire({
                title: 'Delete Notification?',
                text: 'This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#f97316',
                cancelButtonColor: '#64748b',
                background: '#fff7ed',
                color: '#1f2937',
                iconColor: '#f97316',
                customClass: {
                    popup: 'swal-orange-popup',
                    confirmButton: 'swal-orange-confirm',
                    cancelButton: 'swal-orange-cancel'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteNotification(raw);
                }
            });
        }

        @* function onDeleteNotification(button) {
            const raw = decodeURIComponent($(button).closest(".notification-list-item").data("raw") || "");
            if (!raw) return;
            if (!confirm("Delete this notification from history?")) return;
            deleteNotification(raw);
        } *@
            @* 
        function deleteNotification(rawMessage) {
            $.ajax({
                url: `http://localhost:5245/api/notifications/customer/delete/${customerId}`,
                type: "DELETE",
                contentType: "application/json",
                data: JSON.stringify({ message: rawMessage }),
                success: function (res) {
                    if (res.success) {
                        loadAllNotificationHistory();
                    } else {
                        alert("Could not delete notification");
                    }
                },
                error: function () {
                    alert("Failed to delete notification");
                }
            });
        } *@


            function deleteNotification(rawMessage) {
                $.ajax({
                    url: `http://localhost:5245/api/notifications/customer/delete/${customerId}`,
                    type: "DELETE",
                    contentType: "application/json",
                    data: JSON.stringify({ message: rawMessage }),
                    success: function (res) {
                        if (res.success) {

                            Swal.fire({
                                title: 'Deleted!',
                                text: 'Notification successfully removed.',
                                icon: 'success',
                                confirmButtonText: 'OK',
                                confirmButtonColor: '#f97316',
                                background: '#fff7ed',
                                color: '#1f2937',
                                iconColor: '#f97316',
                                customClass: {
                                    popup: 'swal-orange-popup',
                                    confirmButton: 'swal-orange-confirm'
                                }
                            }).then(() => {
                                loadAllNotificationHistory();
                            });

                        } else {
                            Swal.fire({
                                title: 'Error',
                                text: 'Could not delete notification.',
                                icon: 'error',
                                confirmButtonColor: '#f97316'
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            title: 'Failed',
                            text: 'Something went wrong while deleting.',
                            icon: 'error',
                            confirmButtonColor: '#f97316'
                        });
                    }
                });
            }

        function escapeHtml(text) {
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        function showEmptyState() {
            $("#pageNotificationCount").text("0 Notifications");

            $("#allNotificationsList").html(`
                        <div class="empty-state">
                            <i class="bi bi-bell-slash"></i>
                            <h2>No Notifications</h2>
                            <p>No notification history found.</p>
                        </div>
                    `);
        }

    </script>
}