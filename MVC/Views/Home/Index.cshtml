@section Scripts {

    <!-- KENDO & JQUERY -->
    <link rel="stylesheet" href="~/kendo/kendo.default-v2.min.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/kendo/kendo.all.min.js"></script>

    <!-- ================= TRENDING DISHES – HORIZONTAL (KENDO) ================= -->
    <script id="dish-template" type="text/x-kendo-template">
        <div class="dish-card-horizontal">
            <div class="dish-image">
             <img src="/Images/restaurant/dishes/#= c_restaurantid #/#= c_imageurl #"
                 alt="Dish Image"
                 onerror="this.src='/Images/no-image.png'" />

                @* http://localhost:5030/Images/restaurant/dishes/5/asd.jpg *@
            </div>

            <div class="dish-content">
                <h4 class="dish-name">#: c_name #</h4>
                <div class="dish-partner">
                    #: c_r_name ? c_r_name : 'DineSwift Partner' #
                </div>

                # if (c_category) { #
                    <span class="dish-category">#: c_category #</span>
                # } #
            </div>
        </div>
    </script>

    <script>
        $(document).ready(function () {
            
            $("#dishes-list").click(function(e){
                window.location.href ="/Auth/Login";
            });
            $("#restaurants-list").click(function(e){
                window.location.href ="/Auth/Login";
            });
            $("#dishes-list").kendoListView({
                dataSource: {
                    transport: {
                        read: {
                            url: "http://localhost:5245/api/userHome/allDishes",
                            dataType: "json"
                        }
                    },
                    pageSize: 8
                },
                template: kendo.template($("#dish-template").html()),
                scrollable: false
            });
        });
    </script>

    <!-- ================= VIEW ALL RESTAURANTS (KENDO LISTVIEW WITH CUSTOM NAV) ================= -->
    <script id="restaurant-template" type="text/x-kendo-template">
        <div class="restaurant-card">
            <div class="k-card restaurant-card-inner">
                <img class="restaurant-rect-image"
                     src="/Images/restaurant/restaurantimages/#=c_r_image#"
                     alt="#: c_r_name #" />
                <div class="restaurant-card-body">
                    <h4 class="restaurant-card-name">#: c_r_name #</h4>
                </div>
            </div>
        </div>
    </script>

    <script>
        $(document).ready(function () {
            var restaurantsDs = new kendo.data.DataSource({
                transport: {
                    read: {
                        url: "http://localhost:5245/api/userHome/allRestaurants",
                        dataType: "json"
                    }
                },
                pageSize: 3
            });

            $("#restaurants-list").kendoListView({
                dataSource: restaurantsDs,
                template: kendo.template($("#restaurant-template").html()),
                scrollable: false
            });

            $(".restaurants-nav-btn.prev").on("click", function () {
                var page = restaurantsDs.page() || 1;
                if (page > 1) {
                    restaurantsDs.page(page - 1);
                }
            });

            $(".restaurants-nav-btn.next").on("click", function () {
                var page = restaurantsDs.page() || 1;
                var totalPages = restaurantsDs.totalPages();
                if (page < totalPages) {
                    restaurantsDs.page(page + 1);
                }
            });
        });
    </script>

    <!-- ================= HERO IMAGE ROTATION ================= -->
    <script>
        (function () {
            const dots = document.querySelectorAll(".hero-dish-dot");
            const mainImg = document.getElementById("heroDishMainImage");
            if (!dots.length || !mainImg) return;

            let current = 0;

            function render(index) {
                if (index < 0 || index >= dots.length) return;

                const img = dots[index].querySelector("img");
                if (img && img.src) {
                    mainImg.style.opacity = "0";
                    setTimeout(() => {
                        mainImg.src = img.src;
                        mainImg.onload = () => {
                            mainImg.style.opacity = "1";
                        };
                        mainImg.onerror = () => {
                            mainImg.style.opacity = "1";
                        };
                    }, 200);
                }

                dots.forEach((d, i) => d.classList.toggle("is-active", i === index));
            }

            dots.forEach((dot, i) => {
                dot.addEventListener("click", () => {
                    current = i;
                    render(i);
                });
            });

            setInterval(() => {
                current = (current + 1) % dots.length;
                render(current);
            }, 2400);

            render(0);
        })();
    </script>
}