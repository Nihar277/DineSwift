@{
    ViewData["Title"] = "Home";
    Layout = "_homeLayout";
}



<!-- ================= HERO SECTION ================= -->
<section class="section hero" id="hero">
    <div data-animate>

        <div class="hero-kicker">
            <span>★</span>
            <span>Fresh food, right on time</span>
        </div>

        <h1 class="hero-title">
            Enjoy your <span class="highlight">delicious food</span><br />
            without leaving home.
        </h1>

        <!-- Search -->
        <div class="hero-search">
            <div class="hero-search-inputs">

                <div class="hero-input">
                    <span class="label">Search food</span>
                    <input type="text" placeholder="Enter dishes" />
                </div>

                <div class="hero-divider"></div>

                <div class="hero-input">
                    <span class="label">Deliver to</span>
                    <input type="text" placeholder="Enter location" />
                </div>

            </div>

            <button class="hero-search-btn">Find meals</button>
        </div>
    </div>

    <!-- ================= HERO IMAGE ================= -->
    <div class="hero-right" data-animate>
        <div class="hero-right-arc"></div>

        <div class="hero-dish-orbit">
            <div class="hero-dish-orbit-items">

                <button class="hero-dish-dot dot-1 is-active" data-index="0">
                    <img src="~/Images/landing_page/indian.jpg" />
                </button>

                <button class="hero-dish-dot dot-2" data-index="1">
                    <img src="~/Images/landing_page/italian.jpg" />
                </button>

                <button class="hero-dish-dot dot-3" data-index="2">
                    <img src="~/Images/landing_page/thai.jpg" />
                </button>

                <button class="hero-dish-dot dot-4" data-index="3">
                    <img src="~/Images/landing_page/dessert.jpg" />
                </button>

                <button class="hero-dish-dot dot-5" data-index="4">
                    <img src="~/Images/landing_page/chinese.jpg" />
                </button>

                <button class="hero-dish-dot dot-6" data-index="5">
                    <img src="~/Images/landing_page/juice.jpg" />
                </button>

            </div>

            <div class="hero-dish-main">
                <img id="heroDishMainImage"
                     src="~/Images/landing_page/indian.jpg"
                     alt="Featured Dish" />
            </div>
        </div>
    </div>
</section>

