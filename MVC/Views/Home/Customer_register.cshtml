@section Scripts {
    <script type="text/javascript">
        /* ================= IMAGE PREVIEW FUNCTIONALITY ================= */
        function setupImagePreview() {
            const previewContainer = document.getElementById('imagePreview');
            
            // If image preview container doesn't exist, skip setup
            if (!previewContainer) {
                return;
            }
            
            const placeholder = previewContainer.querySelector('.preview-placeholder');

            // Listen for file selection
            $(document).on('change', '[name="c_imagefile"]', function (e) {
                const file = e.target.files[0];
                if (!file || !previewContainer) return;

                // Show upload progress
                previewContainer.innerHTML = `
                                <div class="upload-progress">
                                    <span class="progress-spinner"></span>
                                    Uploading...
                                </div>
                            `;

                // Create file reader to preview image
                const reader = new FileReader();

                reader.onload = function (e) {
                    if (!previewContainer) return;
                    setTimeout(() => {
                        previewContainer.innerHTML = `
                                        <img src="${e.target.result}" class="preview-image" alt="Profile Preview" />
                                    `;
                    }, 500);
                };

                reader.onerror = function () {
                    if (!previewContainer) return;
                    previewContainer.innerHTML = `
                                    <div class="preview-placeholder" style="color: var(--danger-color);">
                                        ❌
                                    </div>
                                `;
                    kendo.alert("Failed to load image. Please try again.");
                };

                reader.readAsDataURL(file);
            });

            // Reset preview when wizard resets
            $(document).on('click', '.k-wizard-buttons .k-button-secondary', function () {
                if (!previewContainer) return;
                if ($(this).text().includes('Reset') || $(this).text().includes('Cancel')) {
                    setTimeout(() => {
                        previewContainer.innerHTML = `
                                        <div class="preview-placeholder">
                                            👤
                                        </div>
                                    `;
                    }, 100);
                }
            });

            // Reset preview when changing wizard steps back
            $(document).on('click', '.k-wizard-buttons .k-button:contains("Previous")', function () {
                if (!previewContainer) return;
                const fileInput = $('[name="c_imagefile"]')[0];
                if (fileInput && (!fileInput.files || fileInput.files.length === 0)) {
                    previewContainer.innerHTML = `
                                    <div class="preview-placeholder">
                                        👤
                                    </div>
                                `;
                }
            });
        }

        /* ================= CUSTOM VALIDATIONS ================= */
        kendo.ui.validator.rules.strongPassword = function (input) {
            if (input.is("[name='c_password']")) {
                var value = input.val();
                return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&]).{8,}$/.test(value);
            }
            return true;
        };
        kendo.ui.validator.messages.strongPassword = "Password must be at least 8 characters with uppercase, lowercase, number & special character";

        kendo.ui.validator.rules.passwordMatch = function (input) {
            if (input.is("[name='c_confirmpassword']")) {
                var password = $("[name='c_password']").val();
                var confirm = input.val();
                return password === confirm;
            }
            return true;
        };
        kendo.ui.validator.messages.passwordMatch = "Passwords do not match";

        kendo.ui.validator.rules.phoneValidation = function (input) {
            if (input.is("[name='c_phonenumber']")) {
                return /^[6-9]\d{9}$/.test(input.val());
            }
            return true;
        };
        kendo.ui.validator.messages.phoneValidation = "Enter a valid 10-digit mobile number (starts with 6-9)";

        kendo.ui.validator.rules.pincodeValidation = function (input) {
            if (input.is("[name='c_pincode']")) {
                return /^[1-9][0-9]{5}$/.test(input.val());
            }
            return true;
        };
        kendo.ui.validator.messages.pincodeValidation = "Enter a valid 6-digit pincode";

        kendo.ui.validator.rules.fileRequired = function (input) {
            if (input.is("[name='c_imagefile']")) {
                var upload = input.data("kendoUpload");
                if (!upload) return true;
                return upload.getFiles().length > 0;
            }
            return true;
        };
        kendo.ui.validator.messages.fileRequired = "Please select a profile image";

        kendo.ui.validator.rules.emailExists = function (input) {
            if (input.is("[name='c_email']")) {
                var email = input.val();
                if (!email) return true;

                var emailExists = false;
                $.ajax({
                    url: "http://localhost:5245/api/Customer/checkEmailExists?email=" + email,
                    type: "GET",
                    async: false,
                    success: function () {
                        emailExists = false;
                    },
                    error: function () {
                        emailExists = true;
                    }
                });

                return emailExists === false;
            }
            return true;
        };
        kendo.ui.validator.messages.emailExists = "Email already exists";

        /* ================= WIZARD INITIALIZATION ================= */
        $(document).ready(function () {
            // Setup image preview
            setupImagePreview();

            let wizardData = {};

            $("#wizard").kendoWizard({
                pager: true,
                action: function (e) {
                    if (e.step.options.form && !e.step.options.form.validate()) {
                        e.preventDefault();
                    }
                },
                steps: [
                    /* ================= STEP 1: PERSONAL DETAILS ================= */
                    {
                        title: "Personal",
                        icon: "user",
                        buttons: ["next"], // Only Next button in first step
                        form: {
                            validateOnBlur: true,
                            layout: "grid",
                            grid: { cols: 2, gutter: 10 },
                            items: [
                                {
                                    field: "c_fname",
                                    label: "First Name",
                                    validation: { required: { message: "First name is required" } }
                                },
                                {
                                    field: "c_lname",
                                    label: "Last Name",
                                    validation: { required: { message: "Last name is required" } }
                                },
                                {
                                    field: "c_email",
                                    label: "Email Address",
                                    colSpan: 2,
                                    validation: {
                                        required: { message: "Email is required" },
                                        email: { message: "Please enter a valid email" },
                                        emailExists: true
                                    }
                                },
                                {
                                    field: "c_phonenumber",
                                    label: "Phone Number",
                                    validation: { required: { message: "Mobile number is required" }, phoneValidation: true }
                                },
                                {
                                    field: "c_gender",
                                    label: "Gender",
                                    editor: function (container, options) {
                                        const genders = ["Male", "Female", "Other"];
                                        const div = $('<div class="gender-options"></div>').appendTo(container);
                                        genders.forEach(g => {
                                            div.append(
                                                `<div class="gender-option">
                                                                        <input type="radio" name="${options.field}" value="${g}" id="gender_${g}" required data-required-msg="please select gender">
                                                                        <label for="gender_${g}"><span>${g}</span></label>
                                                                    </div>`
                                            );
                                        });
                                    },
                                    validation: { required: { message: "Please select gender" } }
                                },
                                {
                                    field: "c_password",
                                    label: "Password",
                                    colSpan: 2,
                                    editor: function (container, options) {
                                        $(`<input type="password" name="${options.field}" class="k-textbox" required placeholder="Min 8 chars with uppercase, lowercase, number & special char" data-required-msg="Password is required"/>`)
                                            .appendTo(container);
                                    },
                                    validation: { required: { message: "Password is required" }, strongPassword: true }
                                },
                                {
                                    field: "c_confirmpassword",
                                    label: "Confirm Password",
                                    colSpan: 2,
                                    editor: function (container, options) {
                                        $(`<input type="password" name="${options.field}" class="k-textbox" required placeholder="Re-enter your password" data-required-msg="Please confirm your password"/>`)
                                            .appendTo(container);
                                    },
                                    validation: { required: { message: "Please confirm your password" }, passwordMatch: true }
                                }

                            ]
                        }
                    },
                    /* ================= STEP 2: ADDRESS & IMAGE ================= */
                    {
                        title: "Address",
                        icon: "home",
                        buttons: ["previous", "done"],
                        form: {
                            validateOnBlur: true,
                            layout: "grid",
                            grid: { cols: 2, gutter: 20 },
                            items: [
                                {
                                    field: "c_pincode",
                                    label: "Pincode",
                                    validation: { required: { message: "Please Enter your pincode" }, pincodeValidation: true }
                                },
                                {
                                    field: "c_state",
                                    label: "State",
                                    editor: function (container, options) {
                                        $('<input name="' + options.field + '" required data-required-msg="State is required"/>')
                                            .appendTo(container)
                                            .kendoDropDownList({
                                                optionLabel: "Select State",
                                                dataTextField: "c_sname",
                                                dataValueField: "id",
                                                dataSource: {
                                                    transport: {
                                                        read: {
                                                            url: "http://localhost:5245/api/Customer/states",
                                                            dataType: "json"
                                                        }
                                                    }
                                                },
                                                change: function () {
                                                    const cityDropDown = $("[name='c_city']").data("kendoDropDownList");
                                                    cityDropDown.value("");
                                                    cityDropDown.dataSource.read();
                                                    cityDropDown.enable(true);
                                                }
                                            });
                                    },
                                    validation: { required: { message: "State is required" } }
                                },
                                {
                                    field: "c_city",
                                    label: "City",
                                    editor: function (container, options) {
                                        $('<input name="' + options.field + '" required data-required-msg="City is required" />')
                                            .appendTo(container)
                                            .kendoDropDownList({
                                                optionLabel: "Select City",
                                                dataTextField: "cityName",
                                                dataValueField: "cityId",
                                                enable: false,
                                                dataSource: {
                                                    transport: {
                                                        read: {
                                                            url: function () {
                                                                const stateId = $("[name='c_state']").val();
                                                                return "http://localhost:5245/api/Customer/cities/" + stateId;
                                                            },
                                                            dataType: "json"
                                                        }
                                                    }
                                                }
                                            });
                                    },
                                    validation: { required: { message: "City is required" } }
                                },

                                {
                                    field: "c_address",
                                    label: "Delivery Address",
                                    colSpan: 2,
                                    editor: function (container, options) {
                                        $(`<textarea name="${options.field}" class="k-textarea" rows="3" required placeholder="Enter your complete delivery address like 180,vithhal nagar soc.,surat" data-required-msg="Address is required"></textarea>`)
                                            .appendTo(container);
                                    },
                                    validation: { required: { message: "Address is required" } }
                                },
                                {
                                    field: "c_imagefile",
                                    label: "Profile Image",
                                    colSpan: 2,
                                    editor: function (container, options) {

                                        $(`<input type="file" 
                            name="${options.field}" 
                            accept=".jpg,.jpeg,.png" />`)
                                            .appendTo(container)
                                            .kendoUpload({
                                                multiple: false,
                                                localization: {
                                                    select: "📷 Choose Image",
                                                    dropFilesHere: "Drop your profile image here"
                                                },
                                                validation: {
                                                    allowedExtensions: [".jpg", ".jpeg", ".png"]
                                                },
                                                select: function (e) {
                                                    const file = e.files[0];
                                                    const ext = file.extension.toLowerCase();

                                                    if (![".jpg", ".jpeg", ".png"].includes(ext)) {
                                                        e.preventDefault();
                                                        kendo.alert("❌ Only JPG, JPEG, and PNG images are allowed.");
                                                    }
                                                }
                                            });
                                    },
                                    validation: {
                                        fileRequired: true
                                    }

                                }

                            ]
                        }
                    }
                ],
                /* ================= WHEN USER CLICKS DONE ================= */
                done: function (e) {
                    wizardData = { ...e.forms[0]._model.toJSON(), ...e.forms[1]._model.toJSON() };

                    let doneBtn = e.sender.element.find(".k-wizard-buttons .k-button.k-primary");
                    doneBtn.prop("disabled", true).html('<span class="loading-spinner"></span> Sending OTP...');

                    let sendFormData = new FormData();
                    sendFormData.append("email", wizardData.c_email);

                    $.ajax({
                        url: "http://localhost:5245/api/Otp/send",
                        type: "POST",
                        data: sendFormData,
                        processData: false,
                        contentType: false,
                        success: function (response) {

                            console.log("send Otyp response:", response);
                            if (response.success) {
                                doneBtn.prop("disabled", false).text("Done");
                                showOtpVerificationModal(wizardData.c_email, wizardData.c_fname);
                            } else {
                                kendo.alert(response.message || "Failed to send OTP.");
                                doneBtn.prop("disabled", false).text("Done");
                            }
                        },
                        error: function (xhr) {
                            console.log("send OTP error:", xhr);
                            let msg = xhr.responseJSON?.message || "Failed to send OTP. Please try again.";
                            kendo.alert(msg);
                            doneBtn.prop("disabled", false).text("Done");
                        }
                    });
                }
            });

            /* ================= ADD STEP INDICATOR TO LEFT SIDE ================= */
            // Function to update step indicator text
            function updateStepIndicator() {
                var wizard = $("#wizard").data("kendoWizard");
                if (!wizard) return;

                var currentStep = wizard.currentStepIndex() + 1;
                var totalSteps = wizard.steps().length;
                var stepText = "Step " + currentStep + " of " + totalSteps;

                // Find the wizard buttons container
                var buttonsContainer = $(".k-wizard-buttons");
                if (buttonsContainer.length === 0) return;

                // Check if step indicator already exists
                var stepIndicator = buttonsContainer.find(".step-indicator-left");
                if (stepIndicator.length === 0) {
                    // Create and add step indicator
                    stepIndicator = $('<span class="step-indicator-left"></span>');
                    buttonsContainer.prepend(stepIndicator);
                }

                // Update the text
                stepIndicator.text(stepText);
            }

            // Update step indicator on wizard events
            $("#wizard").on("activate", updateStepIndicator);
            $("#wizard").on("done", updateStepIndicator);

            // Initial update
            setTimeout(updateStepIndicator, 100);

            /* ================= OTP VERIFICATION MODAL ================= */
            function showOtpVerificationModal(email, firstName) {
                if ($("#otpModal").data("kendoWindow")) {
                    $("#otpModal").data("kendoWindow").destroy();
                }

                const modalContent = `
                <div style="padding: 35px; text-align: center; min-width: 350px;">
                    <div style="width: 60px; height: 60px; margin: 0 auto 20px; background: var(--swiggy-orange-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; color: var(--swiggy-orange); border: 3px solid var(--swiggy-orange-light);">
                        📱
                    </div>
                    <h4 style="font-size: 18px; margin-bottom: 10px; color: var(--text-dark); font-weight: 700;">Verify Your Email</h4>
                    <p style="color: var(--text-medium); margin-bottom: 25px; font-size: 13px; line-height: 1.5;">
                        We've sent a 6-digit OTP to<br>
                        <strong style="color: var(--text-dark); font-weight: 600;">${email}</strong>
                    </p>
                    <div style="margin-bottom: 25px;">
                        <input type="text" id="otpInput" style="width: 220px; height: 50px; font-size: 22px; letter-spacing: 8px; text-align: center; border: 2px solid var(--border-color); border-radius: 8px; margin: 0 auto; display: block; background: var(--bg-light); color: var(--text-dark); font-weight: 600;" maxlength="6" placeholder="••••••" autocomplete="off" />
                    </div>
                    <!-- CHANGED: Center the button properly -->
                    <div style="margin-bottom: 20px; display: flex; justify-content: center; align-items: center; width: 100%;">
                        <button id="verifyOtpBtn" class="k-button k-button-primary" style="padding: 10px 30px; font-size: 14px; font-weight: 600; height: 42px; min-width: 180px; display: inline-block;">Verify & Continue</button>
                    </div>
                    <div style="margin-top: 20px; font-size: 12px; color: var(--text-medium); padding-top: 15px; border-top: 1px solid var(--border-color);">
                        Didn't receive the code? 
                        <a href="javascript:void(0)" id="resendOtpBtn" style="color: var(--swiggy-orange); text-decoration: none; font-weight: 700; margin-left: 5px;">Resend OTP</a>
                    </div>
                </div>`;

                const otpWindow = $("<div id='otpModal'></div>").kendoWindow({
                    title: false,
                    modal: true,
                    width: 400,
                    resizable: false,
                    actions: ["Close"],
                    close: function () {
                        this.destroy();
                    }
                }).data("kendoWindow");

                otpWindow.content(modalContent).center().open();

                // Force center on screen
                setTimeout(() => {
                    otpWindow.center();
                }, 100);

                $("#otpInput").focus();

                $("#otpInput").on("input", function () {
                    this.value = this.value.replace(/\D/g, '');
                    if (this.value.length === 6) {
                        setTimeout(verifyOtp, 300);
                    }
                });

                let canResend = true;

                function verifyOtp() {
                    const otp = $("#otpInput").val().trim();
                    if (otp.length !== 6) {
                        kendo.alert("Please enter a valid 6-digit OTP");
                        return;
                    }

                    $("#verifyOtpBtn").prop("disabled", true)
                        .html('<span style="display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.3); border-radius: 50%; border-top-color: white; animation: spin 0.8s linear infinite; margin-right: 8px;"></span> Verifying...');

                    let verifyFormData = new FormData();
                    verifyFormData.append("email", email);
                    verifyFormData.append("otp", otp);

                    $.ajax({
                        url: "http://localhost:5245/api/Otp/verify",
                        type: "POST",
                        data: verifyFormData,
                        processData: false,
                        contentType: false,
                        success: function (response) {
                            console.log("verify OTP response:", response);
                            if (response.success) {
                                performRegistration();
                            } else {
                                kendo.alert(response.message || "Invalid OTP");
                                $("#verifyOtpBtn").prop("disabled", false).text("Verify & Continue");
                            }
                        },
                        error: function () {
                            console.log("verify OTP error:", xhr);
                            kendo.alert("Verification failed. Please try again.");
                            $("#verifyOtpBtn").prop("disabled", false).text("Verify & Continue");
                            $("#otpInput").val("").focus();
                        }
                    });
                }

                function performRegistration() {
                    let fd = new FormData();

                    // Append image file if selected
                    let fileInput = $("[name='c_imagefile']")[0];
                    if (fileInput && fileInput.files && fileInput.files.length > 0) {
                        fd.append("c_imagefile", fileInput.files[0]);
                    }


                    // Get state and city text values
                    wizardData.c_state = $("[name='c_state']").data("kendoDropDownList").text();
                    wizardData.c_city = $("[name='c_city']").data("kendoDropDownList").text();

                    // Append wizard data
                    Object.entries(wizardData).forEach(([key, value]) => {
                        if (value !== "" && value !== null && value !== undefined) {
                            fd.append(key, value);
                        }
                    });

                    $.ajax({
                        url: "http://localhost:5245/api/Customer/register",
                        type: "POST",
                        data: fd,
                        processData: false,
                        contentType: false,
                        success: function (response) {
                            console.log("registration response:", response);
                            if (response.success) {
                                showSuccessModal(firstName);
                            } else {
                                kendo.alert(response.message || "Registration failed.");
                            }
                        },
                        error: function (xhr) {
                            console.log("registration error:", xhr);
                            let msg = "Registration failed.";
                            if (xhr.responseJSON?.message) msg = xhr.responseJSON.message;
                            kendo.alert(msg);
                        }
                    });
                }

                function resendOtp() {
                    if (!canResend) return;

                    canResend = false;
                    $("#resendOtpBtn").css("opacity", "0.5");

                    $.ajax({
                        url: "http://localhost:5245/api/Otp/resend",
                        type: "POST",
                        contentType: "application/json",
                        data: JSON.stringify({ email: email }),
                        success: function (response) {
                            console.log("resend OTP response:", response);
                            if (response.success) {
                                kendo.alert("New OTP has been sent!");
                                $("#otpInput").val("").focus();

                                setTimeout(() => {
                                    canResend = true;
                                    $("#resendOtpBtn").css("opacity", "1");
                                }, 30000);
                            } else {
                                kendo.alert(response.message || "Failed to resend OTP");
                                canResend = true;
                                $("#resendOtpBtn").css("opacity", "1");
                            }
                        },
                        error: function (xhr) {
                            console.log("resend OTP error:", xhr);
                            kendo.alert("Failed to resend OTP.");
                            canResend = true;
                            $("#resendOtpBtn").css("opacity", "1");
                        }
                    });
                }

                $("#verifyOtpBtn").on("click", verifyOtp);
                $("#resendOtpBtn").on("click", resendOtp);

                $("#otpInput").on("keypress", function (e) {
                    if (e.which === 13) {
                        verifyOtp();
                    }
                });
            }

            /* ================= SUCCESS MODAL ================= */
            function showSuccessModal(firstName) {
                $("#otpModal").data("kendoWindow")?.close();

                const successContent = `
            <div style="padding: 40px; text-align: center; min-width: 350px;">
                <div style="width: 70px; height: 70px; margin: 0 auto 20px; background: linear-gradient(135deg, var(--success-color) 0%, #4A9F3A 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 35px; color: white; border: 4px solid var(--swiggy-orange-light); box-shadow: 0 10px 25px rgba(96, 178, 70, 0.3);">
                    ✓
                </div>
                <h4 style="color: var(--success-color); font-size: 20px; margin-bottom: 12px; font-weight: 800;">Welcome to DineSwift! 🎉</h4>
                <p style="color: var(--text-medium); margin-bottom: 30px; font-size: 14px; line-height: 1.6;">
                    Hey <strong style="color: var(--text-dark); font-weight: 700;">${firstName}</strong>!<br>
                    Your account is ready to use.
                </p>
                <!-- CHANGED: Center the button properly -->
                <div style="display: flex; justify-content: center; align-items: center; width: 100%; margin-bottom: 10px;">
                    <button id="goToLoginBtn" class="k-button k-button-primary" style="padding: 12px 35px; font-size: 14px; font-weight: 700; height: 45px; min-width: 200px; display: inline-block;">Start Exploring</button>
                </div>
                <div style="margin-top: 25px; font-size: 12px; color: var(--text-light);">
                    Redirecting to login page...
                </div>
            </div>`;

                const successWindow = $("<div id='successModal'></div>").kendoWindow({
                    title: false,
                    modal: true,
                    width: 420,
                    resizable: false,
                    actions: [],
                    close: function () {
                        this.destroy();
                        window.location.href = "/Auth/Login";
                    }
                }).data("kendoWindow");

                successWindow.content(successContent).center().open();

                // Force center on screen
                setTimeout(() => {
                    successWindow.center();
                }, 100);

                $("#goToLoginBtn").on("click", function () {
                    window.location.href = "/Auth/Login";
                });
            }

            // Clean Kendo fields
            function cleanKendoFields(container) {
                $(container)
                    .find("input, textarea, select")
                    .each(function () {
                        $(this)
                            .removeAttr("title")
                            .removeAttr("aria-label")
                            .attr("autocomplete", "off");
                    });
            }

            $(document).ready(function () {
                cleanKendoFields(document);
            });

            $(document).on("focusin", ".k-form input, .k-form textarea, .k-form select", function () {
                $(this).removeAttr("title").removeAttr("aria-label");
            });

            $(document).on("kendoStepperActivate", function (e) {
                try { cleanKendoFields(e.sender.element); } catch (err) { }
            });
        });
    </script>
}