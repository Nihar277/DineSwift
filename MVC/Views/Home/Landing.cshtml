@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DineSwift – Delicious Food, Delivered Swift</title>
    
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #ff7a18;
            --primary-dark: #f06400;
            --bg: #fff6ef;
            --text: #2d2d2d;
            --muted: #777;
        }

        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(180deg, #fff2e8 0%, #fffaf6 100%);
            color: var(--text);
        }

        /* HEADER */
        .header {
            max-width: 1200px;
            margin: auto;
            padding: 18px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            color: var(--primary);
        }

        .nav a {
            margin: 0 12px;
            text-decoration: none;
            font-weight: 500;
            color: #333;
        }

        .btn {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 500;
        }

        /* HERO */
        .hero {
            position: relative;
            text-align: center;
            padding: 90px 20px 110px;
            overflow: hidden;
        }

        .hero h1 {
            font-size: 46px;
            line-height: 1.2;
            margin-bottom: 14px;
        }

        .hero span { color: var(--primary); }

        .hero p {
            max-width: 620px;
            margin: auto;
            color: var(--muted);
            font-size: 15px;
        }

        /* SEARCH */
        .search {
            margin-top: 30px;
            display: flex;
            justify-content: center;
        }

        .search-box {
            width: 520px;
            background: #fff;
            border-radius: 40px;
            padding: 8px;
            display: flex;
            box-shadow: 0 20px 40px rgba(0,0,0,.08);
        }

        .search-box input {
            border: none;
            outline: none;
            flex: 1;
            padding: 12px 18px;
            font-size: 14px;
        }

        /* FLOATING ICONS */
        .food {
            position: absolute;
            width: 60px;
            animation: float 4s ease-in-out infinite;
            opacity: .9;
        }

        .f1 { top: 20%; left: 8%; }
        .f2 { top: 25%; right: 10%; animation-delay: 1s; }
        .f3 { bottom: 22%; left: 15%; animation-delay: 2s; }

        @@keyframes float {
            0%,100% { transform: translateY(0); }
            50% { transform: translateY(-14px); }
        }

        /* SECTIONS */
        .section {
            max-width: 1200px;
            margin: auto;
            padding: 60px 24px;
        }

        .section h2 {
            font-size: 26px;
            margin-bottom: 10px;
        }

        /* WHAT'S ON YOUR MIND */
        .mind-sub {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 22px;
        }

        .mind-row {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .mind-item {
            background: #fff;
            border-radius: 16px;
            padding: 14px 18px;
            min-width: 90px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,.06);
            cursor: pointer;
            transition: all .3s ease;
        }

        .mind-item img {
            width: 26px;
            margin-bottom: 6px;
        }

        .mind-item span {
            font-size: 13px;
            font-weight: 500;
        }

        .mind-item:hover {
            transform: translateY(-4px);
        }

        .mind-item.active {
            background: var(--primary);
            color: #fff;
        }

        .mind-item.active img {
            filter: brightness(0) invert(1);
        }

        /* RESTAURANTS */
        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 22px;
        }

        .card {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 16px 30px rgba(0,0,0,.07);
            transition: transform .3s;
        }

        .card:hover {
            transform: translateY(-6px);
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

        .card-body {
            padding: 14px;
        }

        .rating {
            color: #28a745;
            font-weight: 600;
            font-size: 14px;
        }

        /* FOOTER */
        footer {
            background: #2b1b14;
            color: #ddd;
            padding: 50px 24px;
        }

        footer .grid {
            max-width: 1200px;
            margin: auto;
            grid-template-columns: repeat(3,1fr);
        }

        footer a {
            color: #bbb;
            text-decoration: none;
            font-size: 14px;
            display: block;
            margin-bottom: 6px;
        }

        @@media(max-width: 900px) {
            .grid { grid-template-columns: 1fr; }
        }

        /* WHY CHOOSE US */
.why {
    background: #fff;
    border-radius: 24px;
    padding: 60px 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,.06);
}

.why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 30px;
}

.why-card {
    text-align: center;
    padding: 26px 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, #fff7f1, #ffffff);
    transition: all .3s ease;
}

.why-card:hover {
    transform: translateY(-6px);
}

.why-card img {
    width: 54px;
    margin-bottom: 14px;
}

.why-card h4 {
    margin: 10px 0 6px;
    font-size: 16px;
}

.why-card p {
    font-size: 13px;
    color: var(--muted);
}

@@media(max-width: 900px) {
    .why-grid { grid-template-columns: 1fr; }
}

    </style>
</head>
<body>

<div class="header">
    <div class="logo">🍔 DineSwift</div>
    <div class="nav">
        <a href="#">Home</a>
        <a href="#">Restaurants</a>
        <a href="#">Offers</a>
    </div>
    <button class="btn">Sign In</button>
</div>

<section class="hero">
    <img class="food f1" src="https://cdn-icons-png.flaticon.com/512/1046/1046784.png">
    <img class="food f2" src="https://cdn-icons-png.flaticon.com/512/1404/1404945.png">
    <img class="food f3" src="https://cdn-icons-png.flaticon.com/512/1046/1046786.png">

    <h1>Delicious Food,<br><span>Delivered Swift</span></h1>
    <p>Discover the best restaurants near you and get your favorite meals delivered hot & fresh.</p>

    <div class="search">
        <div class="search-box">
            <input type="text" placeholder="Enter your delivery address" />
            <button class="btn">Find Food</button>
        </div>
    </div>
</section>

<!-- WHAT'S ON YOUR MIND -->
<section class="section mind">
    <h2>What's on your mind?</h2>
    <p class="mind-sub">Explore cuisines from around the world</p>

    <div class="mind-row">
        <div class="mind-item active"><img src="https://cdn-icons-png.flaticon.com/512/1828/1828884.png"><span>All</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/3132/3132693.png"><span>Pizza</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/3075/3075977.png"><span>Burgers</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/3075/3075974.png"><span>Sushi</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/992/992754.png"><span>Indian</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/1046/1046781.png"><span>Chinese</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/1046/1046777.png"><span>Mexican</span></div>
        <div class="mind-item"><img src="https://cdn-icons-png.flaticon.com/512/1046/1046785.png"><span>Desserts</span></div>
    </div>
</section>

<section class="section">
    <h2>Popular Restaurants Near You</h2>
    <div class="grid">
        <div class="card">
            <img src="https://images.unsplash.com/photo-1528605248644-14dd04022da1?w=800">
            <div class="card-body">
                <strong>The Italian Kitchen</strong><br>
                <span class="rating">★ 4.8</span>
            </div>
        </div>
        <div class="card">
            <img src="https://images.unsplash.com/photo-1550547660-d9450f859349?w=800">
            <div class="card-body">
                <strong>Burger Palace</strong><br>
                <span class="rating">★ 4.6</span>
            </div>
        </div>
        <div class="card">
            <img src="https://images.unsplash.com/photo-1541544741938-0af808871cc0?w=800">
            <div class="card-body">
                <strong>Sakura Sushi</strong><br>
                <span class="rating">★ 4.9</span>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="why">
        <h2>Why Choose DineSwift?</h2>
        <p class="mind-sub">We make food delivery faster, smarter & tastier</p>

        <div class="why-grid">
            <div class="why-card">
                <img src="https://cdn-icons-png.flaticon.com/512/2972/2972185.png">
                <h4>Lightning Fast Delivery</h4>
                <p>Your favorite meals delivered hot & fresh in minutes.</p>
            </div>

            <div class="why-card">
                <img src="https://cdn-icons-png.flaticon.com/512/3081/3081559.png">
                <h4>Top Rated Restaurants</h4>
                <p>Only the best local restaurants with high ratings.</p>
            </div>

            <div class="why-card">
                <img src="https://cdn-icons-png.flaticon.com/512/1828/1828919.png">
                <h4>Secure & Easy Ordering</h4>
                <p>Simple checkout with safe & reliable payments.</p>
            </div>
        </div>
    </div>
</section>


<footer>
    <div class="grid">
        <div>
            <h4>DineSwift</h4>
            <p>Fast, fresh food delivered.</p>
        </div>
        <div>
            <h4>Company</h4>
            <a href="#">About</a>
            <a href="#">Careers</a>
        </div>
        <div>
            <h4>Support</h4>
            <a href="#">Help Center</a>
            <a href="#">Privacy Policy</a>
        </div>
    </div>
</footer>

</body>
</html>
