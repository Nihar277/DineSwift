</div>

</body>









@section Scripts {

    <script>
        $(document).ready(function () {
             (function () {

        // Function to remove field-name overlays (like "c_email")
        function cleanKendoFields(container) {
            $(container)
                .find("input, textarea, select")
                .each(function () {
                    $(this)
                        .removeAttr("title")
                        .removeAttr("aria-label")
                        .attr("autocomplete", "off");
                });
        }

        // Run on initial page load
        $(document).ready(function () {
            cleanKendoFields(document);
        });

        // Run when focusing any input (fixes stepper dynamic rendering)
        $(document).on("focusin", ".k-form input, .k-form textarea, .k-form select", function () {
            $(this).removeAttr("title").removeAttr("aria-label");
        });

        // Stepper support: when step changes, re-clean fields
        $(document).on("kendoStepperActivate", function (e) {
            try { cleanKendoFields(e.sender.element); } catch (err) { }
        });

    })();

            function showLoader(text) {
    $("#loaderText").text(text);
    $("#globalLoader").fadeIn(200);
}

function hideLoader() {
    $("#globalLoader").fadeOut(200);
}


            let otpSent = false;
            let otpVerified = false;

            /* ================= CUSTOM VALIDATIONS ================= */

            kendo.ui.validator.rules.strongPassword = function (input) {
                if (input.is("[name='c_password']")) {
                    var value = input.val();
                    return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&]).{8,}$/.test(value);
                }
                return true;
            };
            kendo.ui.validator.messages.strongPassword = "Password must contain uppercase, lowercase, number & special character";

            kendo.ui.validator.rules.passwordMatch = function (input) {
                if (input.is("[name='c_confirmpassword']")) {
                    var password = $("[name='c_password']").val();
                    var confirm = input.val();
                    return password === confirm;
                }
                return true;
            };
            kendo.ui.validator.messages.passwordMatch = "Password and Confirm Password do not match";

            kendo.ui.validator.rules.ifscValidation = function (input) {
                if (input.is("[name='c_r_ifsc']")) {
                    return /^[A-Z]{4}0[A-Z0-9]{6}$/.test(input.val());
                }
                return true;
            };
            kendo.ui.validator.messages.ifscValidation = "Invalid IFSC Code";

            kendo.ui.validator.rules.phoneValidation = function (input) {
                if (input.is("[name='c_phonenumber']")) {
                    return /^[6-9]\d{9}$/.test(input.val());
                }
                return true;
            };
            kendo.ui.validator.messages.phoneValidation = "Enter a valid 10-digit mobile number";

            kendo.ui.validator.rules.pincodeValidation = function (input) {
                if (input.is("[name='c_pincode']")) {
                    return /^[1-9][0-9]{5}$/.test(input.val());
                }
                return true;
            };
            kendo.ui.validator.messages.pincodeValidation = "Enter a valid 6-digit pincode";

            kendo.ui.validator.rules.accountNoValidation = function (input) {
                if (input.is("[name='c_r_ac']")) {
                    return /^\d{12}$/.test(input.val());
                }
                return true;
            };
            kendo.ui.validator.messages.accountNoValidation = "Account number must be exactly 12 digits";

            kendo.ui.validator.rules.fileRequired = function (input) {
                if (input.is("[name='c_image']") || input.is("[name='c_r_image']") || input.is("[name='c_r_aadhar']")) {
                    var upload = input.getKendoUpload();
                    if (!upload) return false;
                    return upload.getFiles().length > 0;
                }
                return true;
            };
            kendo.ui.validator.messages.fileRequired = "Please select a file";

            kendo.ui.validator.rules.gstValidation = function (input) {
                if (input.is("[name='c_r_gst']")) {
                    var gst = input.val().toUpperCase();
                    // Indian GST format
                    return /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/.test(gst);
                }
                return true;
            };

            kendo.ui.validator.messages.gstValidation = "Enter a valid GST Number (Example: 27AAPFU0939F1ZV)";

            kendo.ui.validator.rules.emailExists = function (input) {

                if (input.is("[name='c_email']")) {

                    var email = input.val();
                    if (!email) return true;

                    $.ajax({
                        url: "http://localhost:5245/api/Customer/checkEmailExists?email=" + email,
                        type: "GET",               // or POST (as per your API)
                        async: false,              // 🔴 REQUIRED
                        success: function () {
                            emailExists = false;   // email NOT exists
                        },
                        error: function () {
                            emailExists = true;    // email exists (400)
                        }
                    });

                    return emailExists === false;
                }

                return true;
            };

            kendo.ui.validator.messages.emailExists = "Email already exists";


