<!-- Kendo UI CSS -->
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2025.3.1015/styles/kendo.default-v2.min.css" />

<!-- jQuery -->
<script src="https://kendo.cdn.telerik.com/2025.3.1015/js/jquery.min.js"></script>

<!-- Kendo UI JS -->
<script src="https://kendo.cdn.telerik.com/2025.3.1015/js/kendo.all.min.js"></script>



<style>

        /* ================= ROOT & BODY ================= */
        *, *::before, *::after {
            box-sizing: border-box;
            
        }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            background: #fef0e6;
        }

        /* ================= MAIN WRAPPER ================= */
        .vendor-wrapper {
            width: min(95%, 1300px);
            min-height: 85vh;
            display: flex;
            align-items: stretch;
            justify-content: center;
            border-radius: 24px;
        }

        /* ================= LEFT PANEL ================= */
        .vendor-left {
            flex: 1 1 45%;
            min-width: 320px;
            position: relative;
            overflow: hidden;
            color: #fff;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 50%, #dc2626 100%);
            border-radius: 24px 0 0 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-box {
            width: 80%;
            text-align: center;
            position: relative;
            z-index: 2;
             margin-bottom: 20px;
        }
        

        /* ================= LOGO ================= */
        .brand-logo {
            width: clamp(180px, 25vw, 300px);
            height: auto;
            display: block;
            margin: clamp(-60px, -8vh, -80px) auto 20px;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.35));
          
           

        }

        /* ================= IMAGE CARD ================= */
        .image-card {
            width: clamp(220px, 28vw, 280px);
            height: clamp(280px, 40vw, 360px);
            margin: 20px auto;
            background: rgba(255,255,255,0.15);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 25px 50px rgba(0,0,0,0.35);
            margin-top: -70px;
            
        }

        .image-card img {
            width: 90%;
            animation: floatImage 5s ease-in-out infinite;
        }

        /* ================= BADGES ================= */
        .badges {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 30px;
        }

        .badge {
            background: rgba(255,255,255,0.2);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
        }

        /* ================= STATS ================= */
        .stats-box {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .stat {
            background: rgba(255,255,255,0.18);
            border-radius: 14px;
            padding: 12px;
            text-align: center;
        }

        .stat h4 {
            margin: 0;
            font-size: clamp(16px, 2vw, 20px);
        }

        .stat span {
            font-size: 12px;
            opacity: 0.9;
        }

        /* ================= FLOATING ICONS ================= */
        .float-icon {
            position: absolute;
            font-size: 22px;
            opacity: 0.6;
            animation: floatIcons 8s infinite ease-in-out;
        }

        .icon-1 { top: 20%; left: 10%; }
        .icon-2 { top: 40%; right: 15%; }
        .icon-3 { bottom: 30%; left: 15%; }
        .icon-4 { bottom: 20%; right: 10%; }

        /* ================= RIGHT PANEL ================= */
        .vendor-right {
            flex: 1 1 55%;
            min-width: 320px;
            background: #fff;
            border-radius: 0 24px 24px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .form-card {
            width: 85%;
        }

        .title {
            text-align: center;
            font-size: clamp(18px, 2vw, 26px);
            margin-bottom: 30px;
            font-weight: 600;
        }

        /* ================= BACK BUTTON ================= */
        .back-inside-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            padding: 8px 16px;
            border-radius: 18px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            color: #c6894d;
            background: #fff3e6;
            border: 1px solid #ffd2a8;
            transition: all 0.25s ease;
        }

        .back-inside-btn:hover {
            background: #ff7a00;
            color: #fff;
            transform: translateX(-4px);
        }

        /* ================= KENDO FIXES ================= */
        .k-wizard {
            border: none !important;
            background: transparent !important;
        }

        .k-stepper {
            justify-content: center;
        }

        .k-step-current .k-step-indicator {
            background: #ff7a00 !important;
            color: #fff !important;
        }

        /* ================= ANIMATIONS ================= */
        @@keyframes floatImage {
            0% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0); }
        }

        @@keyframes floatIcons {
            0% { transform: translateY(0); }
            50% { transform: translateY(-25px); }
            100% { transform: translateY(0); }
        }

        /* ================= RESPONSIVE - TABLET ================= */
        @@media (max-width: 1024px) {
            .vendor-wrapper {
                flex-direction: column;
                min-height: auto;
                width: 95%;
            }

            .vendor-left,
            .vendor-right {
                width: 100%;
                min-width: unset;
                border-radius: 0;
            }

            .vendor-left {
                border-radius: 24px 24px 0 0;
                padding: 30px 20px;
            }

            .vendor-right {
                border-radius: 0 0 24px 24px;
                padding: 40px 20px;
            }

            .brand-box {
                width: 90%;
            }

            .image-card {
                width: 200px;
                height: 260px;
            }
        }

        /* ================= RESPONSIVE - MOBILE ================= */
        @@media (max-width: 480px) {
            body {
                align-items: flex-start;
                padding: 10px;
            }

            .vendor-wrapper {
                width: 100%;
                margin-top: 10px;
                border-radius: 16px;
            }

            .vendor-left {
                border-radius: 16px 16px 0 0;
                padding: 20px 15px;
            }

            .vendor-right {
                border-radius: 0 0 16px 16px;
                padding: 30px 15px;
            }

            .brand-logo {
                width: 150px;
                margin: -30px auto 15px;
            }

            .image-card {
                width: 160px;
                height: 200px;
                margin: 15px auto;
            }

            .badges {
                flex-wrap: wrap;
                gap: 8px;
                margin-bottom: 20px;
            }

            .badge {
                padding: 5px 10px;
                font-size: 11px;
            }

            .stats-box {
                grid-template-columns: repeat(2, 1fr);
                gap: 8px;
            }

            .stat {
                padding: 10px 8px;
            }

            .stat h4 {
                font-size: 14px;
            }

            .stat span {
                font-size: 10px;
            }

            .form-card {
                width: 95%;
            }

            .title {
                font-size: 18px;
                margin-bottom: 20px;
            }

            .back-inside-btn {
                top: 12px;
                left: 12px;
                padding: 6px 12px;
                font-size: 12px;
            }

            .float-icon {
                font-size: 16px;
            }

            .k-stepper .k-step-label {
                font-size: 11px;
            }
        }

        .loader-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.loader-box {
    background: #fff;
    padding: 24px 32px;
    border-radius: 14px;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
}

.loader-box .k-icon {
    font-size: 42px;
    color: #ff7a00;
    animation: spin 1s linear infinite;
}

.loader-box p {
    margin-top: 12px;
    font-size: 14px;
    font-weight: 600;
}

@@keyframes spin {
    to { transform: rotate(360deg); }
}



/* Main orange background */
/* 🔥 Hide Kendo field-name validation tooltips */
.k-tooltip,
.k-tooltip-validation {
    display: none !important;
}

/* 🛑 Prevent browser autofill icons overlay */
input::-webkit-credentials-auto-fill-button {
    display: none !important;
}

/* 👇 Extra safety: remove auto labels from dropdown inputs */
.k-dropdown .k-input,
.k-dropdown input {
    title: "" !important;
    aria-label: "" !important;
}


</style>

<body>
     <div class="vendor-wrapper">
        <!-- ================= LEFT PANEL ================= -->
        <div class="vendor-left">
            <!-- Floating Food Icons -->
            <span class="float-icon icon-1">🍔</span>
