                                                        read: {
                                                            url: function () {
                                                                const stateId = $("[name='c_r_state']").val();
                                                                return "http://localhost:5245/api/Customer/cities/" + stateId;
                                                            },
                                                            dataType: "json"
                                                        }
                                                    }
                                                }
                                            });
                                    },
                                    validation: { required: { message: "City is required" } }
                                },
                                { field: "c_r_address", label: "Restaurant Address", editor: (c, o) => { $('<textarea name="' + o.field + '" required data-required-msg="Address is required"></textarea>').appendTo(c).kendoTextArea({ rows: 2 }); }, validation: { required: true } },
                                { field: "c_r_ac", label: "Account Number", validation: { required: { message: "Account Number is required" }, accountNoValidation: true } },
                                { field: "c_r_ifsc", label: "IFSC Code", validation: { required: { message: "IFSC Code is required" }, ifscValidation: true } },
                                {
                                    field: "c_r_gst",
                                    label: "GST Number",
                                    validation: {
                                        required: { message: "GST Number is required" },
                                        gstValidation: true
                                    }
                                },

                                {
                                    field: "c_r_image",
                                    label: "Restaurant Logo",
                                    editor: function (container, options) {
                                        $(`<input type="file" 
                    name="${options.field}" 
                    accept=".jpg,.jpeg,.png" />`)
                                            .appendTo(container)
                                            .kendoUpload({
                                                multiple: false,
                                                localization: {
                                                    select: "📷 Choose Logo"
                                                },
                                                validation: {
                                                    allowedExtensions: [".jpg", ".jpeg", ".png"]
                                                },
                                                select: function (e) {
                                                    const ext = e.files[0].extension.toLowerCase();
                                                    if (![".jpg", ".jpeg", ".png"].includes(ext)) {
                                                        e.preventDefault();
                                                        kendo.alert("❌ Only JPG, JPEG, and PNG images are allowed.");
                                                    }
                                                }
                                            });
                                    },
                                    validation: { fileRequired: true }
                                },
                                {
                                    field: "c_r_aadhar",
                                    label: "Food Licence",
                                    editor: function (container, options) {
                                        $(`<input type="file" 
                    name="${options.field}" 
                    accept=".jpg,.jpeg,.png" />`)
                                            .appendTo(container)
                                            .kendoUpload({
                                                multiple: false,
                                                localization: {
                                                    select: "🪪 Upload Aadhar"
                                                },
                                                validation: {
                                                    allowedExtensions: [".jpg", ".jpeg", ".png"]
                                                },
                                                select: function (e) {
                                                    const ext = e.files[0].extension.toLowerCase();
                                                    if (![".jpg", ".jpeg", ".png"].includes(ext)) {
                                                        e.preventDefault();
                                                        kendo.alert("❌ Only JPG, JPEG, and PNG images are allowed.");
                                                    }
                                                }
                                            });
                                    },
                                    validation: { fileRequired: true }
                                }

                            ]
                        }
                    }
                ],

                /* ================= SUBMIT ================= */
                done: function (e) {

                    if (!e.forms[2].validate()) return;

                    let email = $("[name='c_email']").val();
                    showLoader("Sending OTP...");


                    // SEND OTP if not sent
                    if (!otpSent) {
                        var formData = new FormData();
                        formData.append("Email", email);

                        $.ajax({
                            url: "http://localhost:5245/api/otp/send",
                            type: "POST",
                            data: formData,
                            contentType: false,
                            processData: false,
                            success: function (res) {
                                 hideLoader();
                                if (res.success) {
                                    otpSent = true;
                                    openOtpDialog(e);
                                } else {
                                    kendo.alert(res.Message || "OTP not sent");
                                }
                            },
                            error: function () {
                                 hideLoader();
                                kendo.alert("OTP service failed");
                            }
                        });
                        return;
                    }

                    // If OTP already sent
                    openOtpDialog(e);
                }

            });

           function openOtpDialog(e) {

    // destroy previous dialog
    if ($("#otpDialog").data("kendoDialog")) {
        $("#otpDialog").data("kendoDialog").destroy();
        $("#otpDialog").remove();
    }

    $("<div id='otpDialog' />").kendoDialog({
        title: "Verify OTP",
        width: "420px",
        modal: true,
        content: `
        <style>
            .k-dialog { animation: otpZoomIn 0.35s ease-out; }
            @@keyframes otpZoomIn {
                from { transform: scale(0.85); opacity: 0; }
                to { transform: scale(1); opacity: 1; }
            }
            .otp-container { text-align:center; padding:10px 0; }
            .otp-title { font-size:18px; font-weight:600; margin-bottom:6px; }
            .otp-subtitle { font-size:13px; color:#6b7280; margin-bottom:16px; }
            .otp-inputs { display:flex; justify-content:center; gap:8px; }
            .otp-box {
                width:42px; height:46px; text-align:center;
                font-size:20px; border-radius:8px;
                border:1px solid #d1d5db;
            }
            .otp-box:focus {
                border-color:#4f46e5;
                box-shadow:0 0 0 2px rgba(79,70,229,0.25);
            }
            .k-dialog .k-primary {
                background:linear-gradient(135deg,#4f46e5,#6366f1);
                border:none;
            }
        </style>

        <div class="otp-container">
            <div class="otp-title">OTP Verification</div>
            <div class="otp-subtitle">Enter the 6-digit code sent to your email</div>

            <div class="otp-inputs">
                <input class="otp-box" maxlength="1" />
                <input class="otp-box" maxlength="1" />
                <input class="otp-box" maxlength="1" />
                <input class="otp-box" maxlength="1" />
                <input class="otp-box" maxlength="1" />
                <input class="otp-box" maxlength="1" />
            </div>

            <input type="hidden" id="otpInput" />
        </div>
        `,
        open: function () {

            const boxes = $("#otpDialog .otp-box");
            boxes.first().focus();

            boxes.on("input", function () {
                const i = boxes.index(this);
                if (this.value && boxes[i + 1]) boxes[i + 1].focus();
                $("#otpInput").val(boxes.map(function () {
                    return this.value;
                }).get().join(""));
            });

            boxes.on("keydown", function (e) {
                const i = boxes.index(this);
                if (e.key === "Backspace" && !this.value && boxes[i - 1]) {
                    boxes[i - 1].focus();
                }
            });
        },
        actions: [
            {
                text: "Verify",
                primary: true,
                action: function () {

                    const otp = $("#otpInput").val();
                    const email = $("[name='c_email']").val();

                    if (!otp) {
                        kendo.alert("Enter OTP");
                        return false;
                    }

                    var otpData = new FormData();
                    otpData.append("Email", email);
                    otpData.append("OTP", otp);

                    showLoader("Verifying OTP...");


                    // VERIFY OTP
                    $.ajax({
                        url: "http://localhost:5245/api/otp/verify",
                        type: "POST",
                        data: otpData,
                        contentType: false,
                        processData: false,
                        success: function (res) {
                            hideLoader();
                            if (!res.success) {
                                kendo.alert(res.Message || "Invalid OTP");
                                return;
                            }

                            // ✅ CLOSE OTP DIALOG
                             hideLoader();
                            $("#otpDialog").data("kendoDialog").close();

                            // FINAL SUBMIT
                            let data = {
                                ...e.forms[0]._model,
                                ...e.forms[1]._model,
                                ...e.forms[2]._model
                            };

                            let fd = new FormData();
                            Object.entries(data).forEach(([key, value]) => {
                                if (
                                    value !== null &&
                                    value !== "" &&
                                    !["c_state", "c_city", "c_r_state", "c_r_city"].includes(key)
                                ) {
                                    fd.append(key, value);
                                }
                            });

                            if ($("[name='c_image']")[0].files.length)
                                fd.append("c_image", $("[name='c_image']")[0].files[0]);
                            if ($("[name='c_r_image']")[0].files.length)
                                fd.append("c_r_image", $("[name='c_r_image']")[0].files[0]);
                            if ($("[name='c_r_aadhar']")[0].files.length)
                                fd.append("c_r_aadhar", $("[name='c_r_aadhar']")[0].files[0]);

                            fd.append("c_state", $("[name='c_state']").data("kendoDropDownList").text());
                            fd.append("c_city", $("[name='c_city']").data("kendoDropDownList").text());
                            fd.append("c_r_state", $("[name='c_r_state']").data("kendoDropDownList").text());
                            fd.append("c_r_city", $("[name='c_r_city']").data("kendoDropDownList").text());
                            showLoader("Registering vendor...");

                            $.ajax({
                                url: "http://localhost:5245/api/restaurant/vendor/register",
                                type: "POST",
                                data: fd,
                                processData: false,
                                contentType: false,
                                success: function (res) {
                                     hideLoader();
                                    if (res.success) {

                                        // ✅ SUCCESS DIALOG
                                        $("<div />").kendoDialog({
                                            title: "Registration Successful",
                                            content: `
                                                <div style="text-align:center;padding:10px">
                                                    <h3>🎉 Vendor Registered!</h3>
                                                    <p>Your account has been created successfully.</p>
                                                </div>
                                            `,
                                            width: "400px",
                                            modal: true,
                                            actions: [{
                                                text: "OK",
                                                primary: true,
                                                action: function () {
                                                    window.location.href = "/auth/login";
                                                }
                                            }]
                                        }).data("kendoDialog").open();
                                    }
                                },
                                error: function (err) {
                                     hideLoader();
                                    if (err.responseJSON?.Message) {
                                        kendo.alert(err.responseJSON.Message);
                                    } else if (err.responseJSON?.errors) {
                                        kendo.alert(Object.values(err.responseJSON.errors).join("\n"));
                                    } else {
                                        kendo.alert("Registration failed.");
                                    }
                                }
                            });
                        },
                        error: function () {
                             hideLoader();
                            kendo.alert("OTP verification failed.");
                        }
                    });

                    return false;
                }
            },
            { text: "Cancel" }
        ]
    }).data("kendoDialog").open();
}





        });
    </script>
}