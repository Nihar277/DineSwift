    <span class="password-toggle" data-target="oldPassword">
        <i class="fa-solid fa-eye-slash"></i>
    </span>
</div>

            <span class="k-invalid-msg" data-for="oldPassword"></span>
        </div>

        <div class="window-form-group">
            <label>New Password</label>
           <div style="position:relative;">
    <input id="newPassword" name="newPassword" type="password" class="k-textbox" required data-required-msg="New Password is required" />
    <span class="password-toggle" data-target="newPassword">
        <i class="fa-solid fa-eye-slash"></i>
    </span>
</div>

            <span class="k-invalid-msg" data-for="newPassword"></span>
        </div>

        <div class="window-form-group">
            <label>Confirm Password</label>
           <div style="position:relative;">
    <input id="confirmPassword" name="confirmPassword" type="password" class="k-textbox" required data-required-msg="Confirm Password is required" />
    <span class="password-toggle" data-target="confirmPassword">
        <i class="fa-solid fa-eye-slash"></i>
    </span>
</div>

            <span class="k-invalid-msg" data-for="confirmPassword"></span>
        </div>

        <div class="window-buttons">
            <button type="button" class="k-button btn-secondary" onclick="closeChangePassword()">Cancel</button>
            <button type="button" class="k-button btn-save" id="btnChangePassword">
                <span class="btn-text">Update Password</span>
                <span class="btn-spinner" style="display:none;"><i class="fa-solid fa-spinner fa-spin"></i></span>
            </button>

        </div>
    </form>
</div>

@section Scripts {
<script>
    // Ensure jQuery is loaded
    if (typeof jQuery === 'undefined') {
        console.error('jQuery is not loaded!');
    }
    
    @* const USER_ID = "@Context.Session.GetInt32("CustomerId")"; *@
    let originalData = {};
    const apiBase = "http://localhost:5245";
    const imageBase = "/Images/customer/"; // Make sure this matches your MVC static files path
    
    $(document).ready(function() {
        loadCartCount();
        $("#btnChangePassword").on("click", function () {
            $("#changePasswordForm").trigger("submit");
        });
    });

    function loadCartCount() {
    $.get(`/api/userHome/GetCartCount?userid=${USER_ID}`, function (count) {
        $("#cartCount").text(count);
    });
}



    let changePasswordWindow;

    /* ================= NOTIFICATION SYSTEM ================= */
    function showNotification(message, type) {
        // Create notification container if it doesn't exist
        if (!$("#notificationContainer").length) {
            $('body').append('<div id="notificationContainer"></div>');
        }
        
        const container = $("#notificationContainer");
        
        // Create Kendo Notification widget
        container.kendoNotification({
            position: {
                pinned: true,
                top: 50,
                right: 50
            },
            stacking: "down",
            hideOnClick: true,
            autoHideAfter: 4000,
            templates: [{
                type: "success",
                template: '<div class="k-notification-success">#= message #</div>'
            }, {
                type: "error",
                template: '<div class="k-notification-error">#= message #</div>'
            }, {
                type: "info",
                template: '<div class="k-notification-info">#= message #</div>'
            }]
        }).data("kendoNotification");
        
        // Show notification
        const notification = container.data("kendoNotification");
        notification.show({
            message: message
        }, type || "info");
    }

    // Add CSS for notification styles
    $('head').append(`
    <style>
        .k-notification-success {
            background: #4CAF50;
            color: white;
            padding: 15px 20px;
            border-radius: 8px;
            font-weight: 500;
            box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
        }
        
        .k-notification-error {
            background: #F44336;
            color: white;
            padding: 15px 20px;
            border-radius: 8px;
            font-weight: 500;
            box-shadow: 0 4px 12px rgba(244, 67, 54, 0.3);
        }
        
        .k-notification-info {
            background: #2196F3;
            color: white;
            padding: 15px 20px;
            border-radius: 8px;
            font-weight: 500;
            box-shadow: 0 4px 12px rgba(33, 150, 243, 0.3);
        }
    </style>
    `);

    $(document).ready(function () {
        // 🔹 Change Password
        initChangePasswordWindow();
        initChangePasswordValidator();

        // 🔹 Profile Form Validator
       $("#profileForm").kendoValidator({
    validateOnBlur: true,
    rules: {

        // Gender required
        genderRequired: function (input) {
            if (input.is("[name='c_gender']")) {
                return $("input[name='c_gender']:checked").length > 0;
            }
            return true;
        },

        // Phone number → exactly 10 digits
        phoneLength: function (input) {
            if (input.is("#phoneNumber")) {
                return /^\d{10}$/.test(input.val());
            }
            return true;
        },

        // Postal code → exactly 6 digits
        pincodeLength: function (input) {
            if (input.is("#pincode")) {
                return /^\d{6}$/.test(input.val());
            }
            return true;
        }
    },

    messages: {
        required: "This field is required",
        genderRequired: "Please select gender",
        phoneLength: "Phone number must be exactly 10 digits",
        pincodeLength: "Postal code must be exactly 6 digits"
    }
});


        // 🔹 Load profile data
        loadProfile();
    });

    /* ================= KENDO WINDOW ================= */
    function initChangePasswordWindow() {
        changePasswordWindow = $("#changePasswordWindow").kendoWindow({
            title: "Change Password",
            modal: true,
            visible: false,
            width: "420px",
            resizable: false
        }).data("kendoWindow");
    }

    function openChangePasswordWindow() {
        $("#changePasswordForm")[0].reset();
        $(".k-invalid-msg").hide();
        changePasswordWindow.center().open();
    }

    function closeChangePassword() {
        changePasswordWindow.close();
    }

    /* ================= VALIDATION ================= */
    function initChangePasswordValidator() {
        $("#changePasswordForm").kendoValidator({
            validateOnBlur: true,
            rules: {
                passwordLength: function (input) {
                    if (input.is("#newPassword")) {
                        return input.val().length >= 8;
                    }
                    return true;
                },
                passwordMatch: function (input) {
                    if (input.is("#confirmPassword")) {
                        return input.val() === $("#newPassword").val();
                    }
                    return true;
                }
            },
            messages: {
                required: "This field is required",
                passwordLength: "Password must be at least 8 characters",
                passwordMatch: "Passwords do not match"
            }
        });
    }

    /* ================= CHANGE PASSWORD SUBMIT ================= */
$("#changePasswordForm").on("submit", function (e) {
    e.preventDefault();

    const validator = $(this).data("kendoValidator");
    if (!validator.validate()) return;

    // Show Kendo window progress and button spinner
    kendo.ui.progress($("#changePasswordWindow .k-window-content"), true);
    const $btn = $("#btnChangePassword");
    $btn.prop('disabled', true);
    $btn.find('.btn-text').hide();
    $btn.find('.btn-spinner').show();

    function restoreChangePasswordBtn() {
        $btn.prop('disabled', false);
        $btn.find('.btn-spinner').hide();
        $btn.find('.btn-text').show();
    }

    $.ajax({
        url: apiBase + "/api/Password/change/" + USER_ID,
        type: "POST",
        contentType: "application/json",
        data: JSON.stringify({
            currentPassword: $("#oldPassword").val(),
            newPassword: $("#newPassword").val(),
            confirmPassword: $("#confirmPassword").val()
        }),
        success: function (response) {
            console.log(response);
            if (response.success) {
                Swal.fire({
                    icon: "success",
                    title: "Success",
                    text: response.message,
                    confirmButtonText: "OK"
                });
                closeChangePassword();
                return;
            } else {
                showNotification(response.message || "Password update failed", "error");
            }
        },
        error: function (xhr) {
            console.log(xhr);
            showNotification(xhr.responseText || "Failed to update password", "error");
        },
        complete: function () {
            // Ensure spinner and kendo progress are hidden regardless of outcome
            restoreChangePasswordBtn();
            kendo.ui.progress($("#changePasswordWindow .k-window-content"), false);
        }
    });
});

    /* ================= LOAD PROFILE ================= */
 function loadProfile() {

    // Instant placeholders
    $('#displayName').text("Loading...");
    $('#profileImage').attr("src", imageBase + "default.jpg");

    // Load cached data first
    const cached = sessionStorage.getItem("profileCache");
    if (cached) {
        populateForm(JSON.parse(cached));
    }

    // Show loader only on image
    kendo.ui.progress($(".profile-image-wrapper"), true);

    $.get(apiBase + "/api/ProfileApi?id=" + USER_ID)
        .done(function (data) {
            originalData = { ...data };
            populateForm(data);
            sessionStorage.setItem("profileCache", JSON.stringify(data));
        })
        .fail(function () {
            showNotification("Failed to load profile", "error");
        })
        .always(function () {
            kendo.ui.progress($(".profile-image-wrapper"), false);
        });
}


    function logout() {
        Swal.fire({
            title: "Logout?",
            text: "Are you sure you want to logout?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Logout",
            cancelButtonText: "Cancel"
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Profile/Logout";
            }
        });
    }

    function openDeleteAccountWindow() {
        const customerId = parseInt($("#customerId").val());

        if (!customerId) {
            showNotification("Invalid session", "error");
            return;
        }

        Swal.fire({
            title: "Delete Account?",
            text: "This action will deactivate your account permanently!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Yes, Delete",
            cancelButtonText: "Cancel"
        }).then((result) => {
            if (result.isConfirmed) {
                kendo.ui.progress($(".profile-container"), true);
                var formData = new FormData();
                formData.append('customerId', customerId);

                $.ajax({
                    url: apiBase + "/api/ProfileApi/delete-account",
                    type: "POST",
                    contentType: false,
                    processData: false,
                    data: formData,
                    success: function (response) {
                        kendo.ui.progress($(".profile-container"), false);
                        Swal.fire("Deleted!", response.message, "success")
                            .then(() => {
                                window.location.href = "/Profile/Logout";
                            });
                    },
                    error: function (xhr) {
                        kendo.ui.progress($(".profile-container"), false);
                        showNotification(
                            xhr.responseJSON?.message || "Delete failed",
                            "error"
                        );
                    }
                });
            }
        });
    }

    /* ================= POPULATE FORM ================= */
    /* ================= POPULATE FORM ================= */
function populateForm(data) {
    console.log("Populating form with data:", data); // Debug log
    
    $('#customerId').val(data.c_customerid || '');
    $('#firstName').val(data.c_fname || '');
    $('#lastName').val(data.c_lname || '');
    $('#email').val(data.c_email || '');
    $('#address').val(data.c_address || '');
    $('#phoneNumber').val(data.c_phonenumber || '');
    $('#city').val(data.c_city || '');
    $('#pincode').val(data.c_pincode || '');
    $('#state').val(data.c_state || '');

    $('input[name="c_gender"]').prop('checked', false);
    if (data.c_gender) {
        $('input[name="c_gender"][value="' + data.c_gender + '"]').prop('checked', true);
    }

    $('#displayName').text((data.c_fname || '') + " " + (data.c_lname || ''));

    // Handle image loading
    const imageName = data.c_image && data.c_image.trim() !== ""
        ? data.c_image
        : "default.jpg";
    
    // Add timestamp to prevent caching
    const timestamp = new Date().getTime();
    const imageUrl = imageBase + imageName + "?v=" + timestamp;
    
    console.log("Setting image src to:", imageUrl); // Debug log
    $('#profileImage').attr("src", imageUrl);
}

    /* ================= IMAGE PREVIEW ================= */
    $('#imageInput').on('change', function (e) {
        const file = e.target.files[0];
        if (!file) return;

        if (!file.type.startsWith("image/")) {
            showNotification("Only image files are allowed", "error");
            this.value = "";
            return;
        }

        // Check file size (limit to 5MB)
        if (file.size > 5 * 1024 * 1024) {
            showNotification("Image size should be less than 5MB", "error");
            this.value = "";
            return;
        }

        const reader = new FileReader();
        reader.onload = e => {
            $('#profileImage').attr('src', e.target.result);
            // Store the file for upload
            $(this).data('selectedFile', file);
        };
        reader.readAsDataURL(file);
    });

    /* ================= PROFILE FORM SUBMIT ================= */
/* ================= PROFILE FORM SUBMIT ================= */
$('#profileForm').submit(function (e) {
    e.preventDefault();

    const validator = $("#profileForm").data("kendoValidator");
    if (!validator || !validator.validate()) {
        return;
    }

    const formData = new FormData();
    const imageFile = $('#imageInput')[0].files[0];

    // Add all form data
    formData.append('c_customerid', $('#customerId').val());
    formData.append('c_fname', $('#firstName').val());
    formData.append('c_lname', $('#lastName').val());
    formData.append('c_email', $('#email').val());
    formData.append('c_address', $('#address').val());
    formData.append('c_phonenumber', $('#phoneNumber').val());
    formData.append('c_city', $('#city').val());
    formData.append('c_pincode', $('#pincode').val());
    formData.append('c_state', $('#state').val());
    formData.append('c_gender', $('input[name="c_gender"]:checked').val());

    // Append image if exists
    if (imageFile) {
        formData.append('c_imagefile', imageFile);
    }

    // Show loading indicator
    kendo.ui.progress($(".profile-container"), true);

    $.ajax({
        url: apiBase + "/api/ProfileApi",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function (response) {
            kendo.ui.progress($(".profile-container"), false);
            
            // Check if response is valid
            if (response && typeof response === 'object') {
                if (response.success === true) {
                   Swal.fire({
    icon: "success",
    title: "Success",
    text: response.message || "Profile updated successfully",
    confirmButtonText: "OK"
});

                    
                    // Update originalData
                    originalData = {
                        c_customerid: $('#customerId').val(),
                        c_fname: $('#firstName').val(),
                        c_lname: $('#lastName').val(),
                        c_email: $('#email').val(),
                        c_address: $('#address').val(),
                        c_phonenumber: $('#phoneNumber').val(),
                        c_city: $('#city').val(),
                        c_pincode: $('#pincode').val(),
                        c_state: $('#state').val(),
                        c_gender: $('input[name="c_gender"]:checked').val(),
                        c_image: response.c_image || originalData.c_image
                    };
                    
                    // Refresh profile image with timestamp to prevent caching
                    if (response.c_image) {
                        const timestamp = new Date().getTime();
                        $('#profileImage').attr('src', imageBase + response.c_image + '?t=' + timestamp);
                    } else if (originalData.c_image) {
                        // If no new image but we have existing image
                        const timestamp = new Date().getTime();
                        $('#profileImage').attr('src', imageBase + originalData.c_image + '?t=' + timestamp);
                    }
                    
                    // Update display name
                    $('#displayName').text($('#firstName').val() + " " + $('#lastName').val());
                    
                    // Clear file input
                    $('#imageInput').val('');
                } else {
                    showNotification(response.message || "Update failed", "error");
                }
            } else {
                showNotification("Invalid response from server", "error");
            }
        },
        error: function (xhr, status, error) {
            kendo.ui.progress($(".profile-container"), false);
            let errorMessage = "Update Failed: ";
            
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMessage += xhr.responseJSON.message;
            } else if (xhr.responseText) {
                errorMessage += xhr.responseText;
            } else {
                errorMessage += error;
            }
            
            showNotification(errorMessage, "error");
        }
    });
});
    /* ================= DISCARD CHANGES ================= */
    function discardChanges() {
        populateForm(originalData);
        $('#imageInput').val('');
    }

    $(document).on("click", ".password-toggle", function () {
    const targetId = $(this).data("target");
    const input = $("#" + targetId);
    const icon = $(this).find("i");

    if (input.attr("type") === "password") {
        input.attr("type", "text");
        icon.removeClass("fa-eye-slash").addClass("fa-eye");
    } else {
        input.attr("type", "password");
        icon.removeClass("fa-eye").addClass("fa-eye-slash");
    }
});

</script>


