@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;

}

<!-- Kendo UI CSS -->
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.common.min.css">
<link rel="stylesheet" href="https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.default.min.css">

<!-- Font Awesome for Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

<!-- Kendo UI JS -->
<script src="https://kendo.cdn.telerik.com/2024.1.130/js/kendo.all.min.js"></script>

<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fef0e6;
            position: relative;
            overflow-x: hidden;
        }

        .forgot-page {
            display: flex;
            min-height: 100vh;
            width: 100%;
            padding: 80px;
            border-radius: 50px;
            overflow: hidden;
            position: relative;
            z-index: 1;
        }
        
        /* Fix zoom scaling - ensure container and content scale together */
        .forgot-page * {
            box-sizing: border-box;
        }

        /* Left Side - Graphics */
        .left-side {
            flex: 1;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            position: relative;
            overflow: hidden;
            border-radius: 32px 0 0 32px;
        }

        .left-side::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            top: -250px;
            right: -250px;
            border-radius: 50%;
            animation: float 20s ease-in-out infinite;
        }

        .left-side::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
            bottom: -200px;
            left: -200px;
            border-radius: 50%;
            animation: float 15s ease-in-out infinite reverse;
        }

        @@keyframes float {
            0%, 100% {
                transform: translate(0, 0) scale(1);
            }
            50% {
                transform: translate(30px, -30px) scale(1.1);
            }
        }

        .graphic-content {
            max-width: 500px;
            text-align: center;
            z-index: 1;
            position: relative;
        }

        .graphic-illustration {
            width: 100%;
            max-width: 400px;
            margin-bottom: 30px;
            animation: illustrationFloat 3s ease-in-out infinite;
        }

        @@keyframes illustrationFloat {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-20px);
            }
        }

        .graphic-content h1 {
            color: white;
            font-size: 42px;
            margin-bottom: 20px;
            font-weight: 700;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }

        .graphic-content p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 18px;
            line-height: 1.6;
            text-shadow: 0 1px 5px rgba(0, 0, 0, 0.1);
        }

        /* Right Side - Form */
        .right-side {
            flex: 1;
            background: #ffffff;
            padding: 60px 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0 32px 32px 0;
        }

        /* remove container restriction */
        .fs-container {
            width: 80%;
            max-width: none;
            position: relative;
        }
        
        /* Ensure all content scales proportionally with zoom */
        .fs-container * {
            box-sizing: border-box;
        }

        /* kill card look */
        .card {
            background: transparent;
            border-radius: 0;
            padding: 0;
            box-shadow: none;
            animation: none;
            position: relative;
            width: 100%;
        }
        
        /* Ensure card content scales properly with zoom */
        .card * {
            box-sizing: border-box;
        }
        
        /* Fix zoom scaling - ensure everything scales together */
        .forgot-page,
        .fs-container,
        .card {
            will-change: auto;
        }
        
        /* Prevent container from growing independently on zoom */
        .forgot-page {
            max-width: 100vw;
        }
        
        .fs-container {
            max-width: 100%;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .step {
            display: none;
            animation: fadeIn 0.5s ease-out;
        }

        .step.active {
            display: block;
        }

        .back-button {
            display: flex;
            align-items: center;
            color: #999;
            font-size: 14px;
            cursor: pointer;
            margin-bottom: 20px;
            transition: all 0.3s ease;
            padding: 8px 0;
        }

        .back-button:hover {
            color: #E9622A;
            transform: translateX(-3px);
        }

        .back-button svg {
            margin-right: 8px;
        }

        .icon-container {
            width: 140px;
        height: 140px;
        margin: 0 auto 35px;
        position: relative;
        animation: iconFloat 3s ease-in-out infinite;
        }

         @@keyframes iconFloat {

        0%,
        100% {
            transform: translateY(0) scale(1);
        }

        50% {
            transform: translateY(-10px) scale(1.02);
        }
    }

        .icon-bg {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(233, 98, 42, 0.15) 0%, rgba(255, 140, 0, 0.15) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        animation: bgPulse 2s ease-in-out infinite;
    }

    @@keyframes bgPulse {

        0%,
        100% {
            box-shadow: 0 0 0 0 rgba(233, 98, 42, 0.4);
        }

        50% {
            box-shadow: 0 0 0 15px rgba(233, 98, 42, 0);
        }
    }

     .icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 30;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

        .icon-svg {
        width: 80px;
        height: 80px;
        color: #E9622A;
        animation: iconPulse 2s ease-in-out infinite;
        filter: drop-shadow(0 4px 12px rgba(233, 98, 42, 0.3));
        transition: all 0.3s ease;
    }

    @@keyframes iconPulse {

        0%,
        100% {
            transform: scale(1);
            filter: drop-shadow(0 4px 12px rgba(233, 98, 42, 0.3));
        }

        50% {
            transform: scale(1.05);
            filter: drop-shadow(0 6px 16px rgba(233, 98, 42, 0.5));
        }
    }

    .icon-svg:hover {
        transform: scale(1.1);
        filter: drop-shadow(0 8px 20px rgba(233, 98, 42, 0.6));
    }

    .lock-icon-svg {
        width: 80px;
        height: 80px;
    }

    .mail-icon-svg {
        width: 80px;
        height: 80px;
    }


    .email-icon,
    .password-icon {
        font-size: 60px;
        color: #E9622A;
    }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 12px;
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(135deg, #E9622A 0%, #ff8c00 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 32px;
            font-size: 15px;
        }

        .form-group {
            margin-bottom: 28px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #333;
            font-size: 14px;
            font-weight: 600;
        }

        .k-textbox {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.3s ease;
            background: #fafafa;
        }

        .k-textbox:focus {
            border-color: #E9622A;
            box-shadow: 0 0 0 4px rgba(233, 98, 42, 0.1);
            background: white;
            outline: none;
        }

        .password-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .password-input-wrapper .k-textbox {
            padding-right: 42px;
        }

        .password-toggle {
            position: absolute;
            right: 14px;
            cursor: pointer;
            color: #999;
            transition: color 0.2s ease;
        }

        .password-toggle:hover {
            color: #E9622A;
        }

        .password-hint {
            font-size: 12px;
            color: #666;
            margin-top: 6px;
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .otp-container {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .otp-input {
            width: 55px;
            height: 60px;
            text-align: center;
            font-size: 26px;
            font-weight: bold;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            transition: all 0.3s ease;
            background: #fafafa;
        }

        .otp-input:focus {
            border-color: #E9622A;
            box-shadow: 0 0 0 4px rgba(233, 98, 42, 0.15);
            outline: none;
            background: white;
        }

        .resend-link {
            text-align: center;
            margin-bottom: 20px;
        }

        .resend-link a {
            color: #E9622A;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .resend-link a:hover {
            color: #ff8c00;
        }

        .resend-link a.disabled {
            color: #999;
            cursor: not-allowed;
            pointer-events: none;
        }

        #resendTimer {
            font-size: 13px;
            color: #666;
            margin-top: 8px;
        }

        #timerSec {
            font-weight: 600;
            color: #E9622A;
        }

        .k-button {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #E9622A 0%, #ff8c00 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 6px 20px rgba(233, 98, 42, 0.35);
        }

        .k-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(233, 98, 42, 0.45);
        }

        .k-button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .error-message {
            color: #dc3545;
            font-size: 13px;
            margin-top: 10px;
            display: none;
            padding: 10px 12px;
            background: rgba(220, 53, 69, 0.08);
            border-left: 3px solid #dc3545;
            border-radius: 6px;
        }

        .error-message.show {
            display: block;
            animation: errorShake 0.5s ease-out;
        }

        @@keyframes errorShake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
            20%, 40%, 60%, 80% { transform: translateX(5px); }
        }

        .success-message {
            background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
            color: #22B55B;
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-size: 14px;
            border: 2px solid #c3e6cb;
            display: none;
            box-shadow: 0 4px 12px rgba(34, 181, 91, 0.15);
        }

        .success-message.show {
            display: block;
        }

        .loader {
            border: 3px solid rgba(233, 98, 42, 0.2);
            border-top: 3px solid #E9622A;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            animation: spin 0.8s linear infinite;
            display: inline-block;
            margin-left: 10px;
            vertical-align: middle;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .password-strength {
            height: 5px;
            background: #eee;
            border-radius: 10px;
            margin-top: 10px;
            overflow: hidden;
        }

        .password-strength-bar {
            height: 100%;
            width: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 10px;
            background: transparent;
        }

        .password-strength-bar.strength-weak {
            width: 33% !important;
            background: linear-gradient(90deg, #dc3545, #ff4757) !important;
        }

        .password-strength-bar.strength-medium {
            width: 66% !important;
            background: linear-gradient(90deg, #ffc107, #ffa502) !important;
        }

        .password-strength-bar.strength-strong {
            width: 100% !important;
            background: linear-gradient(90deg, #28a745, #2ecc71) !important;
        }

        /* Notification Overlay */
        .notification-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 9998;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .notification-overlay.show {
            display: flex;
        }

        .success-popup, .error-popup {
            width: 320px;
            background: #fff;
            border-radius: 20px;
            padding: 30px 20px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
            animation: popupSlideIn 0.4s ease-out;
        }

        .error-popup {
            display: none;
        }

        .notification-overlay.show-error .error-popup {
            display: block;
        }

        .notification-overlay.show-error .success-popup {
            display: none;
        }

        .success-popup h2, .error-popup h2 {
            margin: 15px 0 8px;
            color: #333;
            font-size: 24px;
            background: none;
            -webkit-text-fill-color: initial;
        }

        .success-popup p, .error-popup p {
            color: #777;
            font-size: 14px;
            margin-bottom: 25px;
        }

        .success-wrap, .error-wrap {
            position: relative;
            width: 120px;
            height: 120px;
            margin: auto;
            margin-bottom: 20px;
        }

        .circle, .error-circle {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            animation: pop 0.6s ease-out;
        }

        .circle {
            background: #2ecc71;
        }

        .error-circle {
            background: #dc3545;
        }

        .circle svg, .error-circle svg {
            width: 50px;
            height: 50px;
            stroke: #fff;
            stroke-width: 6;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            animation: draw 0.6s ease-out forwards;
        }

        .swirl, .error-swirl {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            animation: rotate 3s linear infinite;
        }

        .swirl span, .error-swirl span {
            position: absolute;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            animation: fire 1.2s ease-in-out infinite;
        }

        .swirl span {
            background: rgba(46, 204, 113, 0.7);
        }

        .error-swirl span {
            background: rgba(220, 53, 69, 0.7);
        }

        .swirl span:nth-child(1), .error-swirl span:nth-child(1) { top: 0; left: 50%; }
        .swirl span:nth-child(2), .error-swirl span:nth-child(2) { top: 20%; right: 10%; }
        .swirl span:nth-child(3), .error-swirl span:nth-child(3) { bottom: 20%; right: 10%; }
        .swirl span:nth-child(4), .error-swirl span:nth-child(4) { bottom: 0; left: 50%; }
        .swirl span:nth-child(5), .error-swirl span:nth-child(5) { bottom: 20%; left: 10%; }
        .swirl span:nth-child(6), .error-swirl span:nth-child(6) { top: 20%; left: 10%; }

        .error-popup .close-error {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: none;
            background: #dc3545;
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .error-popup .close-error:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(220, 53, 69, 0.4);
        }

        @@keyframes pop {
            0% { transform: scale(0.6); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        @@keyframes draw {
            from { stroke-dasharray: 100; stroke-dashoffset: 100; }
            to { stroke-dasharray: 100; stroke-dashoffset: 0; }
        }

        @@keyframes rotate {
            100% { transform: rotate(360deg); }
        }

        @@keyframes fire {
            0%, 100% { transform: scale(0.6); opacity: 0.4; }
            50% { transform: scale(1.2); opacity: 1; }
        }

        @@keyframes popupSlideIn {
            from { opacity: 0; transform: scale(0.85); }
            to { opacity: 1; transform: scale(1); }
        }

        /* Responsive Design */
        @@media (max-width: 1024px) {
            .forgot-page {
                flex-direction: column;
            }

            .left-side {
                min-height: 300px;
                padding: 30px;
            }

            .graphic-content h1 {
                font-size: 32px;
            }

            .graphic-content p {
                font-size: 16px;
            }

            .graphic-illustration {
                max-width: 300px;
            }
        }

        @@media (max-width: 768px) {
            .left-side {
                min-height: 250px;
                padding: 20px;
            }

            .graphic-content h1 {
                font-size: 28px;
                margin-bottom: 15px;
            }

            .graphic-content p {
                font-size: 14px;
            }

            .graphic-illustration {
                max-width: 250px;
                margin-bottom: 20px;
            }

            .card {
                padding: 30px 25px;
            }

            .otp-input {
                width: 45px;
                height: 55px;
                font-size: 22px;
            }
        }
    </style>

<!-- Notification Overlay -->
<div class="notification-overlay" id="notificationOverlay">
    <div class="success-popup" id="successPopup">
        <div class="success-wrap">
            <div class="swirl">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
            </div>
            <div class="circle">
                <svg viewBox="0 0 52 52">
                    <path d="M14 27 L23 36 L38 18" />
                </svg>
            </div>
        </div>
        <h2>Congratulations!</h2>
        <p id="successMessage">Password reset successful! Redirecting to login page...</p>
        <span class="checkmark">✓</span>
        <span class="message" id="successMessageOld"></span>
    </div>

    <div class="error-popup" id="errorPopup">
        <div class="error-wrap">
            <div class="error-swirl">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
            </div>
            <div class="error-circle">
                <svg viewBox="0 0 52 52">
                    <line x1="13" y1="13" x2="39" y2="39" />
                    <line x1="39" y1="13" x2="13" y2="39" />
                </svg>
            </div>
        </div>
        <h2>Error!</h2>
        <p id="errorMessage">Something went wrong. Please try again.</p>
        <button class="close-error" onclick="hideErrorNotification()">Close</button>
    </div>
</div>

<div class="forgot-page">
<!-- Left Side - Graphics -->
        <div class="left-side">
            <div class="graphic-content">
                <svg class="graphic-illustration" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
                    <!-- Background circles -->
                    <circle cx="300" cy="150" r="100" fill="rgba(255, 255, 255, 0.1)"/>
                    <circle cx="150" cy="400" r="100" fill="rgba(255, 255, 255, 0.1)"/>
                    
                    <!-- Main illustration background -->
                    <rect x="100" y="150" width="300" height="250" rx="20" fill="rgba(255, 255, 255, 0.95)"/>
                    
                    <!-- Lock icon at top -->
                    <circle cx="250" cy="100" r="40" fill="#dc3545"/>
                    <rect x="235" y="95" width="30" height="20" rx="5" fill="white"/>
                    <path d="M240 100 Q240 85 250 85 Q260 85 260 100" stroke="white" stroke-width="3" fill="none"/>
                    
                    <!-- Red bars representing blocked content -->
                    <rect x="150" y="180" width="200" height="25" rx="5" fill="#dc3545"/>
                    <rect x="330" y="230" width="90" height="25" rx="5" fill="#dc3545"/>
                    <rect x="75" y="280" width="90" height="25" rx="5" fill="#dc3545"/>
                    
                    <!-- Small lock icons -->
                    <circle cx="130" cy="245" r="15" fill="rgba(233, 98, 42, 0.2)"/>
                    <rect x="125" y="240" width="10" height="8" rx="2" fill="rgba(233, 98, 42, 0.6)"/>
                    
                    <circle cx="360" cy="295" r="15" fill="rgba(233, 98, 42, 0.2)"/>
                    <rect x="355" y="290" width="10" height="8" rx="2" fill="rgba(233, 98, 42, 0.6)"/>
                    
                    <!-- Person illustration -->
                    <circle cx="250" cy="300" r="35" fill="#1a1a2e"/>
                    <ellipse cx="250" cy="365" rx="60" ry="40" fill="#ff9f43"/>
                    
                    <!-- Face details -->
                    <circle cx="240" cy="295" r="4" fill="white"/>
                    <circle cx="260" cy="295" r="4" fill="white"/>
                    <path d="M235 310 Q250 320 265 310" stroke="white" stroke-width="2" fill="none"/>
                    
                    <!-- Laptop -->
                    <rect x="190" y="350" width="120" height="70" rx="5" fill="#e8e8e8"/>
                    <rect x="195" y="355" width="110" height="55" rx="3" fill="#4a90e2"/>
                    <circle cx="250" cy="382" r="8" fill="white" opacity="0.3"/>
                    
                    <!-- Question mark and exclamation -->
                    <text x="360" y="270" font-size="35" fill="#E9622A" font-weight="bold">?</text>
                    <text x="125" y="380" font-size="35" fill="#E9622A" font-weight="bold">!</text>
                </svg>
                
                <h1>Forgot Password?</h1>
                <p>Don't worry! It happens. Please enter the email address associated with your account.</p>
            </div>
        </div>

<!-- right side -->
<div class="right-side">
    <div class="fs-container">
        <div class="card k-card">
            <!-- Step 1: Enter Email -->
            <div id="step1" class="step active">
                <div class="icon-container">
                    <div class="icon-bg"></div>
                    <div class="icon">
                        <svg class="icon-svg lock-icon-svg" viewBox="0 0 24 24" fill="none"
                            xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M19 11H5C3.89543 11 3 11.8954 3 13V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V13C21 11.8954 20.1046 11 19 11Z"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path
                                d="M7 11V7C7 5.67392 7.52678 4.40215 8.46447 3.46447C9.40215 2.52678 10.6739 2 12 2C13.3261 2 14.5979 2.52678 15.5355 3.46447C16.4732 4.40215 17 5.67392 17 7V11"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                </div>

                <h2>Forgot Password</h2>
                <p class="subtitle">Please enter your email address</p>

                <div class="error-message" id="emailError"></div>

                <div class="form-group">
                    <label for="emailInput">Email Address :</label>
                    <input type="email" id="emailInput" class="k-textbox" placeholder="Enter your email"
                        autocomplete="off" spellcheck="false" autocapitalize="none" autocorrect="off">
                        
                </div>

                <button class="k-button" id="sendOtpBtn">
                    Continue
                </button>
                <div class="back-button" style="margin-top:30px;" onclick="window.location.href='/Auth/login'">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Back to Login
                </div>
            </div>

            <!-- Step 2: Verify OTP -->
            <div id="step2" class="step">
                <div class="back-button" onclick="goToStep(1)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Back
                </div>

                <div class="icon-container">
                    <div class="icon-bg"></div>
                    <div class="icon">
                        <svg class="icon-svg mail-icon-svg" viewBox="0 0 24 24" fill="none"
                            xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" />
                        </svg>
                    </div>
                </div>

                <h2>Verify your Email</h2>
                <p class="subtitle">Please enter the 6 digit code</p>

                <div class="success-message" id="otpSentMessage">
                    OTP has been sent to your email address
                </div>

                <div class="error-message" id="otpError"></div>

                <div class="otp-container k-otp">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="0">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="1">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="2">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="3">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="4">
                    <input type="text" maxlength="1" class="otp-input k-otp-input" data-index="5">
                </div>

                <div class="resend-link">
                    <a href="#" id="resendLink">Resend code</a>
                    <div id="resendTimer" style="display:none;">
                        You can resend OTP in <span id="timerSec">05:00</span>
                    </div>
                </div>

                <button class="k-button" id="verifyOtpBtn">
                    Verify
                </button>
            </div>

            <!-- Step 3: Change Password -->
            <div id="step3" class="step">
                <div class="back-button" onclick="goToStep(2)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                    Back
                </div>

                <div class="icon-container">
                    <div class="icon-bg"></div>
                    <div class="icon">
                        <svg class="icon-svg lock-icon-svg" viewBox="0 0 24 24" fill="none"
                            xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M19 11H5C3.89543 11 3 11.8954 3 13V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V13C21 11.8954 20.1046 11 19 11Z"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <path
                                d="M7 11V7C7 5.67392 7.52678 4.40215 8.46447 3.46447C9.40215 2.52678 10.6739 2 12 2C13.3261 2 14.5979 2.52678 15.5355 3.46447C16.4732 4.40215 17 5.67392 17 7V11"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                </div>

                <h2>Change your Password</h2>
                <p class="subtitle">Your new password must be different</p>

                <div class="error-message" id="passwordError"></div>

                <div class="form-group">
                    <label for="newPassword">New Password :</label>
                    <div class="password-input-wrapper">
                        <input type="password" id="newPassword" class="k-textbox" placeholder="Enter new password"
                            autocomplete="new-password">
                        <span class="password-toggle" data-target="newPassword">
                            <i class="fa-solid fa-eye-slash"></i>
                        </span>
                    </div>
                    <div class="password-hint">
                        Password must be at least 8 characters long, 1 capital letter, 1 special character
                    </div>
                    <div class="password-strength">
                        <div class="password-strength-bar" id="strengthBar"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm Password :</label>
                    <div class="password-input-wrapper">
                        <input type="password" id="confirmPassword" class="k-textbox"
                            placeholder="Confirm your password" autocomplete="new-password">
                        <span class="password-toggle" data-target="confirmPassword">
                            <i class="fa-solid fa-eye-slash"></i>
                        </span>
                    </div>
                </div>

                <button class="k-button" id="savePasswordBtn">
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
</div>

    <script>
        $(document).ready(function () {
            // Simple notification show/hide functions
            function showSuccessNotification(message) {
                $('#successMessage').text(message);
                $('#notificationOverlay').removeClass('show-error').addClass('show');
            }

            function hideSuccessNotification() {
                $('#notificationOverlay').removeClass('show');
            }

            window.showErrorNotification = function (message) {
                $('#errorMessage').text(message);
                $('#notificationOverlay').removeClass('show').addClass('show-error').addClass('show');
            }

            window.hideErrorNotification = function () {
                $('#notificationOverlay').removeClass('show show-error');
            }

            // Initialize Kendo UI components
            // Keep text inputs as plain HTML so there is only one visible textbox (no Kendo wrapper)
            $("#sendOtpBtn, #verifyOtpBtn, #savePasswordBtn").kendoButton();

            let currentEmail = '';
            let currentOtp = '';
            let resendCooldown = 300;
            let resendInterval = null;

            // API Base URL - Update this to your actual API URL
            const API_BASE_URL = 'http://localhost:5245/api/forgot-password';

            // Resend Timer Function
            function formatTime(seconds) {
                const mins = Math.floor(seconds / 60);
                const secs = seconds % 60;
                return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
            }

            function startResendTimer() {
                let timeLeft = resendCooldown;
                $('#resendLink').hide().addClass('disabled');
                $('#resendTimer').show();
                $('#timerSec').text(formatTime(timeLeft));

                if (resendInterval) {
                    clearInterval(resendInterval);
                }

                resendInterval = setInterval(() => {
                    timeLeft--;
                    $('#timerSec').text(formatTime(timeLeft));

                    if (timeLeft <= 0) {
                        clearInterval(resendInterval);
                        resendInterval = null;
                        $('#resendTimer').hide();
                        $('#resendLink').show().removeClass('disabled');
                    }
                }, 1000);
            }


            // Step navigation
            window.goToStep = function (stepNumber) {
                $('.step').removeClass('active');
                $('#step' + stepNumber).addClass('active');

                // Clean up resend timer if going back to step 1
                if (stepNumber === 1 && resendInterval) {
                    clearInterval(resendInterval);
                    resendInterval = null;
                    $('#resendTimer').hide();
                    $('#resendLink').show().removeClass('disabled');
                }

                // Clear fields when going back
                if (stepNumber === 1) {
                    // Clear email and errors
                    $('#emailInput').val('');
                    $('#emailError').removeClass('show').text('');
                } else if (stepNumber === 2) {
                    // Clear OTP fields and errors
                    $('.otp-input').val('');
                    $('#otpError').removeClass('show').text('');
                    currentOtp = '';
                } else if (stepNumber === 3) {
                    // Clear password fields and errors
                    $('#newPassword').val('');
                    $('#confirmPassword').val('');
                    $('#passwordError').removeClass('show').text('');
                    $('#strengthBar').removeClass('strength-weak strength-medium strength-strong').css('width', '0');
                }
            };

            // Send OTP
            $('#sendOtpBtn').click(function () {
                const email = $('#emailInput').val().trim();
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

                $('#emailError').removeClass('show').text('');

                if (!email) {
                    showError('emailError', 'Please enter your email address');
                    return;
                }

                if (!emailRegex.test(email)) {
                    showError('emailError', 'Please enter a valid email address');
                    return;
                }

                currentEmail = email;
                const btn = $(this);
                btn.prop('disabled', true).html('Sending... <span class="loader"></span>');

                $.ajax({
                    url: API_BASE_URL + '/request-otp',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: email }),
                    success: function (response) {
                        btn.prop('disabled', false).text('Continue');
                        $('#otpSentMessage').addClass('show');
                        goToStep(2);
                        startResendTimer(); // Start cooldown timer
                        setTimeout(() => $('#otpSentMessage').removeClass('show'), 5000);
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).text('Send');
                        const errorMsg = xhr.responseJSON?.message || xhr.responseText || 'Email is not registered';
                        showError('emailError', errorMsg);
                    }
                });
            });

            // OTP Input handling
            $('.otp-input').on('input', function () {
                const $this = $(this);
                const value = $this.val();

                // Only allow numbers
                if (!/^\d*$/.test(value)) {
                    $this.val('');
                    return;
                }

                // Move to next input
                if (value && $this.next('.otp-input').length) {
                    $this.next('.otp-input').focus();
                }
            });

            $('.otp-input').on('keydown', function (e) {
                const $this = $(this);

                // Handle backspace
                if (e.key === 'Backspace' && !$this.val()) {
                    $this.prev('.otp-input').focus();
                }
            });

            // Paste handling for OTP
            $('.otp-input').first().on('paste', function (e) {
                e.preventDefault();
                const pastedData = e.originalEvent.clipboardData.getData('text');
                const digits = pastedData.replace(/\D/g, '').split('');

                $('.otp-input').each(function (index) {
                    if (digits[index]) {
                        $(this).val(digits[index]);
                    }
                });
            });

            // Resend OTP with cooldown protection
            $('#resendLink').off('click').on('click', function (e) {
                e.preventDefault();

                // Check if timer is active
                if (resendInterval) {
                    return;
                }

                if (!currentEmail) {
                    showError('otpError', 'Email missing. Please restart process.');
                    return;
                }

                const link = $(this);
                link.hide();
                $('#resendTimer').show();
                $('#timerSec').text(resendCooldown);

                $.ajax({
                    url: API_BASE_URL + '/request-otp',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: currentEmail }),
                    success: function (response) {
                        $('#otpSentMessage').text('OTP resent successfully').addClass('show');
                        startResendTimer();
                        // Clear OTP input fields
                        $('.otp-input').val('');
                        $('.otp-input').first().focus();
                        setTimeout(() => $('#otpSentMessage').removeClass('show'), 5000);
                    },
                    error: function (xhr) {
                        if (resendInterval) {
                            clearInterval(resendInterval);
                            resendInterval = null;
                        }
                        $('#resendTimer').hide();
                        $('#resendLink').show().removeClass('disabled');

                        const errorMsg = xhr.responseJSON?.message || xhr.responseText || 'Failed to resend OTP. Please try again.';

                        // Handle 429 Too Many Requests
                        if (xhr.status === 429) {
                            showError('otpError', 'Please wait before requesting a new OTP');
                            startResendTimer(); // Start timer even on error if backend enforces cooldown
                        } else {
                            showError('otpError', errorMsg);
                        }
                    }
                });
            });

            // Password show/hide toggles
            $('.password-toggle').on('click', function () {
                const targetId = $(this).data('target');
                const input = $('#' + targetId);
                const icon = $(this).find('i');

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                }
            });

            // Verify OTP (Step 2) - API call to verify OTP
            $('#verifyOtpBtn').click(function () {
                const otp = $('.otp-input').map(function () {
                    return $(this).val();
                }).get().join('');

                $('#otpError').removeClass('show').text('');

                if (!otp || otp.length !== 6) {
                    showError('otpError', 'Please enter the complete 6-digit code');
                    return;
                }

                // Validate OTP format (must be 6 digits)
                if (!/^\d{6}$/.test(otp)) {
                    showError('otpError', 'OTP must contain only numbers');
                    return;
                }

                if (!currentEmail) {
                    showError('otpError', 'Email missing. Please restart the process.');
                    return;
                }

                const btn = $(this);
                btn.prop('disabled', true).html('Verifying... <span class="loader"></span>');

                // Verify OTP using the OTP controller endpoint
                const formData = new FormData();
                formData.append('Email', currentEmail);
                formData.append('Otp', otp);

                $.ajax({
                    url: 'http://localhost:5245/api/otp/verify',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        // Handle both success (200) and error (400) responses
                        if (response && response.success === true) {
                            // OTP is valid - store it and proceed to step 3
                            currentOtp = otp;
                            btn.prop('disabled', false).text('Verify');
                            goToStep(3);
                        } else {
                            // OTP is invalid
                            btn.prop('disabled', false).text('Verify');
                            const errorMsg = (response && response.message) ? response.message : 'Invalid OTP. Please try again.';
                            showError('otpError', errorMsg);
                        }
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).text('Verify');
                        // Try to parse the response
                        let errorMsg = 'Failed to verify OTP. Please try again.';
                        
                        if (xhr.responseJSON) {
                            if (xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            } else if (xhr.responseJSON.Message) {
                                errorMsg = xhr.responseJSON.Message;
                            } else if (typeof xhr.responseJSON === 'string') {
                                errorMsg = xhr.responseJSON;
                            }
                        } else if (xhr.responseText) {
                            try {
                                const parsed = JSON.parse(xhr.responseText);
                                errorMsg = parsed.message || parsed.Message || errorMsg;
                            } catch (e) {
                                errorMsg = xhr.responseText;
                            }
                        }
                        
                        showError('otpError', errorMsg);
                    }
                });
            });


            // Password strength checker - use event delegation to work even when step 3 is dynamically shown
            $(document).on('input keyup paste', '#newPassword', function () {
                const password = $(this).val();
                const strengthBar = $('#strengthBar');

                if (!strengthBar.length) {
                    // If strength bar doesn't exist yet, try again after a short delay
                    setTimeout(() => {
                        const bar = $('#strengthBar');
                        if (bar.length) {
                            updatePasswordStrength(password, bar);
                        }
                    }, 100);
                    return;
                }

                updatePasswordStrength(password, strengthBar);
            });

            // Helper function to update password strength
            function updatePasswordStrength(password, strengthBar) {
                let strength = 0;
                
                // Check length
                if (password.length >= 8) strength++;
                
                // Check for lowercase and uppercase
                if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
                
                // Check for digit
                if (/\d/.test(password)) strength++;
                
                // Check for special character
                if (/[^a-zA-Z\d]/.test(password)) strength++;

                // Remove all strength classes first
                strengthBar.removeClass('strength-weak strength-medium strength-strong');

                if (password.length === 0) {
                    // Reset to empty state
                    strengthBar.css('width', '0').css('background', 'transparent');
                } else if (strength <= 1) {
                    // Weak password
                    strengthBar.addClass('strength-weak');
                } else if (strength <= 3) {
                    // Medium password
                    strengthBar.addClass('strength-medium');
                } else {
                    // Strong password
                    strengthBar.addClass('strength-strong');
                }
            }

            // Save Password
            $('#savePasswordBtn').click(function () {
                const newPassword = $('#newPassword').val().trim();
                const confirmPassword = $('#confirmPassword').val().trim();

                $('#passwordError').removeClass('show').text('');

                if (!newPassword) {
                    showError('passwordError', 'Please enter a new password');
                    return;
                }

                if (newPassword.length < 8) {
                    showError('passwordError', 'Password must be at least 8 characters');
                    return;
                }

                if (!confirmPassword) {
                    showError('passwordError', 'Please confirm your password');
                    return;
                }

                if (newPassword !== confirmPassword) {
                    showError('passwordError', 'Passwords do not match');
                    return;
                }

                if (!currentEmail) {
                    showError('passwordError', 'Email missing. Please restart the process.');
                    return;
                }

                const btn = $(this);
                btn.prop('disabled', true).html('Saving... <span class="loader"></span>');

                // Update password only - OTP was already verified in step 2
                $.ajax({
                    url: API_BASE_URL + '/update-password',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        Email: currentEmail,
                        NewPassword: newPassword,
                        ConfirmPassword: confirmPassword
                    }),
                    success: function (response) {
                        btn.prop('disabled', false).text('Save');

                        // Show success notification
                        showSuccessNotification("Password reset successful! Redirecting to login page...");

                        // Redirect to login page after 3 seconds
                        setTimeout(function () {
                            window.location.href = '/Auth/login'; // Update this to your login page URL
                        }, 3000);
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).text('Save');
                        
                        // Log full error for debugging
                        console.log('Password update error:', xhr);
                        console.log('Status:', xhr.status);
                        console.log('Response:', xhr.responseJSON || xhr.responseText);
                        
                        // Parse error message properly
                        let errorMsg = 'Failed to reset password. Please try again.';
                        
                        if (xhr.responseJSON) {
                            // Check for different response formats
                            if (xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            } else if (xhr.responseJSON.Message) {
                                errorMsg = xhr.responseJSON.Message;
                            } else if (typeof xhr.responseJSON === 'string') {
                                errorMsg = xhr.responseJSON;
                            } else if (xhr.responseJSON.title) {
                                errorMsg = xhr.responseJSON.title;
                            } else if (xhr.responseJSON.errors) {
                                // Handle ModelState validation errors
                                const errors = xhr.responseJSON.errors;
                                const errorMessages = [];
                                for (let key in errors) {
                                    if (errors[key] && errors[key].length > 0) {
                                        errorMessages.push(errors[key][0]);
                                    }
                                }
                                if (errorMessages.length > 0) {
                                    errorMsg = errorMessages.join(', ');
                                }
                            }
                        } else if (xhr.responseText) {
                            try {
                                const parsed = JSON.parse(xhr.responseText);
                                if (parsed.message) {
                                    errorMsg = parsed.message;
                                } else if (parsed.Message) {
                                    errorMsg = parsed.Message;
                                } else if (parsed.title) {
                                    errorMsg = parsed.title;
                                } else if (parsed.errors) {
                                    // Handle ModelState validation errors
                                    const errors = parsed.errors;
                                    const errorMessages = [];
                                    for (let key in errors) {
                                        if (errors[key] && errors[key].length > 0) {
                                            errorMessages.push(errors[key][0]);
                                        }
                                    }
                                    if (errorMessages.length > 0) {
                                        errorMsg = errorMessages.join(', ');
                                    }
                                }
                            } catch (e) {
                                // If not JSON, use the text directly
                                errorMsg = xhr.responseText;
                            }
                        }

                        // Show error notification popup
                        showErrorNotification(errorMsg);

                        // If OTP is invalid, expired, or not found, go back to step 2 after showing error
                        const errorLower = errorMsg.toLowerCase();
                        if (errorLower.includes('otp') || errorLower.includes('expired') || errorLower.includes('not found')) {
                            setTimeout(() => {
                                hideErrorNotification();
                                goToStep(2);
                                // Clear OTP fields and show message
                                $('.otp-input').val('');
                                currentOtp = '';
                                showError('otpError', 'OTP was already used. Please request a new OTP.');
                            }, 3000);
                        } else {
                            showError('passwordError', errorMsg);
                        }
                    }
                });
            });

            // Helper function to show errors
            function showError(elementId, message) {
                $('#' + elementId).text(message).addClass('show');
                setTimeout(() => {
                    $('#' + elementId).removeClass('show');
                }, 5000);
            }

            // Enter key handling
            $('#emailInput').keypress(function (e) {
                if (e.which === 13) {
                    $('#sendOtpBtn').click();
                }
            });

            $('.otp-input').last().keypress(function (e) {
                if (e.which === 13) {
                    $('#verifyOtpBtn').click();
                }
            });

            $('#confirmPassword').keypress(function (e) {
                if (e.which === 13) {
                    $('#savePasswordBtn').click();
                }
            });
        });
    </script>
</div>
</div>