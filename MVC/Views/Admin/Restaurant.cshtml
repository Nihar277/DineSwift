</style>


<!-- RESTAURANT STATS -->
<div class="stats-row">

    <div class="stat-card total">
        <div class="stat-header">
            <i class="fa-solid fa-store stat-icon"></i>
            <div class="stat-title">Total Restaurants</div>
        </div>
        <div class="stat-value" id="totalRestaurant">0</div>
    </div>

    <div class="stat-card success">
        <div class="stat-header">
            <i class="fa-solid fa-circle-check stat-icon"></i>
            <div class="stat-title">Active</div>
        </div>
        <div class="stat-value" id="activeRestaurant">0</div>
    </div>

    <div class="stat-card warning">
        <div class="stat-header">
            <i class="fa-solid fa-circle-xmark stat-icon"></i>
            <div class="stat-title">Inactive</div>
        </div>
        <div class="stat-value" id="inactiveRestaurant">0</div>
    </div>

    <div class="stat-card info">
        <div class="stat-header">
            <i class="fa-solid fa-door-open stat-icon"></i>
            <div class="stat-title">Open</div>
        </div>
        <div class="stat-value" id="openRestaurant">0</div>
    </div>

    <div class="stat-card muted">
        <div class="stat-header">
            <i class="fa-solid fa-door-closed stat-icon"></i>
            <div class="stat-title">Closed</div>
        </div>
        <div class="stat-value" id="closedRestaurant">0</div>
    </div>

    <div class="stat-card new">
        <div class="stat-header">
            <i class="fa-solid fa-calendar-day stat-icon"></i>
            <div class="stat-title">Today Registered</div>
        </div>
        <div class="stat-value" id="todayRestaurant">0</div>
    </div>

</div>


<div class="card">
    <div class="menu-list-header">
        <div>
            <strong>Restaurant Network</strong>
            <div class="header-subtitle">Manage partner status and business profiles</div>
        </div>
        <div class="search-wrapper">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input type="text" id="search-box" class="menu-search-input" placeholder="Search by name, city..." />
            <button type="button" id="search-clear-btn"
                style="display:none; border:none; background:none; cursor:pointer; color: #94a3b8;">
                <i class="fa-solid fa-circle-xmark"></i>
            </button>
        </div>
    </div>

    <div id="grid-menu-items"></div>
</div>

<div id="addressModel">
    <form id="addressFrm" class="p-4"></form>
</div>
<div id="accountModel">
    <form id="accountFrm" class="p-4"></form>
</div>
<div id="ownerModel">
    <form id="ownerFrm" class="p-4"></form>
</div>

<script>
    $(document).ready(function () {
        loadGrid();
        loadWindow();
        loadFrm();

        // Search Implementation
        $("#search-box").on("keyup", function () {
            var val = $(this).val();
            var grid = $("#grid-menu-items").data("kendoGrid");
            if (!grid) return;

            if (val) {
                grid.dataSource.filter({
                    logic: "or",
                    filters: [
                        { field: "c_r_name", operator: "contains", value: val },
                        { field: "c_r_email", operator: "contains", value: val },
                        { field: "c_city", operator: "contains", value: val }
                    ]
                });
                $("#search-clear-btn").show();
            } else {
                grid.dataSource.filter({});
                $("#search-clear-btn").hide();
            }
        });

        $("#search-clear-btn").click(function () {
            $("#search-box").val("").focus();
            $(this).hide();
            $("#grid-menu-items").data("kendoGrid").dataSource.filter({});
        });
    });

    function loadGrid() {
        var token = "@Context.Session.GetString("Token")";
        $.ajax({
            url: "http://localhost:5245/api/Admin/getAllRestaurant",
            type: "GET",
            headers: { "Authorization": "Bearer " + token },
            success: function (data) {
                console.log(data);
                // ---------- RESTAURANT CARD CALCULATIONS ----------
                var total = data.length;

                var active = data.filter(x => x.c_r_status === "active").length;
                var inactive = data.filter(x => x.c_r_status !== "active").length;

                var open = data.filter(x => x.c_r_isavailable === "yes").length;
                var closed = data.filter(x => x.c_r_isavailable !== "yes").length;

                // Today registered
                var today = new Date().toISOString().split("T")[0];
                var todayRegistered = data.filter(x =>
                    x.c_created_time && x.c_created_time.startsWith(today)
                ).length;

                // ---------- UPDATE UI ----------
                $("#totalRestaurant").text(total);
                $("#activeRestaurant").text(active);
                $("#inactiveRestaurant").text(inactive);
                $("#openRestaurant").text(open);
                $("#closedRestaurant").text(closed);
                $("#todayRestaurant").text(todayRegistered);



                $("#grid-menu-items").kendoGrid({
                    dataSource: { data: data, schema: { model: { id: "c_r_id" } }, pageSize: 5 },
                    sortable: true,
                    filterable: true,
                    groupable: true,
                    pageable: { refresh: true, pageSizes: [5, 10, 25], buttonCount: 3 },
                    columns: [
                        {
                            field: "c_r_name", title: "Restaurant Details", width: 280,
                            template: function (d) {
                                return `<div class="res-identity">
                                    <img src="/Images/restaurant/restaurantimages/${d.c_r_image}" class="restaurant-img" onerror="this.src='https://ui-avatars.com/api/?background=fff7ed&color=f97316&name=${d.c_r_name}'">
                                    <div>
                                        <div style="font-weight:700; color:var(--text-heading); font-size:14px;">${d.c_r_name}</div>
                                        <div style="font-size:12px; color:var(--text-body);">${d.c_r_email}</div>
                                    </div>
                                </div>`;
                            }
                        },
                        {
                            field: "c_city", title: "Location", width: 150,
                            template: (d) => `<div style="font-weight:600; color:var(--text-heading);">${d.c_city}</div><div style="font-size:11px; color:var(--text-body);">${d.c_state}</div>`
                        },
                        {
                            field: "c_r_isavailable", title: "Open / Close", width: 120,
                            template: (d) => {
                                const isOpen = d.c_r_isavailable == "yes";
                                return `
                                <div class="delivery-status ${isOpen ? 'available' : 'offline'}">
                                    <span class="status-dot"></span>
                                    <span class="status-text">${isOpen ? 'Open' : 'Close'}</span>
                                </div>`;
                            }
                        },
                        {
                            title: "Business Profiles", width: 160,
                            template: (d) => `
                                <div class="btn-detail-group">
                                    <button class="btn-icon-alt" title="Location" onclick="showAddress(${d.c_r_id})"><i class="fa-solid fa-location-dot"></i></button>
                                    <button class="btn-icon-alt" title="Banking" onclick="showAccount(${d.c_r_id})"><i class="fa-solid fa-building-columns"></i></button>
                                    <button class="btn-icon-alt" title="Legal" onclick="showOwner(${d.c_r_id})"><i class="fa-solid fa-id-card"></i></button>
                                </div>`
                        },
                         {
                            title: "Status", width: 140,
                            template: (d) => {
                                const isOpen = d.c_r_status == "active";
                                return `<span class="status-tag ${isOpen ? 'tag-open' : 'tag-closed'}">${isOpen ? 'Active' : 'Inactive'}</span>`;
                            }
                        },
                        {
                            title: "Actions", width: 140,
                            template: (d) => d.c_r_status == "active"
                                ? `<button class="btn-status-toggle btn-inactive-state" onclick="inactive(${d.c_customerid})">Suspend</button>`
                                : `<button class="btn-status-toggle btn-active-state" onclick="active(${d.c_customerid})">Approve</button>`
                        }
                    ]
                });
            }
        });
    }

    function loadWindow() {
        $("#addressModel").kendoWindow({
            width: "500px",
            title: "Restaurant Address",
            visible: false,
            actions: [
                "Close"
            ],
            modal: true
        });

        $("#accountModel").kendoWindow({
            width: "500px",
            title: "Restaurant Account",
            visible: false,
            actions: [
                "Close"
            ],
            modal: true
        });
        $("#ownerModel").kendoWindow({
            width: "500px",
            title: "Restaurant Owner",
            visible: false,
            actions: [
                "Close"
            ],
            modal: true
        });
    }


    function loadFrm() {
        $("#addressFrm").kendoForm({
            items: [
                {
                    field: "c_r_name",
                    label: "Restaurant Name",
                    editor: "TextBox",
                    editorOptions: { readonly: true }
                },
                {
                    field: "c_r_state",
                    label: "State",
                    editor: "TextBox",
                    editorOptions: { readonly: true }
                },
                {
                    field: "c_r_city",
                    label: "City",
                    editor: "TextBox",
                    editorOptions: { readonly: true }
                },
                {
                    field: "c_pincode",
                    label: "Pincode",
                    editor: "TextBox",
                    editorOptions: { readonly: true }
                },
                {
