    function active(id) {
        var token = "@Context.Session.GetString("Token")";

        Swal.fire({
            title: "Activate Restaurant?",
            text: "This restaurant will start accepting orders.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Activate",
            cancelButtonText: "Cancel"
        }).then((result) => {

            if (result.isConfirmed) {
                $.ajax({
                    url: "http://localhost:5245/api/Admin/activeRestaurant?id=" + id,
                    type: "GET",
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function () {

                        Swal.fire({
                            icon: "success",
                            title: "Activated!",
                            text: "Restaurant is now active.",
                            timer: 1800,
                            showConfirmButton: false
                        });

                        loadGrid();
                    },
                    error: function () {
                        Swal.fire("Error", "Something went wrong!", "error");
                    }
                });
            }
        });
    }


    function inactive(id) {
        var token = "@Context.Session.GetString("Token")";

        Swal.fire({
            title: "Deactivate Restaurant?",
            text: "This restaurant will stop accepting orders.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Deactivate",
            cancelButtonText: "Cancel"
        }).then((result) => {

            if (result.isConfirmed) {
                $.ajax({
                    url: "http://localhost:5245/api/Admin/inactiveRestaurant?id=" + id,
                    type: "GET",
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function () {

                        Swal.fire({
                            icon: "success",
                            title: "Deactivated!",
                            text: "Restaurant is now inactive.",
                            timer: 1800,
                            showConfirmButton: false
                        });

                        loadGrid();
                    },
                    error: function () {
                        Swal.fire("Error", "Something went wrong!", "error");
                    }
                });
            }
        });
    }
    

</script>