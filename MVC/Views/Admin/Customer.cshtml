@{
    Layout = "_Admin";
}

<style>
    
    :root {
        /* Professional Orange Color Palette */
        --primary-orange: #f97316;
        --deep-orange: #ea580c;
        --orange-light: #fff7ed;
        --primary-gradient: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        --text-heading: #0f172a;
        
        --text-body: #475569;
        --border-color: #e2e8f0;
        --accent-success: #10b981;
        --accent-danger: #ef4444;
        --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }



    /* Header Design */
    .menu-list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 30px;
        background: white;
        border-bottom: 1px solid var(--border-color);
    }

    .menu-list-header strong {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-heading);
        letter-spacing: -0.02em;
        display: block;
    }

    .header-subtitle {
        color: var(--text-body);
        font-size: 0.875rem;
        margin-top: 2px;
    }

    /* Professional Search Bar */
    .search-wrapper {
        position: relative;
        background: #f1f5f9;
        border: 1px solid transparent;
        border-radius: 10px;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        transition: all 0.3s ease;
        width: 300px;
    }

    .search-wrapper:focus-within {
        border-color: var(--primary-orange);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
        width: 340px;
    }

    .search-icon {
        color: #94a3b8;
        margin-right: 10px;
    }

    .menu-search-input {
        border: none;
        background: transparent;
        font-weight: 500;
        outline: none;
        width: 100%;
        color: var(--text-heading);
    }

    /* Kendo Grid Theming */
    #grid-menu-items {
        border: none !important;
    }

    .k-grid-header {
        background: #fff !important;
    }

    .k-grid-header th.k-header {
        color: #64748b !important;
        font-weight: 700 !important;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.05em;
        padding: 15px 20px !important;
        border-bottom: 2px solid #f1f5f9 !important;
    }

    .k-grid td {
        padding: 16px 20px !important;
        border-bottom: 1px solid #f1f5f9 !important;
    }

    .k-grid tr:hover {
        background-color: var(--orange-light) !important;
    }

    /* Custom UI Components */
    .res-identity {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .restaurant-img {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        object-fit: cover;
        border: 1px solid var(--border-color);
    }

    .status-tag {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
    }

    .tag-open {
        background: #dcfce7;
        color: #15803d;
    }

    .tag-closed {
        background: #d2e8fe;
        color: #475569;
    }

    /* Action Buttons */
    .btn-detail-group {
        display: flex;
        gap: 6px;
    }

    .btn-icon-alt {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: white;
        color: #64748b;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .btn-icon-alt:hover {
        border-color: var(--primary-orange);
        color: var(--primary-orange);
        background: var(--orange-light);
    }

    .btn-status-toggle {
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 12px;
        border: none;
        cursor: pointer;
        transition: 0.2s;
        min-width: 100px;
    }

    .btn-active-state {
        background: #d2e8fe;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .btn-active-state:hover {
        background: #e2e8f0;
        color: #1f2937;
        transform: translateY(-1px);
    }

    .btn-active-state:hover {
        @* border-color: #f97316; *@
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.08);
    }


    @@media (max-width: 768px) {
        .menu-list-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .search-wrapper {
            width: 100% !important;
        }
    }

    .card {
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
        margin: 24px;
        overflow: hidden;
        border: none;
    }

    .menu-list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 22px 26px;
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        border-bottom: 1px solid #fed7aa;
    }

    .menu-list-header strong {
        font-size: 1.6rem;
        font-weight: 800;
        color: #9a3412;
    }

    .header-subtitle {
        font-size: 0.85rem;
        color: #92400e;
    }

    .search-wrapper {
        position: relative;
        width: 280px;
        background: #ffffff;
        border-radius: 999px;
        padding: 8px 16px;
        border: 2px solid #fed7aa;
        display: flex;
        align-items: center;
        transition: all 0.25s ease;
    }

    .search-wrapper:focus-within {
        border-color: #f97316;
        box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.15);
    }

    .menu-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: 0.9rem;
        width: 100%;
        margin-left: 8px;
    }

    .k-grid-header th.k-header {
        background: transparent !important;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6b7280 !important;
        padding: 14px 18px !important;
    }

    .k-grid td {
        padding: 16px 18px !important;
        font-size: 0.9rem;
    }

    .k-grid tr:hover {
        background: #fff7ed !important;
        transform: scale(1.002);
        transition: all 0.2s ease;
    }

    .k-grid tbody tr:nth-child(even) {
        background: #fffaf5;
    }

    .status-tag {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .tag-open {
        background: linear-gradient(135deg, #ffedd5, #fed7aa);
        color: #9a3412;
    }

    .btn-icon-alt {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #fff7ed;
        border: 1px solid #f97316;
        color: #ea580c;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s ease;
    }

    .btn-icon-alt:hover {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: #fff;
        transform: translateY(-2px);
    }

    .btn-status-toggle {
        border-radius: 999px;
        padding: 8px 18px;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .btn-active-state {
        linear-gradient(135deg, #22c55e, #f1f5f9)
        color: ##475569;
    }

    .btn-inactive-state {
        background: linear-gradient(135deg, #fb923c, #ea580c);
        color: #fff;
    }


    .k-window-titlebar {
        background: linear-gradient(135deg, #f97316, #ea580c) !important;
        color: #fff !important;
        font-weight: 700;
    }


    .k-form input[readonly] {
        background: #fff7ed !important;
        border-radius: 12px !important;
        border: 1px solid #fed7aa !important;
    }


    /* ONLY for Owner Form */
#ownerFrm .k-form-label,
#ownerFrm .k-label {
    font-size: 1rem;     /* bigger */
    font-weight: 800;   /* bold */
    color: #0f172a;
    margin-bottom: 10px;
    display: block;
}


/* ===============================
   DELIVERY PARTNER STATUS
================================ */

.delivery-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
}

/* AVAILABLE */
.delivery-status.available {
    background: linear-gradient(135deg, #dcfce7, #bbf7d0);
    color: #15803d;
}

.delivery-status.available .status-dot {
    width: 10px;
    height: 10px;
    background: #22c55e;
    border-radius: 50%;
    position: relative;
}

/* Pulsing animation */
.delivery-status.available .status-dot::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.35);
    animation: pulse 1.6s infinite;
}

/* NOT AVAILABLE */
.delivery-status.offline {
    background: #f1f5f9;
    color: #475569;
}

.delivery-status.offline .status-dot {
    width: 10px;
    height: 10px;
    background: #94a3b8;
    border-radius: 50%;
}

/* Pulse animation */
@@keyframes pulse {
    0% {
        transform: scale(0.8);
        opacity: 0.7;
    }
    70% {
        transform: scale(1.6);
        opacity: 0;
    }
    100% {
        opacity: 0;
    }
}


/* ===============================
   DASHBOARD STATS CARDS
================================ */

.stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    padding: 20px 26px;
}

.stat-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 22px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    border-left: 6px solid #f97316;
    transition: all 0.25s ease;
}

.stat-card:hover {
    transform: translateY(-3px);
}

.stat-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #64748b;
    margin-bottom: 8px;
}

.stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
}

/* Card Colors – ORANGE THEME */

/* Total Customers */
.stat-card {
    border-color: var(--primary-orange);
}

/* Active Customers */
/* Active Customers – High Contrast Orange */
.stat-card.success {
    border-left: 6px solid #ea580c; /* darker orange */
    background: linear-gradient(135deg, #ffffff, #ffedd5);
}

.stat-card.success .stat-title {
    color: #9a3412;
}

.stat-card.success .stat-value {
    color: #c2410c; /* strong orange */
}


/* Inactive Customers */
.stat-card.warning {
    border-color: #c2410c; /* dark orange */
    background: linear-gradient(135deg, #ffffff, #ffedd5);
}

.stat-card.warning .stat-value {
    color: #ce5f2b; /* burnt orange */
}


/* New Customers */
.stat-card.info {
    border-color: #fb923c; /* lighter orange */
    background: linear-gradient(135deg, #ffffff, #ffedd5);
}
.stat-card.success .stat-value {
    color: #15803d;
}

.stat-card.warning .stat-value {
    color: #9a3412;
}

.stat-card.info .stat-value {
    color: #c2410c;
}

/* Total Customers – Primary Orange */
.stat-card.total {
    border-left: 6px solid #f97316; /* primary orange */
    background: linear-gradient(135deg, #ffffff, #fff7ed);
}

.stat-card.total .stat-title {
    color: #9a3412;
    font-weight: 800;
}

.stat-card.total .stat-value {
    color: #ea580c; /* bold orange */
    font-size: 2.2rem;
}



/* Responsive */
@@media (max-width: 900px) {
    .stats-row {
        grid-template-columns: repeat(2, 1fr);
    }
}

.stat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
}

.stat-icon {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    background: #fff7ed;
    color: #ea580c;
}

/* Icon color per card */
.stat-card.total .stat-icon {
    background: #fff7ed;
    color: #f97316;
}

.stat-card.success .stat-icon {
    background: #ffedd5;
    color: #ea580c;
}

.stat-card.warning .stat-icon {
    background: #fed7aa;
    color: #9a3412;
}

.stat-card.info .stat-icon {
    background: #ffedd5;
    color: #fb923c;
}




/* ===============================
   SWEETALERT2 THEME (ORANGE UI)
================================ */

/* Popup container */
.swal2-popup {
