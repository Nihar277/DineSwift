</style>
<!-- STAT CARDS -->
<!-- CUSTOMER STATS -->
<div class="stats-row">

    <div class="stat-card total">
        <div class="stat-header">
            <i class="fa-solid fa-users stat-icon"></i>
            <div class="stat-title">Total Customers</div>
        </div>
        <div class="stat-value" id="totalCustomer">0</div>
    </div>

    <div class="stat-card success">
        <div class="stat-header">
            <i class="fa-solid fa-user-check stat-icon"></i>
            <div class="stat-title">Active Customers</div>
        </div>
        <div class="stat-value" id="activeCustomer">0</div>
    </div>

    <div class="stat-card warning">
        <div class="stat-header">
            <i class="fa-solid fa-user-xmark stat-icon"></i>
            <div class="stat-title">Inactive Customers</div>
        </div>
        <div class="stat-value" id="inactiveCustomer">0</div>
    </div>

    <div class="stat-card info">
        <div class="stat-header">
            <i class="fa-solid fa-user-plus stat-icon"></i>
            <div class="stat-title">New Today</div>
        </div>
        <div class="stat-value" id="newCustomer">0</div>
    </div>

</div>



<div class="card">

    

    <div class="menu-list-header">
        <div>
            <strong>Customer Network</strong>
            <div class="header-subtitle">Manage Customer status and business profiles</div>
        </div>
         <div class="search-wrapper">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input type="text" id="search-box" class="menu-search-input" placeholder="Search by name, city..." />
            <button type="button" id="search-clear-btn"
                style="display:none; border:none; background:none; cursor:pointer; color: #94a3b8;">
                <i class="fa-solid fa-circle-xmark"></i>
            </button>
        </div>
    </div>

    <div id="grid-menu-items"></div>
</div>

<div id="addressModel">
    <form id="addressFrm" class="p-4"></form>
</div>
<div id="accountModel">
    <form id="accountFrm" class="p-4"></form>
</div>
<div id="ownerModel">
    <form id="ownerFrm" class="p-4"></form>
</div>

<script>
    $(document).ready(function () {
        loadGrid();

        // Search Implementation
        $("#search-box").on("keyup", function () {
            var val = $(this).val();
            var grid = $("#grid-menu-items").data("kendoGrid");
            if (!grid) return;

            if (val) {
                grid.dataSource.filter({
                    logic: "or",
                    filters: [
                        { field: "c_fname", operator: "contains", value: val },
                        { field: "c_lname", operator: "contains", value: val },
                        { field: "c_email", operator: "contains", value: val },
                        { field: "c_city", operator: "contains", value: val }
                    ]
                });
                $("#search-clear-btn").show();
            } else {
                grid.dataSource.filter({});
                $("#search-clear-btn").hide();
            }
        });

        $("#search-clear-btn").click(function () {
            $("#search-box").val("").focus();
            $(this).hide();
            $("#grid-menu-items").data("kendoGrid").dataSource.filter({});
        });

    });

    function loadGrid() {
        var token = "@Context.Session.GetString("Token")";
        $.ajax({
            url: "http://localhost:5245/api/Admin/getAllCustomer",
            type: "GET",
            headers: { "Authorization": "Bearer " + token },
            success: function (data) {
                console.log(data);
                var total = data.length;
                var active = data.filter(x => x.c_status === "active").length;
                var inactive = data.filter(x => x.c_status !== "active").length;

                var today = new Date().toISOString().split("T")[0];
                var newCustomers = data.filter(x => x.c_created_time?.startsWith(today)).length;

                $("#totalCustomer").text(total);
                $("#activeCustomer").text(active);
                $("#inactiveCustomer").text(inactive);
                $("#newCustomer").text(newCustomers);


                $("#grid-menu-items").kendoGrid({
                    dataSource: { data: data, schema: { model: { id: "c_customerid" } }, pageSize: 5 },
                    sortable: true,
                    filterable: true,
                    groupable: true,
                    pageable: { refresh: true, pageSizes: [5, 10, 25], buttonCount: 3 },
                    columns: [
                        {
                            field: " ", title: "Customer Details", width: 280,
                            template: function (d) {
                                return `<div class="res-identity">
                                    <img src="/Images/customer/${d.c_image}" class="restaurant-img" onerror="this.src='https://ui-avatars.com/api/?background=fff7ed&color=f97316&name=${d.c_fname} ${d.c_lname}'">
                                    <div>
                                        <div style="font-weight:700; color:var(--text-heading); font-size:14px;">${d.c_fname} ${d.c_lname}</div>
                                        <div style="font-size:12px; color:var(--text-body);">${d.c_email}</div>
                                    </div>
                                </div>`;
                            }
                        },
                        {
                            field: "c_city", title: "Location", width: 150,
                            template: (d) => `<div style="font-weight:600; color:var(--text-heading);">${d.c_city}</div><div style="font-size:11px; color:var(--text-body);">${d.c_state}</div>`
                        },
                        {
                            field: "c_gender", title: "Gender", width: 120,
                            template: (d) => {
                                const isOpen = d.c_r_isavailable == "yes";
                                return `<div style="font-weight:600; color:var(--text-heading);">${d.c_gender}</div>`;
                            }
                        }, 
                        {
                            field: "c_address", title: "Address", width: 140,
                        },
                        {
                            field: "c_phonenumber", title: "Phone No.", width: 160,
                        },
                        {
                            title: "Status", width: 140,
                            template: (d) => {
                                const isOpen = d.c_status == "active";
                                return `<span class="status-tag ${isOpen ? 'tag-open' : 'tag-closed'}">${isOpen ? 'Active' : 'Inactive'}</span>`;
                            }
                        },
                        {
                            title: "Actions", width: 140,
                            template: (d) => d.c_status == "active"
                                ? `<button class="btn-status-toggle btn-inactive-state" onclick="inactive(${d.c_customerid})">Suspend</button>`
                                : `<button class="btn-status-toggle btn-active-state" onclick="active(${d.c_customerid})">Approve</button>`
                        }
                    ]
                });
            }
        });
    }

    function active(id) {
        var token = "@Context.Session.GetString("Token")";

        Swal.fire({
            title: "Activate Customer?",
            text: "This customer will start placing orders again.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Activate",
            cancelButtonText: "Cancel"
        }).then((result) => {

            if (result.isConfirmed) {
                $.ajax({
                    url: "http://localhost:5245/api/Admin/activeCustomer?id=" + id,
                    type: "GET",
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function () {

                        Swal.fire({
                            icon: "success",
                            title: "Activated!",
                            text: "Customer is now active.",
                            timer: 1800,
                            showConfirmButton: false
                        });

                        loadGrid();
                    },
                    error: function () {
                        Swal.fire("Error", "Something went wrong!", "error");
                    }
                });
            }
        });
    }


    function inactive(id) {
        var token = "@Context.Session.GetString("Token")";

        Swal.fire({
            title: "Deactivate Customer?",
            text: "This customer will not be able to place orders.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Deactivate",
            cancelButtonText: "Cancel"
        }).then((result) => {

            if (result.isConfirmed) {
                $.ajax({
                    url: "http://localhost:5245/api/Admin/inactiveCustomer?id=" + id,
                    type: "GET",
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function () {

                        Swal.fire({
                            icon: "success",
                            title: "Deactivated!",
                            text: "Customer is now inactive.",
                            timer: 1800,
                            showConfirmButton: false
                        });

                        loadGrid();
                    },
                    error: function () {
                        Swal.fire("Error", "Something went wrong!", "error");
                    }
                });
            }
        });
    }

</script>