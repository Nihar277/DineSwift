    background: linear-gradient(135deg, #fff7ed, #ffffff) !important;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.15) !important;
    border: 1px solid #fed7aa !important;
    font-family: 'Inter', system-ui, sans-serif;
}

/* Title */
.swal2-title {
