    // Load commission statistics
    function loadCommissionStatistics(days, chartType) {
        var token = "@Context.Session.GetString("Token")";

        // Show loading state
        $("#commissionChart").data("kendoChart").setOptions({
            title: {
                text: "Loading commission data..."
            },
            series: []
        });

        $.ajax({
            url: `http://localhost:5245/api/Admin/getCommissionStats?id=${days}`,
            type: "GET",
            headers: { "Authorization": "Bearer " + token },
            success: function (data) {
                console.log("Commission Data --- ",data);
                if (data && data.length > 0) {
                    renderCommissionChart(data, days, chartType);
                } else {
                    showCommissionEmptyState();
                }
            },
            error: function (xhr, status, error) {
                console.error("Error loading commission statistics:", error);
                showCommissionErrorState();
            }
        });
    }

    // Render commission chart
    function renderCommissionChart(data, days, chartType) {
        var chart = $("#commissionChart").data("kendoChart");
        
        var categories = data.map(item => {
            console.log("render ",item.date)
            if(days >= 90){
                var d = new Date(item.date);
                return days <= 30
                    ? d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })
                    : d.toLocaleDateString('en-IN', { month: 'short', year: 'numeric' });
            }else{
                return item.date;
            }
        });

        /* ===================== DONUT ===================== */
        if (chartType === "donut") {
            chart.setOptions({
                title: {
                    text: "Platform Fee Distribution",
                    color: "#7c3aed",
                    font: "bold 14px 'Inter'"
                },
                legend: { position: "bottom" },
                series: [{
                    type: "donut",
                    data: data.map(x => ({
                        category: x.date,
                        value: x.adminComission
                    })),
                    labels: {
                        visible: true,
                        template: "₹#= kendo.toString(value, 'n0') #"
                    }
                }],
                tooltip: {
                    visible: true,
                    template: "₹ #= kendo.toString(value, 'n0') #"
                }
            });
            return;
        }

        var isStacked = chartType === "stacked";

        chart.setOptions({
            title: {
                text: "Orders vs Platform Fee",
                color: "#9a3412",
                font: "bold 14px 'Inter'"
            },

            seriesDefaults: {
                type: isStacked ? "column" : chartType,
                stack: isStacked,
                style: chartType === "line" ? "smooth" : "normal",
                markers: {
                    visible: chartType === "line",
                    size: 6
                }
            },

            series: [
                {
                    name: "Orders",
                    data: data.map(x => x.orders),
                    axis: "orders",
                    color: "#f97316",
                    stack: isStacked ? "orders" : false,
                    tooltip: {
                        template: "Orders: <strong>#= value #</strong>"
                    }
                },
                {
                    name: "Platform Fee (₹)",
                    data: data.map(x => x.adminComission),
                    axis: "revenue",
                    color: "#8b5cf6",
                    stack: isStacked ? "revenue" : false,
                    tooltip: {
                        template: "₹ <strong>#= value #</strong>"
                    }
                }
            ],

            categoryAxis: {
                categories: categories
            },
            valueAxis: [
                {
                    name: "orders",
                    title: {
                        text: "Orders",
                        color: "#f97316",
                        font: "bold 12px 'Inter'"
                    }
                },
                {
                    name: "revenue",
                    title: {
                        text: "Platform Fee (₹)",
                        color: "#8b5cf6",
                        font: "bold 12px 'Inter'"
                    },
                    labels: {
                        format: "₹{0}"
                    },
                    opposite: true
                }
            ]
        });
    }

