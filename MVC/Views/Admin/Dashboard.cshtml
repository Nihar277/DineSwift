    function loadTodaysOrderStatus() {
        var token = "@Context.Session.GetString("Token")";

        // Show loading state
        $("#todaysOrdersChart").data("kendoChart").setOptions({
            title: {
                text: "Loading today's orders..."
            },
            series: []
        });

        $.ajax({
            url: "http://localhost:5245/api/Admin/getTodayOrderStatus",
            type: "GET",
            headers: { "Authorization": "Bearer " + token },
            success: function (data) {
                console.log("data --- ",data);
                if (data && data.length > 0) {
                    renderTodaysChart(data);
                } else {
                    showTodaysEmptyState();
                }
            },
            error: function (xhr, status, error) {
                console.error("Error loading today's order status:", error);
                // Show demo data
                var demoData = [
                    { c_orderstatus: "Delivered", total_orders: 45, color: "#10b981", icon: "fa-check-circle" },
                    { c_orderstatus: "Out for delivery", total_orders: 25, color: "#f59e0b", icon: "fa-truck" },
                    { c_orderstatus: "Processing", total_orders: 35, color: "#3b82f6", icon: "fa-cogs" },
                    { c_orderstatus: "Prepared", total_orders: 15, color: "#8b5cf6", icon: "fa-check" }
                ];
                renderTodaysChart(demoData);
            }
        });
    }

    function renderTodaysChart(data) {
        var chart = $("#todaysOrdersChart").data("kendoChart");

        // Prepare chart data
        var chartData = prepareTodaysChartData(data);

        // Calculate total orders
        var totalOrders = chartData.reduce(function (sum, item) {
            return sum + item.value;
        }, 0);

        // Update chart
        chart.setOptions({
            title: {
                text: totalOrders > 0 ?
                    `Today's Orders: ${totalOrders}` :
                    "No orders today",
                color: totalOrders > 0 ? "#9a3412" : "#94a3b8",
                font: "bold 16px 'Inter', sans-serif"
            },
            series: [{
                name: "Orders",
                data: chartData.map(item => item.value),
                color: function (point) {
                    return point.dataItem.color;
                },
                labels: {
                    visible: true,
                    background: "transparent",
                    color: "#0f172a",
                    font: "bold 12px 'Inter', sans-serif",
                    format: "{0}"
                }
            }],
            categoryAxis: {
                categories: chartData.map(item => item.category)
            },
            valueAxis: {
                title: {
                    text: "Number of Orders",
                    color: "#f97316",
                    font: "bold 12px 'Inter', sans-serif"
                }
            }
        });
    }

    function prepareTodaysChartData(data) {
        // Define status configuration
        var statusConfig = {
            "Delivered": {
                displayName: "Delivered",
                color: "#10b981",
                icon: "fa-check-circle"
            },
            "Out for delivery": {
                displayName: "Out for Delivery",
                color: "#f59e0b",
                icon: "fa-truck"
            },
            "Processing": {
                displayName: "Processing",
                color: "#3b82f6",
                icon: "fa-cogs"
            },
            "Prepared": {
                displayName: "Prepared",
                color: "#8b5cf6",
                icon: "fa-check"
            }
        };

        // Ensure all statuses are included
        var allStatuses = Object.keys(statusConfig);
        var finalData = [];

        allStatuses.forEach(function (status) {
            var item = data.find(d => d.c_orderstatus === status) || {
                c_orderstatus: status,
                total_orders: 0
            };

            var config = statusConfig[status];
            finalData.push({
                category: config.displayName,
                value: item.total_orders || 0,
                color: config.color,
                icon: config.icon
            });
        });

        return finalData;
    }

