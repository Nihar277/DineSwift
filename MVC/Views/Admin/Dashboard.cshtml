                    top: 30,
                    right: 30,
                    bottom: 50
                }
            },
            title: {
                text: "Loading data...",
                color: "#64748b",
                font: "14px 'Inter', sans-serif",
                position: "top"
            },
            legend: {
                position: "top",
                labels: {
                    font: "12px 'Inter', sans-serif",
                    color: "#475569"
                }
            },
            seriesDefaults: {
                type: "line",
                style: "smooth",
                markers: {
                    visible: true,
                    size: 6
                }
            },
            series: [],
            categoryAxis: {
                labels: {
                    font: "11px 'Inter', sans-serif",
                    color: "#64748b"
                },
                line: {
                    color: "#e2e8f0"
                },
                majorGridLines: {
                    visible: true,
                    color: "#f1f5f9"
                }
            },
            valueAxis: {
                labels: {
                    font: "11px 'Inter', sans-serif",
                    color: "#64748b"
                },
                line: {
                    color: "#e2e8f0"
                },
                majorGridLines: {
                    visible: true,
                    color: "#f1f5f9"
                }
            },
            tooltip: {
                visible: true,
                template: "<div class='k-chart-tooltip'>" +
                    "<div class='k-tooltip-title'>#= category #</div>" +
                    "<div class='k-tooltip-content'>" +
                    "<span style='color:#f97316'>Orders: </span><strong>#= value #</strong><br/>" +
                    "<span style='color:#10b981'>Revenue: </span><strong>₹#= series.dataItem.revenue #</strong>" +
                    "</div></div>",
                shared: true,
                format: "{0}"
            },
            transitions: true
        });
    }

    function loadOrderStatistics(days, chartType) {
        var token = "@Context.Session.GetString("Token")";

        // Show loading state
        $("#ordersChart").data("kendoChart").setOptions({
            title: {
                text: "Loading data..."
            },
            series: []
        });

        $.ajax({
            url: `http://localhost:5245/api/Admin/getOrderStats?days=${days}`,
            type: "GET",
            headers: { "Authorization": "Bearer " + token },
            success: function (data) {
                if (data && data.length > 0) {
                    renderOrdersChart(data, days, chartType);
                } else {
                    showEmptyChartState();
                }
            },
            error: function (xhr, status, error) {
                console.error("Error loading order statistics:", error);
                showErrorChartState();
            }
        });
    }

    function renderOrdersChart(data, days, chartType) {
        var chart = $("#ordersChart").data("kendoChart");

        var categories = data.map(item => {
            var date = new Date(item.date);
            return days <= 30
                ? date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })
                : date.toLocaleDateString('en-IN', { month: 'short', year: 'numeric' });
        });

        // Calculate totals for title
        var totalOrders = data.reduce((sum, item) => sum + item.orders, 0);
        var totalRevenue = data.reduce((sum, item) => sum + item.revenue, 0);

        /* ===================== DONUT CHART ===================== */
        if (chartType === "donut") {
            chart.setOptions({
                title: {
                    text: "Revenue Distribution",
                    color: "#9a3412",
                    font: "bold 14px 'Inter'"
                },
                legend: {
                    position: "bottom"
                },
                series: [{
                    type: "donut",
                    data: data.map(x => ({
                        category: x.date,
                        value: x.revenue
                    })),
                    labels: {
                        visible: true,
                        template: "₹#= kendo.toString(value, 'n0') #"
                    }
                }],
                tooltip: {
                    visible: true,
                    template: "₹ #= kendo.toString(value, 'n0') #"
                }
            });
            return;
        }

        /* ===================== FLAGS ===================== */
        var isCombo = chartType === "combo";
        var isStacked = chartType === "stacked";
        var showRevenue = !isStacked;

        chart.setOptions({
            title: {
                text: `${days} Day Order Trends • Total: ${totalOrders} Orders (₹${totalRevenue.toLocaleString('en-IN')})`,
                color: "#9a3412",
                font: "bold 14px 'Inter'"
            },

            seriesDefaults: {
                type: isCombo ? "column" : (isStacked ? "column" : chartType),
                stack: isStacked,
                style: chartType === "line" ? "smooth" : "normal"
            },

            series: [
                {
                    name: "Orders",
                    data: data.map(x => x.orders),
                    color: "#f97316",
                    axis: "orders",
                    field: "orders",
                    stack: isStacked ? "orders" : false,
                    tooltip: {
                        template: "<div>Orders: <strong>#= value #</strong></div>"
                    }
                },
                {
                    name: "Revenue (₹)",
                    data: data.map(x => x.revenue),
                    color: "#10b981",
                    axis: "revenue",
                    visible: showRevenue,
                    tooltip: {
                        template: "<div>Revenue: <strong>₹#= value #</strong></div>"
                    }
                }
            ],

            categoryAxis: {
                categories: categories
            },

            valueAxis: [
                {
                    name: "orders",
                    title: {
                        text: "Orders",
                        color: "#f97316",
                        font: "bold 12px 'Inter', sans-serif"
                    },
                    labels: {
                        format: "{0}"
                    }
                },
                {
                    name: "revenue",
                    title: {
                        text: "Revenue (₹)",
                        color: "#10b981",
                        font: "bold 12px 'Inter', sans-serif"
                    },
                    labels: {
                        format: "₹{0}"
                    },
                    opposite: true
                }
            ],
        });
    }

    function changePeriod(days) {
        // Update active button
        $('.period-btn').removeClass('active');
        $(`.period-btn[data-period="${days}"]`).addClass('active');

        // Get current chart type
        var chartType = $('.type-btn.active').attr('title').toLowerCase().replace(' chart', '');

        // Reload chart with new period
        loadOrderStatistics(days, chartType);
    }

    function changeChartType(type) {
        // Update active button
        $('.type-btn').removeClass('active');
        $(`.type-btn[title="${type.charAt(0).toUpperCase() + type.slice(1)} Chart"]`).addClass('active');

        // Get current period
        var period = $('.period-btn.active').data('period');

        // Reload chart with new type
        loadOrderStatistics(period, type);
    }

    function showEmptyChartState() {
        var chart = $("#ordersChart").data("kendoChart");
        chart.setOptions({
            title: {
                text: "No Data Available",
                color: "#94a3b8"
            },
            series: []
        });

        $("#chartStats").html(`
            <div class="chart-empty-state">
                <i class="fa-solid fa-chart-line"></i>
                <p>No order data available for the selected period</p>
                <button class="retry-btn" onclick="loadOrderStatistics(7, 'line')">
                    Try Again
                </button>
            </div>
        `);
    }

    function showErrorChartState() {
        var chart = $("#ordersChart").data("kendoChart");
        chart.setOptions({
            title: {
                text: "Error Loading Data",
                color: "#ef4444"
            },
            series: []
        });

        $("#chartStats").html(`
            <div class="chart-empty-state">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <p>Failed to load order statistics</p>
                <p style="font-size: 0.9rem;">Please check your connection and try again</p>
                <button class="retry-btn" onclick="loadOrderStatistics(7, 'line')">
                    <i class="fa-solid fa-rotate"></i> Retry
                </button>
            </div>
        `);
    }

